{% extends 'orders_app/skeleton.twig' %}

{% block content %}{% verbatim %}
<div id="app">
	<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
	    <h1 class="h4">
	    	<a href="/orders-app/" class="text-decoration-none"><i class="fa-solid fa-house"></i></a> /
	    	Προσθήκη /
	    	{{order.table.name}}
	    </h1>
    	<div class="btn-toolbar">
	       	<button type="button" class="btn btn-lg btn-primary" @click="save">
	            <span class="spinner-border spinner-border-sm" v-if="fetchingData"></span>
	            <i class="fa-solid fa-floppy-disk" v-if="!fetchingData"></i>
	            <span class="d-none d-sm-none d-md-inline"> Αποθήκευση</span>
	        </a>
	    </div>
	</div>
	<div class="row gx-1 mb-2">
		<div class="col">
			<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="showNotesModal = true">
				<i class="fa-solid fa-comments"></i>
				<span class="d-none d-sm-inline"> Σχόλια</span>
				<span v-if="order.notes.length > 0"> <i class="fa-solid fa-ellipsis"></i></span>
			</button>
		</div>
        <div class="col">
        	<button type="button" class="btn btn-lg btn-outline-primary w-100" @click="timing = null">
				<i class="fa-regular fa-clock"></i>
				<span class="d-none d-sm-inline"> Χρόνος</span>
				<span v-if="timing != null"> [{{timing}}]</span>
			</button>
        </div>
        <div class="col">
        	<button type="button" class="btn btn-lg btn-outline-primary w-100" @click="family = null">
				<i class="fa-solid fa-people-group"></i>
				<span class="d-none d-sm-inline"> Οικογένεια</span>
				<span v-if="family != null"> [{{family}}]</span>
			</button>
        </div>
	</div>

	<div class="modal" tabindex="-1" :class="showNotesModal ? 'd-block' : ''">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">
        				<i class="fa-solid fa-comments"></i> Σχόλια
        			</h5>
      			</div>
      			<div class="modal-body">
		        	<div class="row gx-1">
		        		<textarea class="form-control" v-model="order.notes" rows="3"></textarea>
		        	</div>
      			</div>
      			<div class="modal-footer">
        			<button type="button" class="btn btn-secondary" @click="showNotesModal = false">Κλείσιμο</button>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="modal" tabindex="-1" :class="timing == null ? 'd-block' : ''">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">
        				<i class="fa-regular fa-clock"></i> Επιλογή χρόνου
        			</h5>
      			</div>
      			<div class="modal-body">
		        	<div class="row gx-1">
		        		<div class="col-sm-12 mb-2">
		        			<div class="col-sm-12 mb-2" v-for="n in 5">
		        				<button
		        					type="button"
		        					class="btn btn-outline-primary w-100"
		        					@click="timing = n;"
		        				>
		        					{{n}}
		        				</button>
		        			</div>
		        		</div>
		        	</div>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="modal" tabindex="-1" :class="family == null ? 'd-block' : ''">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">
        				<i class="fa-solid fa-people-group"></i> Επιλογή οικογένειας
        			</h5>
      			</div>
      			<div class="modal-body">
		        	<div class="row gx-1">
		        		<div class="col-sm-12 mb-2" v-for="n in 12">
		        			<button
		        				type="button"
		        				class="btn btn-outline-primary w-100"
		        				@click="family = n;"
		        			>
		        				{{n}}
		        			</button>
		        		</div>
		        	</div>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="sticky-top">
		<button
			type="button"
			class="btn btn-lg btn-primary w-100 mt-2 mb-2"
			@click="isMenuSectionsModalVisible = true"
		>
			<i class="fa-solid fa-plus"></i> Προσθήκη
		</button>
	</div>

	<div class="modal modal-lg" :class="isMenuSectionsModalVisible ? 'd-block' :''" tabindex="-1">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">Επιλογή κατηγορίας</h5>
        			<button type="button" class="btn-close" @click="isMenuSectionsModalVisible = false"></button>
      			</div>
      			<div class="modal-body">
					<div class="row gx-1">
		        		<div class="col-sm-6 mb-2" v-for="menuSection in menuSections">
		        			<button
		        				type="button"
		        				class="btn btn-lg btn-outline-primary w-100"
		        				@click="activeMenuSection = menuSection;isMenuSectionsModalVisible = false "
		        			>
		        				{{getTranslation(menuSection, 'el').name}}
		        			</button>
		        		</div>
		        	</div>
      			</div>
      			<div class="modal-footer">
        			<button type="button" class="btn btn-lg btn-secondary" @click="isMenuSectionsModalVisible = false">
        				Κλείσιμο
        			</button>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="modal modal-lg d-block" v-if="activeMenuSection != null">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">Επιλογή πιάτου</h5>
        			<button
        				type="button"
        				class="btn-close"
        				@click="activeMenuSection = null;isMenuSectionsModalVisible = false"
        			></button>
      			</div>
      			<div class="modal-body">
					<div class="row gx-1">
		        		<div class="col-sm-6 mb-2" v-for="menuItem in activeMenuSection.menuItems">
		        			<div class="btn-group w-100">
  								<button v-if="menuItem.isPricePerKg"
  									type="button"
  									class="btn btn-lg btn-outline-primary w-75"
  									@click="showMenuItemOptionsModal(menuItem)"
  								>
  									{{getTranslation(menuItem, 'el').name}}
  									({{menuItem.price}}&euro;/Kg)
  								</button>
  								<button v-else
  									type="button"
  									class="btn btn-lg btn-outline-primary w-75"
  									@click="addOrderEntry({
  										menuItem: menuItem,
  										timing: isDrink(menuItem) ? 6 : isBread(menuItem) ? 0 : timing,
  										family: family,
  										notes: '',
  										orderEntryExtras: []
  									});
  									activeMenuSection = null"
  								>
  									{{getTranslation(menuItem, 'el').name}} ({{menuItem.price}}&euro;)
  								</button>
  								<button
  									type="button"
  									class="btn btn-lg btn-outline-primary w-25"
  									@click="showMenuItemOptionsModal(menuItem)"
  								>
  									<i class="fa-solid fa-gear"></i>
  								</button>
							</div>
		        		</div>
		        	</div>
      			</div>
      			<div class="modal-footer">
        			<button
        				type="button"
        				class="btn btn-lg btn-secondary"
        				@click="activeMenuSection = null; isMenuSectionsModalVisible = true"
        			>
        				Πίσω
        			</button>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="modal d-block" v-if="activeOrderEntry != null">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">Επιλογές</h5>
        			<button
        				type="button"
        				class="btn-close"
        				@click="activeOrderEntry = null;"
        			></button>
      			</div>
      			<div class="modal-body">
					<div class="mb-3" v-if="activeOrderEntry.menuItem.isPricePerKg">
						<label class="form-label">
							<i class="fa-solid fa-scale-unbalanced"></i> Βάρος (γρ)
						</label>
						<input
							class="form-control"
							type="number"
							min="50"
							step="1"
							v-model="activeOrderEntry.weight"/>
					</div>
					<div class="form-check form-control-lg mb-2" v-for="extra in activeOrderEntry.menuItem.menuItemExtras">
  						<label class="form-check-label w-100">
	  						<input
	  							class="form-check-input"
	  							type="checkbox"
	  							:value="extra"
	  							v-model="activeOrderEntry.orderEntryExtras"
	  						>
							{{extra.name}} <span v-if="extra.price != 0">({{extra.price}} &euro;)</span>
  						</label>
					</div>
					<div class="mb-3" v-if="!isBread(activeOrderEntry.menuItem)">
						<label class="form-label"><i class="fa-regular fa-clock"></i> Χρόνος</label>
						<select class="form-select form-control-lg mb-2" v-model="activeOrderEntry.timing">
							<option v-for="i in 5">{{i}}</option>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label"><i class="fa-solid fa-people-group"></i> Οικογένεια</label>
						<select class="form-select form-control-lg mb-2" v-model="activeOrderEntry.family">
							<option v-for="i in 12">{{i}}</option>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label"><i class="fa-solid fa-comments"></i> Σχόλια</label>
  						<textarea
  							class="form-control form-control-lg"
  							rows="2"
  							v-model="activeOrderEntry.notes"
  						></textarea>
					</div>
      			</div>
      			<div class="modal-footer">
      				<button
        				type="button"
        				class="btn btn-lg btn-secondary"
        				@click="activeOrderEntry = null"
        			>Πίσω</button>
        			<button
        				type="button"
        				class="btn btn-lg btn-primary"
        				@click="
        					activeOrderEntry = null
        				"
        			>Ok</button>
      			</div>
    		</div>
  		</div>
	</div>

	<div class="modal d-block" v-if="newMenuItem != null">
  		<div class="modal-dialog modal-fullscreen-sm-down">
    		<div class="modal-content">
      			<div class="modal-header">
        			<h5 class="modal-title">Επιλογές</h5>
        			<button
        				type="button"
        				class="btn-close"
        				@click="newMenuItem = null;activeMenuSection = null; isMenuSectionsModalVisible = false"
        			></button>
      			</div>
      			<div class="modal-body">
					<div class="mb-3" v-if="newMenuItem.isPricePerKg">
						<label class="form-label">
							<i class="fa-solid fa-scale-unbalanced"></i> Βάρος (γρ)
						</label>
						<input class="form-control form-control-lg" type="number" min="50" step="1" v-model="newOrderEntry.weight"/>
					</div>
					<div class="form-check form-control-lg mb-2" v-for="extra in newMenuItem.menuItemExtras">
  						<label class="form-check-label w-100">
	  						<input
	  							class="form-check-input"
	  							type="checkbox"
	  							:value="extra"
	  							v-model="newOrderEntry.orderEntryExtras"
	  						>
		    				{{extra.name}} <span v-if="extra.price != 0">({{extra.price}} &euro;)</span>
  						</label>
					</div>
					<div v-if="isBread(newMenuItem)">
						<input type="hidden" value="0" v-model="newOrderEntry.timing">
					</div>
					<div v-else-if="isDrink(newMenuItem)">
						<input type="hidden" value="6" v-model="newOrderEntry.timing">
					</div>
					<div class="mb-3" v-else>
						<label class="form-label">
							<i class="fa-regular fa-clock"></i> Χρόνος
						</label>
						<select class="form-select form-control-lg mb-2" v-model="newOrderEntry.timing">
							<option v-for="i in 5">{{i}}</option>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label">
							<i class="fa-solid fa-people-group"></i> Οικογένεια
						</label>
						<select class="form-select form-control-lg mb-2" v-model="newOrderEntry.family">
							<option v-for="i in 12">{{i}}</option>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label">
							<i class="fa-solid fa-comments"></i> Σχόλια
						</label>
  						<textarea
  							class="form-control form-control-lg"
  							rows="2"
  							v-model="newOrderEntry.notes"
  						></textarea>
					</div>
      			</div>
      			<div class="modal-footer">
      				<button
        				type="button"
        				class="btn btn-lg btn-secondary"
        				@click="newMenuItem = null"
        			>Πίσω</button>
        			<button
        				type="button"
        				class="btn btn-lg btn-primary"
        				@click="
        					newOrderEntry.menuItem = newMenuItem;
        					addOrderEntry(newOrderEntry);
        					newMenuItem = null;
        					activeMenuSection = null;
        					newOrderEntry = {notes:'', orderEntryExtras: []};
        				"
        			>Ok</button>
      			</div>
    		</div>
  		</div>
	</div>

	<div v-for="(n, i) in 7">
		<div class="list-group" >
			<a
				class="list-group-item list-group-item-action"
				v-for="orderEntry in filteredEntries(i)"
				@click="activeOrderEntry = orderEntry"
				:style="{'opacity': orderEntry.id ? '0.5' : '1' }"
			>
	  			<div class="d-flex w-100 justify-content-between">
	      			<h5 class="mb-1">
	      				<span v-if="orderEntry.quantity > 1">
	      					{{orderEntry.quantity}} &times;
	      				</span>
	      				{{getTranslation(orderEntry.menuItem, 'el').name}}
	      				({{orderEntry.price}}&euro;)
	      			</h5>
	      			<div v-if="!orderEntry.id">
	      				<button
	      					type="button"
	      					class="btn btn-lg btn-secondary me-2"
	      					@click.stop="if (orderEntry.quantity > 1) { orderEntry.quantity--; } else { deleteOrderEntry(orderEntry.index) }"
	      				>
		      				<i class="fa-solid fa-minus"></i>
		      			</button>
		      			<button
		      				type="button"
		      				class="btn btn-lg btn-secondary me-2"
		      				@click.stop="orderEntry.quantity++"
		      			>
		      				<i class="fa-solid fa-plus"></i>
		      			</button>
		      			<!--<button type="button" class="btn btn-secondary" @click.stop="deleteOrderEntry(orderEntry.index)">
		      				<i class="fa-regular fa-trash-can"></i>
		      			</button>-->
		      		</div>
	    		</div>
	    		<div class="mb-1">
	    			<p class="mb-0" v-if="orderEntry.family != 1 || orderHasManyFamilies()">
	    				<i class="fa-solid fa-people-group"></i> {{orderEntry.family}}
	    			</p>
	    			<p class="mb-0" v-if="orderEntry.weight > 0">
	    				<i class="fa-solid fa-scale-unbalanced"></i> {{`${orderEntry.weight / 1000}Kg`}},
	    			</p>
	    			<p class="mb-0" v-if="orderEntry.orderEntryExtras.length > 0">
	    				<span v-for="extra in orderEntry.orderEntryExtras">
		    				{{extra.name}},
		    			</span>
	    			</p>
	    			<p class="mb-0" v-if="orderEntry.notes.length > 0">{{orderEntry.notes}}</p>
	    		</div>
	  		</a>
		</div>
		<hr v-if="filteredEntries(i).length > 0"/>
	</div>
</div>
{% endverbatim %}{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script src="https://unpkg.com/vue@3"></script>
	<script src="https://unpkg.com/axios"></script>
	<script src="https://unpkg.com/lodash"></script>
	<script src="/assets/js/epos-2.24.0.js"></script>
	<script>
		vueApp = Vue.createApp({
		    data() {
		    	return {
		    		fetchingData: false,
		    		isMenuSectionsModalVisible: false,
		    		showNotesModal: false,

		    		activeMenuSection: null,
		    		newMenuItem: null,
		    		activeOrderEntry: null,

		    		menuSections: [],

		    		family: 1,
		    		timing: 1,

		    		newOrderEntry: {
		    			orderEntryExtras: [],
		    			notes: '',
		    			weight: null
		    		},

		    		stations: [],
		    		epos: null,

		    		order: {
		    			table: {},
		    			adults: null,
		    			minors: null,
		    			notes: '',
		    			orderEntries: []
		    		}
		    	}
		    },
		    mounted () {
		    	let id = new URLSearchParams(window.location.search).get('id');

		    	axios({
                    url: '/admin/graph-ql?useCachedResults=true',
                    method: 'post',
                    data: `{
                        menuSections {
                            id, translations { name, language } ,
                            menuItems: activeMenuItems {
                            	id, isPricePerKg, isDrink, price, translations { name, language },
                            	menuItemExtras {
                            		id, name, price
                            	},
                            	stations {id, name, printerAddress}
                            }
                        },
                        tables {
                        	id, name
                        },
                        stations {
                        	id, name, printerAddress
                        },
                        employees {
                        	id, fullName
                        }
                    }`
                }).then(response => {
                    this.menuSections = response.data.data.menuSections
                    this.tables = response.data.data.tables
                    this.stations = response.data.data.stations
                    this.employees = response.data.data.employees;
                });

		    	axios({
                    url: '/admin/graph-ql',
                    method: 'post',
                    data: `{
                        order (id: ${id}) {
	                        id,
	                        table {
	                        	id, name
	                        },
	                        notes,
	                        adults, minors
	                        orderEntries {
	                        	id, discount, timing, family, quantity, notes, price, weight,
	                        	menuItem {
	                        		id, price, translations { name, language },
	                        		menuItemExtras {
                            			name, price
                            		}
	                        	},
	                        	orderEntryExtras {
	                        		id, name, price
	                        	}
	                        }
	                    }
                    }`
                }).then(response => {
                    this.order = response.data.data.order;
                });
		    },
		    watch: {
		        'order.orderEntries': {
		            handler: function ()  {
		                _.each(this.order.orderEntries, orderEntry => {

			                let price = orderEntry.menuItem.price;

				    		if (orderEntry.weight != null) {
				    			let weight = orderEntry.weight;

				    			if (weight < 1000) {
				    				price -= (price * ((1000 - weight) / 1000));
				    			} else {
				    				price += price * ((weight - 1000) / 1000);
				    			}
				    		}

				    		_.each(orderEntry.orderEntryExtras, extra => {
				    			price += extra.price;
				    		})

				    		price = orderEntry.quantity * price;

				    		orderEntry.price = _.round(price, 1);
				    	});
		            },
		            deep: true,
		            immediate: false
		        },
		        'stations' : {
		        	handler: function ()  {
			        	let isTrue = _.reduce(this.stations, function(result, station) {
	  						return result && station.printOk;
						}, true);

						if (isTrue) {
							window.location.href = '/orders-app/';
						}
					},
					deep: true,
		            immediate: false
		        }
		    },
			methods: {
				getTranslation(object, language) {
					return _.find(object.translations, translation => {
						return translation.language == language;
					});
				},
				orderHasManyFamilies() {
		    		let index = this.order.orderEntries.findIndex(
		    			orderEntry => orderEntry.family != 1
		    		)

		    		return index != -1;
		    	},
				filteredEntries(timing) {
		    		return this.order.orderEntries.filter(orderEntry =>
		    			orderEntry.timing == timing
		    		);
		    	},
		    	newOrderEntries(timing) {
		    		return this.order.orderEntries.filter(orderEntry =>
		    			_.isUndefined(orderEntry.id) && orderEntry.timing == timing
		    		);
		    	},
		    	addOrderEntry(newOrderEntry) {
		    		/*let index = this.order.orderEntries.findIndex(
		    			orderEntry =>
		    				orderEntry.menuItem.id == newOrderEntry.menuItem.id
		    				&& orderEntry.family == newOrderEntry.family
		    				&& orderEntry.timing == newOrderEntry.timing
		    				&& orderEntry.notes == newOrderEntry.notes
		    				&& _.isEqual(orderEntry.orderEntryExtras, newOrderEntry.orderEntryExtras)
		    		);

	    			if (index != -1) {
	    				this.order.orderEntries[index].quantity++;
	    			} else {*/
		    			if (this.isBread(newOrderEntry.menuItem)) {
		    				index = this.breadEntries().length;
		    				timing = 0;
		    			} else if (this.isDrink(newOrderEntry.menuItem)) {
		    				index = this.breadEntries().length + this.foodEntries().length + this.drinkEntries().length;
		    				timing = 6; //timing 6 is for drinks
		    			} else {
		    				index = this.breadEntries().length + this.foodEntries().length;
		    				timing = newOrderEntry.timing;
		    			}

		    			this.order.orderEntries.splice(index, 0, {
			    			index: index,
			    			quantity: 1,
			    			family: newOrderEntry.family,
			    			timing: timing,
			    			menuItem: newOrderEntry.menuItem,
			    			orderEntryExtras: newOrderEntry.orderEntryExtras,
			    			notes: newOrderEntry.notes,
			    			weight: newOrderEntry.weight,
			    			price: this.orderEntryPrice(newOrderEntry)
			    		});
			    	//}
		    	},
		    	showMenuItemOptionsModal (menuItem) {
		    		this.newMenuItem = menuItem;
		    		this.newOrderEntry.timing = this.timing;
					this.newOrderEntry.family = this.family;
					this.newOrderEntry.notes = '';

		    		if (menuItem.isPricePerKg) {
	  					this.newOrderEntry.weight = '';
		    		}
		    	},
		    	foodEntries() {
		    		return this.order.orderEntries.filter(orderEntry =>
		    			!this.isBread(orderEntry.menuItem) &&
		    			!this.isDrink(orderEntry.menuItem)
		    		);
		    	},
		    	breadEntries() {
		    		return this.order.orderEntries.filter(orderEntry => this.isBread(orderEntry.menuItem));
		    	},
		    	drinkEntries() {
		    		return this.order.orderEntries.filter(orderEntry => this.isDrink(orderEntry.menuItem));
		    	},
		    	isBread(menuItem) {
		    		return menuItem.id == 1;
		    	},
		    	isDrink(menuItem) {
		    		return menuItem.isDrink;
		    	},
		    	orderEntryPrice(orderEntry) {
		    		let price = orderEntry.menuItem.price;

		    		if (orderEntry.menuItem.isPricePerKg) {
		    			let weight = orderEntry.weight;

		    			if (weight < 1000) {
		    				price -= (price * ((1000 - weight) / 1000));
		    			} else {
		    				price += price * ((weight - 1000) / 1000);
		    			}
		    		}

		    		_.each(orderEntry.orderEntryExtras, extra => {
		    			price += extra.price;
		    		})

		    		return price;
		    	},
		    	deleteOrderEntry(i) {
		    		let index = this.order.orderEntries.findIndex(
		    			orderEntry => orderEntry.index == i
		    		)
		    		this.order.orderEntries.splice(index, 1);
		    	},
		    	save () {
		    		this.fetchingData = true;
		    		axios.post('/orders-app/add', this.order)
		                .then(response => {
		                    if (response.data == 'ok') {
		                    	this.printOrder();
		                    } else {
		                    	console.log(response.data);
		                    }
		                }).catch(function (error) {
	    					console.log(error);
	  					});
		    	},
		    	printOrder() {
					_.each(this.stations, station => {
						var today = new Date();
						let printer = new epson.ePOSBuilder();

						printer.addText(`${today.getHours()}:${today.getMinutes() < 10 ? '0' + today.getMinutes() : today.getMinutes()}\n`);
						printer.addTextFont(printer.FONT_B);
						printer.addTextSmooth(true);
						printer.addFeedLine(1);
						printer.addTextAlign(printer.ALIGN_CENTER);
						printer.addTextSize(3, 3);
						printer.addText(`Τραπέζι ${this.order.table.name}\n`);
						printer.addFeedLine(1);
						printer.addTextSize(2, 2);
						printer.addText('+++ EXTRA +++');
						printer.addFeedLine(2);
						if (this.order.notes.length > 0) {
							printer.addText(`***\n${this.order.notes}\n***`);
						}
						printer.addFeedLine(2);
						printer.addText(`\n--------------------------------\n`);
						printer.addFeedLine(1);
						printer.addTextAlign(printer.ALIGN_LEFT);
						printer.addTextLineSpace(40);

						let orderEntriesCount = 0;
						for (i = 0; i < 7; i++) {
							_.each(this.newOrderEntries(i), orderEntry => {
								let index = _.findIndex(orderEntry.menuItem.stations, s => s.id == station.id);

								if (index != -1) {
									orderEntriesCount++;
									let quantity = orderEntry.quantity;
									let name = this.getTranslation(orderEntry.menuItem, 'el').name;
									let nameEn = this.getTranslation(orderEntry.menuItem, 'en').name;

									let weight = '';
									if (orderEntry.weight != null) {
										weight = `${orderEntry.weight / 1000}Kg`;
									}

									let tickboxes = '';
									if (quantity > 1 && nameEn != 'Bread') { //TODO
										for (j = 0; j < quantity; j++) {
											tickboxes += '[]';
										}
									}

									if (quantity > 6) {
										printer.addText(`${quantity} x ${name} ${weight} \n\t${tickboxes}\n`);
									} else {
										printer.addText(`${quantity} x ${name} ${weight} ${tickboxes}\n`);
									}

									if (this.orderHasManyFamilies()) {
										printer.addText(`\t(F${orderEntry.family})\n`);
									}

									_.each(orderEntry.orderEntryExtras, orderEntryExtra => {
										printer.addText(`\t${orderEntryExtra.name}\n`);
									});

									if (orderEntry.notes.length > 0) {
										printer.addText(`\t${orderEntry.notes}\n`);
									}
								}
							});
							if (this.filteredEntries(i + 1).length > 0 && orderEntriesCount > 0) {
								printer.addText(`--------------------------------\n`);
								printer.addFeedLine(1);
							}
						}

						printer.addFeedLine(10);
						printer.addCut(printer.CUT_FEED);
						if (orderEntriesCount > 0) {
							//printer.send();
							station.printOk = false;
							var address = `https://${station.printerAddress}/cgi-bin/epos/service.cgi?devid=local_printer&timeout=10000`;
 							//Create an ePOS-Print object
 							var epos = new epson.ePOSPrint(address);
 							//Send the print document
 							epos.onreceive = function (res) {
 								if (!res.success) {
 									alert(`A print error occurred. Station ${station.name}`);
 								} else {
 									station.printOk = true;
 								}
 							}
 							epos.send(printer.toString());
						} else {
							station.printOk = true;
						}
					});
		    	},
			}
		}).mount('#app');
	</script>
{% endblock %}