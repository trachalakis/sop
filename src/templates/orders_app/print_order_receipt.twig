{% extends 'orders_app/skeleton.twig' %}

{% block content %}{% verbatim %}
<div id="app">
	<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
	    <h1>
	    	<a href="/orders-app/" class="text-decoration-none"><i class="bi bi-fork-knife"></i></a> /
	    	{{order.table.name}} / {{order.adults}} / {{order.minors}} / &euro;{{totalPrice}}
	    </h1>
    	<div class="btn-toolbar">
	       	<a href="#" class="btn btn-lg btn-outline-secondary me-2 d-inline d-sm-none" @click="showOptions = true;">
	            <span class="fw-bold">&ctdot;</span>
	        </a>
	       	<div class="d-none d-sm-flex">
		       	<div class="dropdown me-2">
	  				<button class="btn btn-outline-secondary btn-lg dropdown-toggle" type="button" data-bs-toggle="dropdown">
	    				<i class="fa-solid fa-language"></i> <span class="d-none d-sm-none d-md-inline">{{activeLanguage.name}}</span>
	  				</button>
	  				<ul class="dropdown-menu fs-4">
	    				<li v-for="language in languages">
	    					<a class="dropdown-item" href="#" @click="activeLanguage = language">{{language.name}}</a>
	    				</li>
	  				</ul>
				</div>
                <template v-if="receiptPrinters.length == 1">
                    <button
                        type="button"
                        class="btn btn-primary btn-lg me-2"
                        @click="print(receiptPrinters[0]);"
                    >
                        <i class="bi bi-printer"></i> @{{receiptPrinters[0].name}}
                    </button>
                </template>
                <template v-else>
                    <div class="btn-group">
                        <div class="btn-group">
                            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-printer"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li v-for="printer in receiptPrinters"><a class="dropdown-item" @click="print(printer);">{{printer.name}}</a></li>
                            </ul>
                        </div>
                    </div>
                </template>
			</div>
	    </div>
	</div>
	<div class="row gx-1 mb-2" v-if="orderFamilies.length > 1">
		<div class="col">
        	<button
        		type="button"
        		class="btn btn-outline-primary btn-lg w-100"
        		:class="{active: isEqual(selectedFamilies, orderFamilies)}"
        		@click="selectedFamilies = orderFamilies"
        	>
				All families
			</button>
        </div>
		<div class="col" v-for="family in orderFamilies">
        	<button
        		type="button"
        		class="btn btn-outline-primary btn-lg w-100"
        		:class="{active: isEqual(selectedFamilies, [family])}"
        		@click="selectedFamilies = [family]"
        	>
				Family [{{family}}]
			</button>
        </div>
	</div>
	<div v-for="orderEntryGroup in order.orderEntryGroups" class="border rounded mb-3">
		<div class="row">
			<div class="col">
				<div class="fs-5 fw-medium text-center border-bottom p-1 bg-secondary-subtle">
					{{orderEntryGroup.createdAt.substring(11, 16)}}
					<span v-if="orderEntryGroup.notes.length > 0">/ {{orderEntryGroup.notes}}</span>
				</div>
			</div>
		</div>
		<div v-for="(n, i) in 7">
			<div class="mb-1 p-1 ps-2 pe-2" v-if="filterGroupEntries(orderEntryGroup, i).length > 0">
				<div
					class="mb-2"
					v-for="(orderEntry, index) in filterGroupEntries(orderEntryGroup, i)"
				>
	      			<div class="d-flex w-100 justify-content-between">
			      		<span class="fs-4">
		      				{{orderEntry.quantity}} &times; {{getTranslation(orderEntry.menuItem, 'el').name}}
			      		</span>
		      			<div></div>
		      		</div>
		    		<div class="mb-0 ps-3">
		    			<div v-if="orderEntry.weight > 0 || orderHasManyFamilies">
		    				<span v-if="orderEntry.weight > 0">
		    					βάρος <span class="fw-bold">{{orderEntry.weight}}gr</span>
		    				</span>
		    				<span v-if="orderEntry.weight > 0 && orderHasManyFamilies"> / </span>
		    				<span v-if="orderHasManyFamilies">οικογένεια <span class="fw-bold">{{orderEntry.family}}</span></span>
		    			</div>
		    			<div v-if="orderEntry.orderEntryExtras.length > 0">
		    				<span v-for="(extra, index) in orderEntry.orderEntryExtras">
			    				<span>{{extra.name}}</span><span v-if="index != orderEntry.orderEntryExtras.length - 1"> / </span>
			    			</span>
		    			</div>
		    			<div v-if="orderEntry.notes.length > 0">{{orderEntry.notes}}</div>
		    		</div>
		    		<div class="mb-0 ps-3">
		    			<div v-for="orderEntryCancellation in orderEntry.orderEntryCancellations">
		    				<span class="text-danger">{{orderEntryCancellation.cancellationReason}} / {{orderEntryCancellation.createdAt}}</span>
		    			</div>
		    		</div>
		  		</div>
			</div>
			<hr v-if="filterGroupEntries(orderEntryGroup, i).length > 0" class="m-1"/>
		</div>
	</div>

	<div class="offcanvas offcanvas-start" :class="showOptions ? 'show' : ''" tabindex="-1">
  		<div class="offcanvas-header">
    		<h5 class="offcanvas-title" id="offcanvasExampleLabel">Επιλογές</h5>
    		<button type="button" class="btn-close" @click="showOptions = false"></button>
  		</div>
  		<div class="offcanvas-body">
  			<div class="row mb-4">
  				<template v-if="receiptPrinters.length == 1">
                    <button
                        type="button"
                        class="btn btn-primary btn-lg me-2"
                        @click="print(receiptPrinters[0]);"
                    >
                        <i class="bi bi-printer"></i> @{{receiptPrinters[0].name}}
                    </button>
                </template>
                <template v-else>
                    <div class="btn-group">
                        <div class="btn-group">
                            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-printer"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li v-for="printer in receiptPrinters"><a class="dropdown-item" @click="print(printer);">{{printer.name}}</a></li>
                            </ul>
                        </div>
                    </div>
                </template>
  			</div>
  			<div class="row mb-4">
  				<div class="dropdown me-2">
	  				<button class="btn btn-outline-secondary btn-lg dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
	    				<i class="fa-solid fa-language"></i> {{activeLanguage.name}}
	  				</button>
	  				<ul class="dropdown-menu fs-4 w-75">
	    				<li v-for="language in languages">
	    					<a class="dropdown-item" href="#" @click="activeLanguage = language">{{language.name}}</a>
	    				</li>
	  				</ul>
				</div>
  			</div>
  			<div class="row mb-4" v-if="orderHasManyFamilies">
				<div class="col-xs-12 mb-2">
		        	<button
		        		type="button"
		        		class="btn btn-outline-primary btn-lg w-100"
		        		:class="{active: selectedOrderEntries.length == unpaidOrderEntries.length}"
		        		@click.stop="toggleAll();showOptions = false"
		        	>
						Όλα
					</button>
		        </div>
				<div class="col-xs-12 mb-2" v-for="family in orderFamilies">
					<button
		        		type="button"
		        		class="btn btn-outline-primary btn-lg w-100"
		        		:class="{active: entriesBelongTo(family)}"
		        		@click="selectFamily(family);showOptions = false"
		        	>
						Οικογένεια {{family}}
					</button>
				</div>
		    </div>
    	</div>
  	</div>
  	<div class="offcanvas-backdrop fade show" v-if="showOptions"></div>
</div>
<canvas width="576" height="5000" class="d-none"></canvas>
{% endverbatim %}{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script src="/assets/js/vue.global.prod.js"></script>
	<script src="/assets/js/axios.min.js"></script>
	<script src="/assets/js/lodash.min.js"></script>
	<script src="/assets/js/epos-2.24.0.js"></script>
	<script src="/assets/js/translations.js"></script>
	<script>
        const img = new Image();
        img.onload = () => {
            //the assumption is that the logo will be loaded
            //by the time the waiter presses to print button...
        };
        img.src = '/assets/logo.webp';
	</script>
    <script>
        const W = 576;
        const PAD = 3;
        const INDENT = 40;
        let y = 0;

        const centerText = (ctx, text, fontSize, bold = false) => {
            ctx.font = `${bold ? 'bold ' : ''}${fontSize}px monospace`;
            ctx.textAlign = 'center';
            y += fontSize;
            ctx.fillText(text, W / 2, y);
            y += 8;
        };

        const leftText = (ctx, text, fontSize, bold = false, indent = 0) => {
            ctx.font = `${bold ? 'bold ' : ''}${fontSize}px monospace`;
            ctx.textAlign = 'left';
            y += fontSize;
            ctx.fillText(text, PAD + indent, y);
            y += 8;
        };

        const rightText = (ctx, text, fontSize, bold = false, indent = 0) => {
            ctx.font = `${bold ? 'bold ' : ''}${fontSize}px monospace`;
            ctx.textAlign = 'right';
            y += fontSize;
            ctx.fillText(text, W - PAD - indent, y);
            y += 8;
        };

        const separator = (ctx) => {
            y += 8;
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(0, y);
            ctx.lineTo(W, y);
            ctx.stroke();
            y += 12;
        };

        const addImage = (ctx, img, imgWidth, imgHeight, centered = true) => {
            const x = centered ? (W - imgWidth) / 2 : PAD;
            ctx.drawImage(img, x, y, imgWidth, imgHeight);
            y += imgHeight + 8;
        };
    </script>
	<script>
		vueApp = Vue.createApp({
		    data() {
		    	return {
		    		epos: null,

		    		selectedFamilies: [],
		    		order: {
		    			table: {},
		    			orderEntries: []
		    		},
		    		languages: [],
		    		activeLanguage: {},
		    		printers: [],

		    		printingOrder: false,
		    		showOptions: false,

                    canvasCtx: null
		    	}
		    },
		    mounted () {
		    	let id = new URLSearchParams(window.location.search).get('id');
                this.canvasCtx = document.querySelector('canvas').getContext('2d');

		    	axios({
                    url: '/admin/graph-ql',
                    method: 'post',
                    data: `{
                        order (id: ${id}) {
	                        id, uuid
	                        table {
	                        	id, name
	                        },
	                        adults, minors
	                        orderEntryGroups {
	                        	createdAt, notes
		                        orderEntries {
		                        	id, discount, timing, family, quantity, notes, menuItemPrice, weight, isPaid
		                        	menuItem {
		                        		id, price, translations { name, language },
	                            		printers {id, name, printerAddress}
		                        	},
		                        	orderEntryExtras {
		                        		name, price
		                        	},
		                        	orderEntryCancellations {
		                        		id, createdAt, cancellationReason
		                        	}
		                        }
		                    }
	                    }
                    }`
                }).then(response => {
                    this.order = response.data.data.order;
                    this.initialOrder = JSON.parse(JSON.stringify(response.data.data.order));

                    this.selectedFamilies = this.orderFamilies;
                });

                axios({
                    url: '/admin/graph-ql?useCachedResults=true',
                    method: 'post',
                    data: `{
                        languages {
                        	id, name, isoCode
                        },
                        printers {
                        	id, name, printerAddress, isReceiptPrinter
                        }
                    }`
                }).then(response => {
                    this.languages = response.data.data.languages;
                    this.activeLanguage = this.languages[0];
                    this.printers = response.data.data.printers;
                });
		    },
		    computed: {
		    	receiptPrinters () {
                    return _.filter(this.printers, printer => {
		    			return printer.isReceiptPrinter;
		    		});
                },
                allOrdeEntries() {
		    		let allOrdeEntries = []

		    		_.each(this.order.orderEntryGroups , orderEntryGroup => {
		    			_.each(orderEntryGroup.orderEntries, orderEntry => {
		    				allOrdeEntries.push(orderEntry);
		    			})
		    		})

		    		return allOrdeEntries
		    	},
		    	orderFamilies () {
		    		return _.uniq(_.map(this.allOrdeEntries, 'family'));
		    	},
		    	orderHasManyFamilies () {
		    		return this.orderFamilies.length > 1;
		    	},
		    	selectedOrderEntries () {
		    		return _.filter(this.allOrdeEntries, entry => {
		    			return this.selectedFamilies.includes(entry.family);
		    		});
		    	},
				groupedOrderEntries () {
					let entries = [];

					_.each(this.selectedOrderEntries, orderEntry => {
						if (orderEntry.quantity > 0 && orderEntry.menuItemPrice > 0) {
							let x = _.find(entries, function(e) { return e.id == orderEntry.menuItem.id; });

							if (_.isUndefined(x)) {
								entries.push({
									id: orderEntry.menuItem.id,
									menuItem: orderEntry.menuItem,
									quantity: orderEntry.quantity,
									price: this.calculateOrderEntryPrice(orderEntry)
								})
							} else {
								x.quantity += orderEntry.quantity
								x.price += this.calculateOrderEntryPrice(orderEntry)
							}
						}
					})

					return entries;
				},
		    	unpaidOrderEntries () {
		    		return _.filter(this.allOrdeEntries, entry => {
		    			return entry.isPaid == false;
		    		});
		    	},
		    	totalPrice () {
		    		let totalPrice = 0;

		    		_.each(this.selectedOrderEntries, orderEntry => {
			    		totalPrice += this.calculateOrderEntryPrice(orderEntry)
			    	});

		    		return _.round(totalPrice, 1);
		    	}
		    },
		    methods: {
		    	getHm() {
		    		var today = new Date();
		    		return `${today.getHours()}:${today.getMinutes() < 10 ? '0' + today.getMinutes() : today.getMinutes()}\n`
		    	},
		    	filterGroupEntries(orderGroup, timing) {
		    		return orderGroup.orderEntries.filter(
		    			orderEntry =>
		    			orderEntry.timing == timing
		    		);
		    	},
		    	calculateOrderEntryPrice(orderEntry) {
		    		let price = orderEntry.menuItemPrice;

		    		let weight = orderEntry.weight;
		    		if (weight > 0) {
		    			if (weight < 1000) {
		    				price -= (price * ((1000 - weight) / 1000));
		    			} else {
		    				price += price * ((weight - 1000) / 1000);
		    			}
		    		}

		    		_.each(orderEntry.orderEntryExtras, extra => {
		    			price += extra.price;
		    		})

		    		return _.round((price * orderEntry.quantity) - orderEntry.discount, 1);
		    	},
		    	isDeleted(orderEntry) {
		    		return orderEntry.quantity == 0;
		    	},
		    	print(printer) {
		    		if (this.printingOrder) {
		    			return
		    		}
		    		this.printingOrder = true;

                    this.canvasCtx.clearRect(0, 0, W, 5000);
		    		this.canvasCtx.fillStyle = 'white';
		    		this.canvasCtx.fillRect(0, 0, W, 5000);
		    		this.canvasCtx.fillStyle = 'black';

                    centerText(
                        this.canvasCtx,
                        this.order.table.name + '/' + this.getHm(),
                        18
                    );
                    y+= 16;
                    
                    addImage(this.canvasCtx, img, 500, 417, centered = true);

                    separator(this.canvasCtx);
                    _.each(this.groupedOrderEntries, orderEntry => {
						let quantity = orderEntry.quantity;

						let name = this.getTranslation(orderEntry.menuItem, this.activeLanguage.isoCode).name

						let menuItemBlock = '';
						menuItemBlock = `${quantity} x ${name}`;
						if (menuItemBlock.length >= 31) {
							name = name.substring(
								0, name.indexOf('/') - (quantity.toString().length - 1)
							); //minus 1 is for times symbol
							menuItemBlock = `${quantity} x ${name}`;
						}

						let dotsBlock = '';
						let priceBlock = '€' + orderEntry.price;
						if ((menuItemBlock.length + priceBlock.length) <= 31) {
							dotsBlock = '.'.repeat(31 - (menuItemBlock.length + priceBlock.length));
						}
						leftText(this.canvasCtx, `${menuItemBlock}${dotsBlock}${priceBlock}\n`, 30, true);
					});
                    separator(this.canvasCtx);
                    rightText(
                        this.canvasCtx, 
                        _.replace(i18n._("Total %s€\n", this.activeLanguage.isoCode), '%s', this.totalPrice),
                        32, false
                    );
                    y+=48;

                    centerText(
                        this.canvasCtx, 
                        i18n._("Thank you!", this.activeLanguage.isoCode),
                        44
                    );
					y+=16;
					if (this.activeLanguage.isoCode == 'en') {
						centerText(
                            this.canvasCtx, 
                            'Tips not required but greatly appreciated.',
                            20
                        );
					}
                    
                    let ePOSBuilder = new epson.ePOSBuilder();
                    ePOSBuilder.addImage(this.canvasCtx, 0, 0, 576, y, ePOSBuilder.COLOR_1, ePOSBuilder.MODE_MONO);
                    ePOSBuilder.addFeedLine(3);
                    ePOSBuilder.addCut(ePOSBuilder.CUT_FEED);
					
                    axios.post(
                        '/admin/print-jobs/create',
                        {
                            printer: printer.name,
                            xml: ePOSBuilder.toString()
                        }
                    ).then(response => {
                        if (response.data == 'ok') {
                            window.location.href = '/orders-app/';
                        }
                    }).catch(function (error) {
                        alert(error);
                    });
		    	},
		    	getTranslation(object, language) {
		    		return _.find(object.translations, translation => {
		    			return translation.language == language;
		    		});
		    	},
		    	isEqual (value, other) {
		    		return _.isEqual(value, other);
		    	},
		    	entriesBelongTo(family) {
		    		_.each(this.selectedOrderEntries, orderEntry => {
		    			orderEntry.family != family
		    		});

		    		return true;
		    	}
		    }
		}).mount('#app')
	</script>
{% endblock %}
