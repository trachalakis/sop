{% block javascript %}
	{{ parent() }}
	<script src="/assets/js/vue.global.prod.js"></script>
	<script src="/assets/js/axios.min.js"></script>
	<script src="/assets/js/lodash.min.js"></script>
	<script src="/assets/js/epos-2.24.0.js"></script>
	<script>

    var ctx = document.getElementById('canvas-test');
    if (ctx.getContext) {

        ctx = ctx.getContext('2d');

        //Loading of the home test image - img1
        var img1 = new Image();

        //drawing of the test image - img1
        img1.onload = function () {
            //draw background image
            ctx.drawImage(img1, 0, 0);
            //draw a box over the top
            //ctx.fillStyle = "rgba(200, 0, 0, 0.5)";
            //ctx.fillRect(0, 0, 500, 500);

        };

        img1.src = '/assets/img/epson_logo.png';
    }

	</script>
	<script>
		vueApp = Vue.createApp({
		    data() {
		    	return {
		    		isMenuSectionsModalVisible: false,
		    		showNotesModal: false,
		    		showOptions: false,
		    		savingOrder: false,

		    		activeMenuSection: null,
		    		newMenuItem: null,
		    		activeOrderEntry: null,

		    		tables: [],
		    		availableTables: [],
		    		menuSections: [],
				printers: [],
		    		timing: 1,

		    		newOrderEntry: {
		    			orderEntryExtras: [],
		    			notes: '',
		    			weight: null
		    		},

		    		order: {
		    			table: null,
		    			adults: null,
		    			minors: null,
		    			notes: '',
		    			orderEntries: [],
		    			employee: null,
		    			reservationId: null
		    		},

					menuName: null
		    	}
		    },
    		watch: {
		        'printers' : {
		        	handler: function ()  {
			        	let isTrue = _.reduce(this.printers, function(result, printer) {
	  						return result && printer.printOk;
						}, true);

						if (isTrue) {
							window.location.href = '/orders-app/';
						}
					},
					deep: true,
		            immediate: false
		        }
		    },
		    mounted () {
		    	this.order.reservationId = new URLSearchParams(window.location.search).get('reservationId');
				//this.menuName = new URLSearchParams(window.location.search).get('menu');
				this.menuName = 'Default';

		    	axios({
                    url: '/admin/graph-ql?useCachedResults=true',
                    method: 'post',
                    data: `{
                        menuSections (menu: "${this.menuName}") {
                            id, translations { name, language } ,
                            menuItems: activeMenuItems {
                            	id, trackAvailableQuantity, availableQuantity, isPricePerKg, isDrink, price, translations { name, language }, menuPosition,
                            	extras: allExtras {
                            		id, name, price
                            	},
                            	printers {id, name, printerAddress}
                            }
                        },
                        tables {
                        	id, name
                        },
                        printers {
                        	id, name, printerAddress, hasReceiptPrinter
                        }
                    }`
                }).then(response => {
                    this.menuSections = response.data.data.menuSections
                    this.tables = response.data.data.tables
                    this.printers = response.data.data.printers
                });
                axios({
                    url: '/admin/graph-ql',
                    method: 'post',
                    data: `{
                        availableTables {
                        	id, name
                        }
                    }`
                }).then(response => {
                    this.availableTables = response.data.data.availableTables
                });
                axios({
                    url: '/admin/graph-ql',
                    method: 'post',
                    data: `{
                        activeUser {
                        	id, fullName
                        }
                    }`
                }).then(response => {
                    this.waiter = response.data.data.activeUser
                });
		    },
		    computed: {
		    	totalPrice () {
		    		let totalPrice = 0;

		    		_.each(this.order.orderEntries, orderEntry => {
			    		totalPrice += this.calculateOrderEntryPrice(orderEntry)
			    	});

		    		return _.round(totalPrice, 1);
		    	}
		    },
		    methods: {
		    	getHm() {
		    		var today = new Date();
		    		return `${today.getHours()}:${today.getMinutes() < 10 ? '0' + today.getMinutes() : today.getMinutes()}\n`
		    	},
		    	getTranslation(object, language) {
		    		return _.find(object.translations, translation => {
		    			return translation.language == language;
		    		});
		    	},
		    	save () {
		    		if (this.order.orderEntries.length == 0) {
		    			return;
		    		}

		    		if (this.savingOrder) {
		    			return;
		    		}
		    		this.savingOrder = true;

		    		axios.post('/orders-app/create', this.order)
		                .then(response => {
		                    if (response.data == 'ok') {
		                    	this.printOrder();
		                    }
		                }).catch(function (error) {
	    					alert(error);
	  					});
		    	},
		    	printOrder() {
					_.each(this.printers, printer => {
						let printer = new epson.ePOSBuilder();

						//var ctx = document.getElementById('canvas-test');
        				//ctx = ctx.getContext('2d');

						printer.addCommand('\x1b\x74\x26'); //ESC t 16 (1252 code table)
						printer.addFeedLine(2);
						printer.addTextAlign(printer.ALIGN_CENTER);
						printer.addTextSmooth(true);
						//printer.addImage(ctx, 0, 0, 257, 212, printer.COLOR_1 , printer.MODE_MONO);
						//printer.addFeedLine(1);

						//printer.addSymbol('1234', printer.SYMBOL_QRCODE_MODEL_2, printer.LEVEL_0, 3);
						printer.addText(`${this.waiter.fullName} / `);
						printer.addText(this.getHm());
						printer.addTextFont(printer.FONT_B);
						printer.addTextAlign(printer.ALIGN_CENTER);
						printer.addFeedLine(1);
						printer.addTextSize(2, 2);
						printer.addText('--- ΝΕΑ ΠΑΡΑΓΓΕΛΙΑ ---');
						printer.addFeedLine(3);
						printer.addTextSize(3, 3);
						printer.addText(`Τραπέζι ${this.order.table.name}`);
						printer.addFeedLine(2);
						printer.addTextSize(2, 2);
						printer.addText(`Άτομα ${this.order.adults} / ${this.order.minors}`);
						if (this.order.notes.length > 0) {
							printer.addFeedLine(2);
							printer.addText(`***\n${this.order.notes}\n***`);
						}
						printer.addFeedLine(2);
						printer.addCommand(_.repeat('-', 32));
						printer.addFeedLine(1);
						printer.addTextAlign(printer.ALIGN_LEFT);
						printer.addTextLineSpace(40);

						let orderEntriesCount = 0;
						for (i = 0; i < 7; i++) {
							_.each(this.orderedEntries(i), orderEntry => {
								let index = _.findIndex(orderEntry.menuItem.printers, s => s.id == printer.id);

								if (index != -1 || printer.hasReceiptPrinter) {
									orderEntriesCount++;
									let quantity = orderEntry.quantity;
									let name = this.getTranslation(orderEntry.menuItem, 'el').name;
									let nameEn = this.getTranslation(orderEntry.menuItem, 'en').name;

									let weight = '';
									if (orderEntry.weight != null) {
										weight = `${orderEntry.weight / 1000}Kg`;
									}

									let tickboxes = '';
									if (quantity > 1 && nameEn != 'Bread') { //TODO
										for (j = 0; j < quantity; j++) {
											tickboxes += '[]';
										}
									}

									let priceBlock = '';
									if (printer.hasReceiptPrinter) {
										let priceBlock = '€' + this.calculateOrderEntryPrice(orderEntry);

										printer.addText(`${quantity} x ${name} (${priceBlock}) ${weight}\n`);
									} else {
										if (quantity > 6) {
											printer.addText(`${quantity} \xd7 ${name} ${weight} \n\t${tickboxes}\n`);
										} else {
											printer.addText(`${quantity} \xd7 ${name} ${weight} ${tickboxes}\n`);
										}
									}

									if (this.orderHasManyFamilies()) {
										printer.addText(`\t(F${orderEntry.family})\n`);
									}

									_.each(orderEntry.orderEntryExtras, orderEntryExtra => {
										printer.addText(`\t${orderEntryExtra.name}\n`);
									});

									if (orderEntry.notes.length > 0) {
										printer.addText(`\t${orderEntry.notes}\n`);
									}
								}
							});
							if (this.filteredEntries(i + 1).length > 0 && orderEntriesCount > 0) {
								printer.addCommand(_.repeat('-', 32));
								printer.addFeedLine(1);
							}
						}

						printer.addFeedLine(10);
						printer.addCut(printer.CUT_FEED);
						if (orderEntriesCount > 0) {
							printer.printOk = false;
							var address = `https://${printer.printerAddress}/cgi-bin/epos/service.cgi?devid=local_printer&timeout=10000`;
 							//Create an ePOS-Print object
 							var epos = new epson.ePOSPrint(address);
 							//Send the print document
 							epos.onreceive = function (res) {
 								//console.log(res);
 								if (!res.success) {
 									alert(`A print error occurred. Printer ${printer.name}`);
 								} else {
 									printer.printOk = true;
 								}
 							}
 							epos.send(printer.toString());
						} else {
							printer.printOk = true;
						}
					});
		    	},
		    	showMenuItemOptionsModal (menuItem) {
		    		this.newMenuItem = menuItem;
		    		this.newOrderEntry.timing = this.timing;
					this.newOrderEntry.family = this.family;
					this.newOrderEntry.notes = '';

		    		if (menuItem.isPricePerKg) {
	  					this.newOrderEntry.weight = '';
		    		}
		    	},

		    	addOrderEntry(newOrderEntry) {
		    		let index = this.order.orderEntries.findIndex(
		    			orderEntry =>
		    				orderEntry.menuItem.id == newOrderEntry.menuItem.id
		    				&& orderEntry.family == newOrderEntry.family
		    				&& orderEntry.timing == newOrderEntry.timing
		    				&& orderEntry.notes == newOrderEntry.notes
		    				&& _.isEqual(orderEntry.orderEntryExtras, newOrderEntry.orderEntryExtras)
		    		);

	    			if (index != -1) {
	    				this.order.orderEntries[index].quantity++;
	    			} else {
		    			if (this.isBread(newOrderEntry.menuItem)) {
		    				index = this.breadEntries().length;
		    				timing = 0;
		    			} else if (this.isDrink(newOrderEntry.menuItem)) {
		    				index = this.breadEntries().length + this.foodEntries().length + this.drinkEntries().length;
		    				timing = 6; //timing 6 is for drinks
		    			} else {
		    				index = this.breadEntries().length + this.foodEntries().length;
		    				timing = newOrderEntry.timing;
		    			}

		    			this.order.orderEntries.splice(index, 0, {
			    			index: index,
			    			quantity: 1,
			    			family: newOrderEntry.family,
			    			timing: timing,
			    			menuItem: newOrderEntry.menuItem,
			    			orderEntryExtras: newOrderEntry.orderEntryExtras,
			    			notes: newOrderEntry.notes,
			    			weight: newOrderEntry.weight,
			    			price: this.calculateOrderEntryPrice(newOrderEntry)
			    		});
			    	}
		    	},
		    	deleteOrderEntry(i) {
		    		let index = this.order.orderEntries.findIndex(
		    			orderEntry => orderEntry.index == i
		    		)
		    		this.order.orderEntries.splice(index, 1);
		    	},
		    	orderHasManyFamilies() {
		    		let index = this.order.orderEntries.findIndex(
		    			orderEntry => orderEntry.family != 1
		    		)

		    		return index != -1;
		    	},
		    	filteredEntries(timing) {
		    		return this.order.orderEntries.filter(orderEntry =>
		    			orderEntry.timing == timing
		    		);

		    		return orderEntries;
		    	},
		    	orderedEntries(step) {
		    		let orderedEntries = this.order.orderEntries.filter(orderEntry =>
		    			orderEntry.timing == step
		    		);
		    		return _.sortBy(orderedEntries, [function(o) { return o.menuItem.menuPosition; }])
		    	},
		    	foodEntries() {
		    		return this.order.orderEntries.filter(orderEntry =>
		    			!this.isBread(orderEntry.menuItem) &&
		    			!this.isDrink(orderEntry.menuItem)
		    		);
		    	},
		    	breadEntries() {
		    		return this.order.orderEntries.filter(orderEntry => this.isBread(orderEntry.menuItem));
		    	},
		    	drinkEntries() {
		    		return this.order.orderEntries.filter(orderEntry => this.isDrink(orderEntry.menuItem));
		    	},
		    	isBread(menuItem) {
		    		return menuItem.id == 1;
		    	},
		    	isDrink(menuItem) {
		    		return menuItem.isDrink;
		    	},
		    	calculateOrderEntryPrice(orderEntry) {
		    		let price = orderEntry.menuItem.price;

		    		if (orderEntry.menuItem.isPricePerKg) {
		    			let weight = orderEntry.weight;

		    			if (weight < 1000) {
		    				price -= (price * ((1000 - weight) / 1000));
		    			} else {
		    				price += price * ((weight - 1000) / 1000);
		    			}
		    		}

		    		_.each(orderEntry.orderEntryExtras, extra => {
		    			price += extra.price;
		    		})

		    		return _.round(price * orderEntry.quantity, 1);
		    	},
		    	filteredTables(row) {
		    		return this.tables.filter(table =>
		    			table.name[0] == row
		    		);
		    	},
		    }
		}).mount('#app');
	</script>
{% endblock %}