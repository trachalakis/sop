{% extends 'orders_app/skeleton.twig' %}

{% block pageCss %}
	<style>
		.mt-n1 {
	  		margin-top: -0.25rem !important;
		}
	</style>
{% endblock %}

{% block content %}{% verbatim %}
<canvas id="canvas-test" width="257" height="212" style="display: none;"></canvas>
<div id="app">
	<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
	    <h1>
	    	<a href="/orders-app/" class="text-decoration-none"><i class='bx bx-restaurant'></i></a> /
			<a class="text-primary text-decoration-none" v-if="order.table != null" @click="order.table = null">{{order.table.name}}</a>
			/ <a class="text-primary text-decoration-none" v-if="order.adults != null"  @click="order.adults = null">{{order.adults}}</a>
			/ <a class="text-primary text-decoration-none" v-if="order.minors != null" @click="order.minors = null">{{order.minors}} </a>
			/ &euro;{{totalPrice}}
	    </h1>
    	<div class="btn-toolbar">
	       	<a href="#" class="btn btn-lg btn-primary me-2 d-inline d-sm-none fw-bold" @click="showOptions = true;">
	            &ctdot;
	        </a>
	       	<button href="#" class="btn btn-lg btn-primary d-none d-sm-inline" @click="save" :disabled="savingOrder || order.orderEntries.length == 0">
	            <span class="spinner-border spinner-border-sm me-1" v-if="savingOrder"></span>Αποθήκευση
	        </button>
	    </div>
	</div>

	<div class="offcanvas offcanvas-start" :class="showOptions ? 'show' : ''" tabindex="-1">
  		<div class="offcanvas-header">
    		<h5 class="offcanvas-title" id="offcanvasExampleLabel">Επιλογές</h5>
    		<button type="button" class="btn-close" @click="showOptions = false"></button>
  		</div>
  		<div class="offcanvas-body">
  			<div class="row mb-2">
  				<div class="col-xs-12 mb-4">
			        <button class="btn btn-lg btn-primary w-100" @click="save" :disabled="savingOrder || order.orderEntries.length == 0">
			            <span class="spinner-border spinner-border-sm me-1" v-if="savingOrder"></span>Αποθήκευση
			        </button>
			    </div>
				<div class="col-xs-12 mb-2">
					<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="showNotesModal = true">
						<span class="me-1">Σχόλια</span>
						<span v-if="order.notes.length > 0" class="fw-bold">*</span>
					</button>
				</div>
		        <div class="col-xs-12 mb-2">
		        	<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="timing = null">
						<span class="me-1">Χρόνος</span>
						<span v-if="timing != null" class="fw-bold">{{timing}}</span>
					</button>
		        </div>
		        <div class="col-xs-12 mb-2">
		        	<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="family = null">
						<span class="me-1">Οικογένεια</span>
						<span v-if="family != null" class="fw-bold">{{family}}</span>
					</button>
		        </div>
		    </div>
    	</div>
  	</div>
  	<div class="offcanvas-backdrop fade show" v-if="showOptions"></div>

	<div class="d-none d-sm-block">
		<div class="row gx-1 mb-2">
			<div class="col">
				<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="showNotesModal = true">
					<span class="me-1">Σχόλια</span>
					<span v-if="order.notes.length > 0" class="fw-bold">*</span>
				</button>
			</div>
	        <div class="col">
	        	<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="timing = null">
					<span class="me-1">Χρόνος</span>
					<span v-if="timing != null" class="fw-bold">{{timing}}</span>
				</button>
	        </div>
	        <div class="col">
	        	<button type="button" class="btn btn-outline-primary btn-lg w-100" @click="family = null">
					<span class="me-1">Οικογένεια</span>
					<span v-if="family != null" class="fw-bold">{{family}}</span>
				</button>
	        </div>
	    </div>
	</div>

	<div class="row gx-1 mb-2">
		<div class="sticky-top">
			<button
				type="button"
				class="btn btn-lg btn-primary w-100 mt-2 mb-2"
				@click="isMenuSectionsModalVisible = true"
			>
				Προσθήκη
			</button>
		</div>

		<div class="modal modal-lg" :class="isMenuSectionsModalVisible ? 'd-block' :''" tabindex="-1">
	  		<div class="modal-dialog modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Επιλογή κατηγορίας</h5>
	        			<button type="button" class="btn-close" @click="isMenuSectionsModalVisible = false"></button>
	      			</div>
	      			<div class="modal-body">
						<div class="row gx-1">
			        		<div class="col-sm-6 mb-2" v-for="menuSection in menuSections">
			        			<button
			        				type="button"
			        				class="btn btn-outline-primary btn-lg w-100"
			        				@click="activeMenuSection = menuSection;isMenuSectionsModalVisible = false "
			        			>
			        				{{getTranslation(menuSection, 'el').name}}
			        			</button>
			        		</div>
			        	</div>
	      			</div>
	      			<div class="modal-footer">
	        			<button type="button" class="btn btn-lg btn-secondary" @click="isMenuSectionsModalVisible = false">
	        				Κλείσιμο
	        			</button>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal modal-lg d-block" v-if="activeMenuSection != null">
	  		<div class="modal-dialog modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Επιλογή πιάτου</h5>
	        			<button
	        				type="button"
	        				class="btn-close"
	        				@click="activeMenuSection = null;isMenuSectionsModalVisible = false"
	        			></button>
	      			</div>
	      			<div class="modal-body">
						<div class="row gx-1">
			        		<div class="col-sm-6 mb-2" v-for="menuItem in activeMenuSection.menuItems">
			        			<div class="btn-group w-100">
	  								<button v-if="menuItem.isPricePerKg"
	  									type="button"
	  									class="btn btn-lg btn-outline-primary w-75"
	  									@click="showMenuItemOptionsModal(menuItem)"
										:disabled="menuItem.trackAvailableQuantity && menuItem.availableQuantity == 0"
	  								>
	  									{{getTranslation(menuItem, 'el').name}}
	  									<span class="text-body-secondary">(&euro;{{menuItem.price}}/Kg)</span>
	  								</button>
	  								<button v-else
	  									type="button"
	  									class="btn btn-lg btn-outline-primary w-75"
	  									@click="
		  									addOrderEntry({
		  										menuItem: menuItem,
		  										timing: isDrink(menuItem) ? 6 : isBread(menuItem) ? 0 : timing,
		  										family: family,
		  										notes: '',
		  										orderEntryExtras: []
		  									});
		  								"
										:disabled="menuItem.trackAvailableQuantity && menuItem.availableQuantity == 0"
	  								>
	  									{{getTranslation(menuItem, 'el').name}}
	  									<span class="text-body-secondary">(&euro;{{menuItem.price}})</span>
	  									<span
	  										v-if="menuItem.trackAvailableQuantity && menuItem.availableQuantity <= 7"
	  										class="badge rounded-pill text-bg-danger ms-1"
	  									>
	  										{{menuItem.availableQuantity}}
	  									</span>
	  								</button>
	  								<button
	  									type="button"
	  									class="btn btn-lg btn-outline-primary w-25"
	  									@click="showMenuItemOptionsModal(menuItem)"
										:disabled="menuItem.trackAvailableQuantity && menuItem.availableQuantity == 0"
	  								>
	  									<span class="fw-bold">&ctdot;</span>
	  								</button>
								</div>
			        		</div>
			        	</div>
	      			</div>
	      			<div class="modal-footer">
	        			<button
	        				type="button"
	        				class="btn btn-lg btn-secondary"
	        				@click="activeMenuSection = null; isMenuSectionsModalVisible = true"
	        			>
	        				Πίσω
	        			</button>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal modal-lg d-block" v-if="newMenuItem != null">
	  		<div class="modal-dialog modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Επιλογές</h5>
	        			<button
	        				type="button"
	        				class="btn-close"
	        				@click="newMenuItem = null;activeMenuSection = null; isMenuSectionsModalVisible = false"
	        			></button>
	      			</div>
	      			<div class="modal-body">
						<div class="mb-3" v-if="newMenuItem.isPricePerKg">
							<label class="form-label">Βάρος (γρ)</label>
							<input class="form-control" type="number" min="50" step="1" v-model="newOrderEntry.weight"/>
						</div>
						<div class="form-check form-control-lg mb-2" v-for="extra in newMenuItem.extras">
	  						<label class="form-check-label w-100 fs-5">
		  						<input
		  							class="form-check-input"
		  							type="checkbox"
		  							:value="extra"
		  							v-model="newOrderEntry.orderEntryExtras"
		  						>
			    				{{extra.name}} <span v-if="extra.price != 0">(&euro;{{extra.price}})</span>
	  						</label>
						</div>
						<div v-if="isBread(newMenuItem)">
							<input type="hidden" value="0" v-model="newOrderEntry.timing">
						</div>
						<div v-else-if="isDrink(newMenuItem)">
							<input type="hidden" value="6" v-model="newOrderEntry.timing">
						</div>
						<div class="mb-3" v-else>
							<label class="form-label">Χρόνος</label>
							<select class="form-select form-control-lg mb-2" v-model="newOrderEntry.timing">
								<option v-for="i in 5">{{i}}</option>
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label">Οικογένεια</label>
							<select class="form-select form-control-lg mb-2" v-model="newOrderEntry.family">
								<option v-for="i in 12">{{i}}</option>
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label">Σχόλια</label>
	  						<textarea
	  							class="form-control"
	  							rows="2"
	  							v-model="newOrderEntry.notes"
	  						></textarea>
						</div>
	      			</div>
	      			<div class="modal-footer">
	      				<button
	        				type="button"
	        				class="btn btn-secondary btn-lg"
	        				@click="newMenuItem = null"
	        			>Πίσω</button>
	        			<button
	        				type="button"
	        				class="btn btn-primary btn-lg"
	        				@click="
	        					newOrderEntry.menuItem = newMenuItem;
	        					addOrderEntry(newOrderEntry);
	        					newMenuItem = null;
	        					activeMenuSection = null;
	        					isMenuSectionsModalVisible = true
	        					newOrderEntry = {notes:'', orderEntryExtras: []};
	        				"
	        			>Ok</button>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal modal-lg d-block" v-if="activeOrderEntry != null">
	  		<div class="modal-dialog modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Επιλογές</h5>
	        			<button
	        				type="button"
	        				class="btn-close"
	        				@click="activeOrderEntry = null;"
	        			></button>
	      			</div>
	      			<div class="modal-body">
						<div class="mb-3" v-if="activeOrderEntry.menuItem.isPricePerKg">
							<label class="form-label">Βάρος (γρ)</label>
							<input
								class="form-control"
								type="number"
								min="50"
								step="1"
								v-model="activeOrderEntry.weight"/>
						</div>
						<div class="form-check form-control-lg mb-2" v-for="extra in activeOrderEntry.menuItem.extras">
	  						<label class="form-check-label w-100 fs-5">
		  						<input
		  							class="form-check-input"
		  							type="checkbox"
		  							:value="extra"
		  							v-model="activeOrderEntry.orderEntryExtras"
		  						>
								{{extra.name}} <span v-if="extra.price != 0">(&euro;{{extra.price}})</span>
	  						</label>
						</div>
						<div class="mb-3" v-if="!isBread(activeOrderEntry.menuItem) && !isDrink(activeOrderEntry.menuItem)">
							<label class="form-label">Χρόνος</label>
							<select class="form-select form-control-lg mb-2" v-model="activeOrderEntry.timing">
								<option v-for="i in 5">{{i}}</option>
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label">Οικογένεια</label>
							<select class="form-select form-control-lg mb-2" v-model="activeOrderEntry.family">
								<option v-for="i in 12">{{i}}</option>
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label">Σχόλια</label>
	  						<textarea
	  							class="form-control form-control-lg"
	  							rows="2"
	  							v-model="activeOrderEntry.notes"
	  						></textarea>
						</div>
	      			</div>
	      			<div class="modal-footer">
	      				<button
	        				type="button"
	        				class="btn btn-secondary btn-lg"
	        				@click="activeOrderEntry = null"
	        			>Πίσω</button>
	        			<button
	        				type="button"
	        				class="btn btn-primary btn-lg"
	        				@click="
	        					activeOrderEntry = null
	        				"
	        			>Ok</button>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div v-for="(n, i) in 7">
			<div class="mb-1 p-1 ps-2 pe-2" v-if="filteredEntries(i).length > 0">
				<div
					v-for="orderEntry in filteredEntries(i)"
					@click="activeOrderEntry = orderEntry"
				>
		  			<div class="mb-2 d-flex w-100 justify-content-between">
		      			<div class="fs-5">
		      				{{orderEntry.quantity}} &times;
		      				{{getTranslation(orderEntry.menuItem, 'el').name}}
		      				/ &euro;{{calculateOrderEntryPrice(orderEntry)}}
		      			</div>
		      			<div>
		      				<button
		      					type="button"
		      					class="btn btn-secondary me-2"
		      					@click.stop="if (orderEntry.quantity > 1) { orderEntry.quantity--; } else { deleteOrderEntry(orderEntry.index) }"
		      				>
			      				<span class="fw-bold">&#x2212;</span>
			      			</button>
			      			<button
			      				type="button"
			      				class="btn btn-secondary"
			      				@click.stop="orderEntry.quantity++"
			      			>
			      				<span class="fw-bold">&#x002B;</span>
			      			</button>
			      		</div>
		    		</div>
		    		<div class="mt-n1 ps-3">
		    			<div v-if="orderEntry.weight > 0 || orderHasManyFamilies()">
		    				<span v-if="orderEntry.weight > 0">
		    					βάρος <span class="fw-bold">{{orderEntry.weight}}gr</span>
		    				</span>
		    				<span v-if="orderEntry.weight > 0 && orderHasManyFamilies()"> / </span>
		    				<span v-if="orderHasManyFamilies()">οικογένεια <span class="fw-bold">{{orderEntry.family}}</span></span>
		    			</div>
		    			<div v-if="orderEntry.orderEntryExtras.length > 0">
		    				<span v-for="(extra, index) in orderEntry.orderEntryExtras">
			    				<span>{{extra.name}}</span><span v-if="index != orderEntry.orderEntryExtras.length - 1"> / </span>
			    			</span>
		    			</div>
		    			<div v-if="orderEntry.notes.length > 0">{{orderEntry.notes}}</div>
		    		</div>
		  		</div>
			</div>
			<hr v-if="filteredEntries(i).length > 0"/>
		</div>
	</div>

	<!-- Modals -->
	<div class="row gx-1 mb-2">
		<div class="modal" tabindex="-1" :class="order.table == null ? 'd-block' : ''">
	  		<div class="modal-dialog modal-lg modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Τραπέζι</h5>
	      			</div>
	      			<div class="modal-body">
						<div class="row gx-1" v-for="(n, i) in 7">
							<div class="col mb-2" v-for="table in filteredTables(i)">
								<button
									type="button"
									class="btn btn-outline-primary btn-lg w-100"
									@click="order.table = table;"
									:disabled="_.findIndex(availableTables, table) < 0"
								>
									{{table.name}}
								</button>
							</div>
						</div>
						<div class="row mb-4">
							<div v-for="table in tables">
								<div class="col" v-if="table.name == 'Take away'">
									<button
										type="button"
										class="btn btn-outline-primary btn-lg w-100"
										@click="order.table = table; order.adults = 1; order.minors = 0"
									>
										{{table.name}}
									</button>
								</div>
							</div>
						</div>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal" tabindex="-1" :class="order.table != null && order.adults == null ? 'd-block' : ''">
	  		<div class="modal-dialog modal-lg modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Ενήλικες</h5>
	      			</div>
	      			<div class="modal-body">
			        	<div class="row gx-1">
			        		<div class="col-sm-3 mb-2" v-for="n in 25">
			        			<button
			        				type="button"
			        				class="btn btn-outline-primary btn-lg w-100"
			        				@click="order.adults = n;"
			        			>
			        				{{n}}
			        			</button>
			        		</div>
			        	</div>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div
			class="modal"
			tabindex="-1"
			:class="order.table != null && order.adults != null && order.minors == null ? 'd-block' : ''">
	  		<div class="modal-dialog modal-lg modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Aνήλικοι</h5>
	      			</div>
	      			<div class="modal-body">
			        	<div class="row gx-1">
			        		<div class="col-sm-3 mb-2" v-for="(n, i) in 26">
			        			<button
			        				type="button"
			        				class="btn btn-outline-primary btn-lg w-100"
			        				@click="order.minors = i;"
			        			>
			        				{{i}}
			        			</button>
			        		</div>
			        	</div>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal" tabindex="-1" :class="showNotesModal ? 'd-block' : ''">
	  		<div class="modal-dialog modal-lg modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Σχόλια</h5>
	        			<button type="button" class="btn-close" @click="showNotesModal = false"></button>
	      			</div>
	      			<div class="modal-body">
			        	<div class="row mb-2">
			        		<div class="col-xs-12 col-sm-4">
			        			<button class="btn btn-outline-primary w-100 mb-2" @click="order.notes = '!!!ΠΡΟΣΟΧΗ!!!' + '\n' + order.notes">!!!ΠΡΟΣΟΧΗ!!!</button>
			        		</div>
			        		<div class="col-xs-12 col-sm-4">
			        			<button type="button" class="btn btn-outline-primary w-100 mb-2" @click="order.notes = 'Ότι βγαίνει πάει'">Ότι βγαίνει πάει</button>
			        		</div>
			        		<div class="col-xs-12 col-sm-4">
			        			<button type="button" class="btn btn-outline-primary w-100 mb-2" @click="order.notes = 'Όλα μαζί'">Όλα μαζί</button>
			        		</div>
			        		<div class="col-xs-12 col-sm-6">
			        			<button type="button" class="btn btn-outline-primary w-100 mb-2" @click="order.notes = 'Πρώτα δεύτερα μαζί'">Πρώτα δεύτερα μαζί</button>
			        		</div>
			        		<div class="col-xs-12 col-sm-6">
			        			<button type="button" class="btn btn-outline-primary w-100 mb-2" @click="order.notes = 'Κυρίως μαζί'">Κυρίως μαζί</button>
			        		</div>
			        	</div>
			        	<div class="row">
			        		<textarea class="form-control" v-model="order.notes" rows="3"></textarea>
			        	</div>
	      			</div>
	      			<div class="modal-footer">
	        			<button type="button" class="btn btn-secondary btn-lg" @click="showNotesModal = false">Κλείσιμο</button>
	      			</div>
	    		</div>
	  		</div>
		</div>

		<div class="modal" tabindex="-1" :class="timing == null ? 'd-block' : ''">
	  		<div class="modal-dialog modal-lg modal-fullscreen-sm-down">
	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Xρόνος σερβιρίσματος</h5>
	      			</div>
	      			<div class="modal-body">
			        	<div class="row gx-1">
			        		<div class="col-sm-12 mb-2">
