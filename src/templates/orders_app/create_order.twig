	    		<div class="modal-content">
	      			<div class="modal-header">
	        			<h5 class="modal-title">Οικογένεια</h5>
	      			</div>
	      			<div class="modal-body">
			        	<div class="row gx-1">
			        		<div class="col-sm-12 mb-2" v-for="n in 12">
			        			<button
			        				type="button"
			        				class="btn btn-outline-primary btn-lg w-100"
			        				@click="family = n;"
			        			>
			        				{{n}}
