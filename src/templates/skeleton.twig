<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>{{'Αlmyriki restaurant | Fish & Seafood restaurant in Chania'|_}}</title>
    {% block css %}
	    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
	    <link rel="stylesheet" href="/assets/fonts/fontawesome-all.min.css">
	    <link rel="stylesheet" href="/assets/fonts/font-awesome.min.css">
	    <link rel="stylesheet" href="/assets/css/styles.css">
	    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.1.1/aos.css">
	    <link rel="stylesheet" href="/assets/css/font.css">
	{% endblock %}
</head>
<body class="page-home">
    <header id="header" class="header">
        <a class="header__title" href="/{{language}}">
            <span class="header__title-text">Almyriki Restaurant</span>
        </a>
        <a id="reservations-link" class="reservations-link header__link" href="/{{language}}/reservations">
            <i class="fas fa-long-arrow-alt-right"></i>
            <span>reservations</span>
            <i class="fas fa-long-arrow-alt-left"></i>
        </a>
        <nav class="header__nav" role="navigation">
            <button class="btn btn-primary js-nav-toggle nav-toggle header__toggle" type="button" aria-expanded="false"
                aria-label="Toggle navigation" aria-controls="js-nav-holder">
                <span class="toggle__bar" aria-hidden="true"></span>
                <span class="toggle__bar" aria-hidden="true"></span>
                <span class="toggle__bar" aria-hidden="true"></span>
                <span class="toggle__bar" aria-hidden="true"></span>
            </button>
            <div id="js-nav-holder" class="nav-holder">
                <ul class="nav main-nav" aria-label="main navigation">
                    <li class="nav-item main-nav__item">
                        <a class="nav-link main-nav__link" href="/{{language}}/restaurant">
                            <span class="main-nav__link-main">The Restaurant</span>
                            <span class="main-nav__link-desc">Read our story, learn our philosohpy</span>
                        </a>
                    </li>
                    <li class="nav-item main-nav__item">
                        <a class="nav-link main-nav__link" href="/{{language}}/location">
                            <span class="main-nav__link-main">The beach</span>
                            <span class="main-nav__link-desc">Dine "al fresco" by the sea in Stavros beach</span></a>
                    </li>
                    <li class="nav-item main-nav__item">
                        <a class="nav-link main-nav__link" href="/{{language}}/menu">
                            <span class="main-nav__link-main">Our menu</span>
                            <span class="main-nav__link-desc">Deliciously fresh seafood, the greek way</span></a>
                    </li>
                    {#<!--<li class="nav-item main-nav__item">
                        <a class="nav-link main-nav__link" href="/recipes.html" data-swup-preload>
                            <span class="main-nav__link-main">Cretan recipes</span>
                            <span class="main-nav__link-desc">Read our story, learn out philosohpy</span></a>
                    </li>
                    <li class="nav-item main-nav__item">
                        <a class="nav-link main-nav__link" href="/blog" data-swup-preload>
                            <span class="main-nav__link-main">The Captain's blog</span>
                            <span class="main-nav__link-desc">Our news and announcements</span></a>
                    </li>-->#}
                </ul>
                <div class="secondary-nav">
                    <div class="secondary-links">
                        <a href="/{{language}}/contact" class="btn btn-link">contact</a>
                        <a href="/{{language}}/directions" class="btn btn-link">directions</a>
                    </div>
                    <div class="lang-select">
                        <span id="lang-select-title" class="lang-select__title sr-only">select language</span>
                        <ul class="list-inline lang-select__list" aria-labelledby="lang-select-title">
                            <li class="list-inline-item lang-select__item">
                            	<a class="lang-select__link" href="/en">EN</a>
                            </li>
                            <li class="list-inline-item lang-select__item">
                            	<a class="lang-select__link" href="/el">EL</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    {% block content %}{% endblock %}
    <footer>
        <section class="section contact-wrap">
            <h2 class="sr-only">Contact info</h2>
            <div class="contact-info">
                <p>We are open daily from 12.30 to 22.30</p>
                <div class="contact-info__items">
                    <div class="contact-item">
                        <h3 class="contact-item__title">Location</h4>
                        <p class="contact-item__main">Stavros Beach, Crete</p>
                    </div>
                    <div class="contact-item">
                        <h3 class="contact-item__title">Tel</h4>
                        <p class="contact-item__main">+30 28210 29489</p>
                    </div>
                    <div class="contact-item">
                        <h3 class="contact-item__title">Email</h3>
                        <p class="contact-item__main">contact@almyriki.gr</p>
                    </div>
                </div>
                <a class="btn btn-dark cta cta--sm" role="button" href="/{{language}}/contact">CONTACT US</a>
                <a class="btn btn-light cta cta--sm" role="button" href="/{{language}}/directions">Map &amp; Directions</a>
            </div>
        </section>
        <div class="sub-footer">
            {#<button class="btn btn-primary cta newsletter-cta" type="button">subscribe to our newsletter</button>#}
            <ul class="list-inline sub-footer__social" aria-label="our social media">
                <li class="list-inline-item">
                	<a href="https://facebook.com/almyrikirestaurant">
                		<i class="fa fa-facebook-f fa-fw footer__social-icon"></i>
                		<span class="sr-only">facebook</span>
                	</a>
                </li>
                <li class="list-inline-item">
                	<a href="https://instagram.com/almyriki">
                		<i class="fa fa-instagram footer__social-icon fa-fw"></i>
                		<span class="sr-only">instagram</span>
                	</a>
                </li>
            </ul>
        </div>
        <div class="signature">
            <p>design by Thanasis Psarros<i class="far fa-copyright"></i> 2019-{{'now'|date('Y')}}</p>
        </div>
    </footer>
    <div class="svgs">
        <svg width="0" height="0">
            <defs>
                <clipPath id="wave-flip" clipPathUnits="objectBoundingBox" transform="scale(0.00055 0.002)">
                    <path
                        d="M1903.2,0c-94,0-94,18-187.94,18s-94-18-187.94-18-94,18-187.93,18-94-18-187.94-18-94,18-187.94,18-94-18-187.93-18-94,18-187.94,18S493.67,0,399.7,0s-94,18-187.93,18S117.8,0,23.83,0C15.13,0,7.24.16,0,.44V514H1927V.43C1919.77.15,1911.89,0,1903.2,0Z">
                    </path>
                </clipPath>
            </defs>
        </svg>
        <svg width="0" height="0">
            <defs>
                <clipPath id="wave" clipPathUnits="objectBoundingBox" transform="scale(0.00055 0.001)">
                    <path
                        d="M1917,0H0V931.56a651.1,651.1,0,0,0,331.16-20.93c96.32-32.18,184.15-86.69,281.11-116.89,103.12-32.11,213.16-35.58,320.89-28,133.05,9.43,270.2,34.9,397.3-5.56,103-32.79,187.49-105.38,278.67-163.39,23.1-14.69,159.87-104.84,307-81.21C1916.11,406,1917,0,1917,0Z">
                    </path>
                </clipPath>
            </defs>
        </svg>
    </div>
    {% block javascript %}
	    <script src="/assets/js/jquery.min.js"></script>
	    <script src="/assets/bootstrap/js/bootstrap.min.js"></script>
	    <script src="/assets/js/headroom.min.js"></script>
	    <script src="https://unpkg.com/imagesloaded@4/imagesloaded.pkgd.min.js"></script>
	    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.1.1/aos.js"></script>
	    <script>
		    $(document).ready(function() {
	    		AOS.init({ disable: 'mobile' });

	    		$('.js-nav-toggle').click(function() {
	        		$('#js-nav-holder').toggleClass('open');
	        		$(this).attr('aria-expanded', function (i, attr) {
	          			return attr == 'true' ? 'false' : 'true'
	        		});
	        		$('body').toggleClass('nav-open');
	    		});
			});

			var myElement = document.querySelector("#header");
			var headroom = new Headroom(myElement, {
				'offset': 200,
				'tolerance': 5,
			});
			headroom.init();
	    </script>
	{% endblock %}
</body>
</html>