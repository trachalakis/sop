<!doctype html>
<html lang="el">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="description" content="">
    <meta name="theme-color" content="#E7E0D1">
    <title>{{siteName}} · Take Out</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    <style>
        :root {
            --mp-sand: #E7E0D1;
            --mp-cream: #FCFAF4;
            --mp-cream-2: #F6F1E6;
            --mp-ink: #2B2A26;
            --mp-teal: #3C7A72;
            --mp-teal-deep: #2F665F;
            --mp-teal-soft: #E3EDEA;
            --mp-rust: #C26A4B;
            --mp-rust-deep: #9A4E32;
            --mp-muted: #6B6354;
            --mp-muted-2: #9A9183;
            --mp-text-2: #5C5446;
            --mp-line: #EFE8DA;
            --mp-border: #E2D9C7;
            --mp-chip-border: #E4DCCC;
            --mp-notice-bg: #F5E5DC;
            --mp-notice-border: #EAD2C4;
            --mp-summary-bg: #F6F1E6;
            --mp-summary-border: #EBE3D2;
            --mp-serif: 'Instrument Serif', Georgia, 'Times New Roman', serif;
            --mp-sans: 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        [v-cloak] { display: none; }

        html, body { height: 100%; }
        body {
            font-family: var(--mp-sans);
            color: var(--mp-ink);
            background: var(--mp-sand);
            background-image: radial-gradient(circle at 80% -10%, rgba(243,217,166,.35), rgba(243,217,166,0) 45%);
            background-attachment: fixed;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        /* App shell — phone-width column centred on larger screens */
        .mp-shell {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100dvh;
            background: var(--mp-cream);
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 0 60px -20px rgba(47,72,67,.25);
        }

        /* Header */
        .mp-header {
            position: sticky;
            top: 0;
            z-index: 30;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 22px 13px;
            padding-top: max(14px, env(safe-area-inset-top));
            background: var(--mp-cream);
            border-bottom: 1px solid var(--mp-line);
        }
        .mp-brand { display: flex; flex-direction: column; min-width: 0; }
        .mp-brand-name {
            font-family: var(--mp-serif);
            font-size: 24px;
            line-height: 1;
            color: var(--mp-ink);
            text-decoration: none;
        }
        .mp-brand-eyebrow {
            font-weight: 700;
            font-size: 9px;
            letter-spacing: .22em;
            color: var(--mp-rust);
            margin-top: 5px;
            text-transform: uppercase;
        }

        /* Language segmented toggle */
        .mp-lang {
            display: inline-flex;
            border: 1px solid var(--mp-border);
            border-radius: 13px;
            overflow: hidden;
            flex: 0 0 auto;
            background: #fff;
        }
        .mp-lang button {
            border: none;
            background: transparent;
            color: var(--mp-muted-2);
            padding: 6px 12px;
            font-family: var(--mp-sans);
            font-weight: 700;
            font-size: 12px;
            cursor: pointer;
        }
        .mp-lang button.is-active { background: var(--mp-teal); color: #fff; }

        /* Buttons */
        .mp-btn {
            font-family: var(--mp-sans);
            font-weight: 700;
            font-size: 16px;
            border: none;
            border-radius: 16px;
            padding: 16px;
            cursor: pointer;
            width: 100%;
            color: #fff;
            background: var(--mp-teal);
            box-shadow: 0 14px 30px -12px rgba(60,122,114,.65);
            transition: transform .08s ease, filter .15s ease;
        }
        .mp-btn:active { transform: translateY(1px); }
        .mp-btn:disabled { opacity: .55; box-shadow: none; cursor: default; }
        .mp-btn-outline {
            background: #fff;
            color: var(--mp-text-2);
            border: 1px solid var(--mp-border);
            box-shadow: none;
        }

        /* Order summary panel (status pages) */
        .mp-summary {
            width: 100%;
            background: var(--mp-summary-bg);
            border: 1px solid var(--mp-summary-border);
            border-radius: 18px;
            padding: 16px 18px;
            text-align: left;
        }
        .mp-summary-title {
            font-weight: 700;
            font-size: 11px;
            letter-spacing: .18em;
            color: var(--mp-muted-2);
            margin-bottom: 10px;
        }
        .mp-summary-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            font-weight: 500;
            font-size: 14px;
            color: var(--mp-text-2);
            padding: 4px 0;
        }
        .mp-summary-row .ex { color: var(--mp-muted-2); font-weight: 400; font-size: 12px; }
        .mp-summary-total {
            display: flex;
            justify-content: space-between;
            font-weight: 700;
            font-size: 15px;
            color: var(--mp-ink);
            border-top: 1px solid #E6DDCB;
            margin-top: 8px;
            padding-top: 10px;
        }

        /* Notice / alert */
        .mp-notice {
            background: var(--mp-notice-bg);
            border: 1px solid var(--mp-notice-border);
            color: var(--mp-rust-deep);
            border-radius: 12px;
            padding: 11px 14px;
            font-weight: 500;
            font-size: 13px;
            line-height: 1.45;
        }
        .mp-error {
            background: #FBE9E7;
            border: 1px solid #F1C7BF;
            color: #B23A2A;
            border-radius: 12px;
            padding: 11px 14px;
            font-weight: 600;
            font-size: 13px;
            line-height: 1.4;
        }

        /* Bottom-sheet overlay shared by drawer + modal */
        .mp-overlay {
            position: fixed;
            inset: 0;
            background: rgba(40,38,32,.5);
            z-index: 60;
            display: flex;
            align-items: flex-end;
            justify-content: center;
        }
        .mp-sheet {
            width: 100%;
            max-width: 480px;
            background: var(--mp-cream);
            border-radius: 26px 26px 0 0;
            box-shadow: 0 -12px 44px -10px rgba(0,0,0,.35);
            padding: 14px 22px calc(22px + env(safe-area-inset-bottom));
            max-height: 92dvh;
            display: flex;
            flex-direction: column;
            animation: mp-sheet-up .22s ease;
        }
        @keyframes mp-sheet-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .mp-sheet-handle {
            width: 38px; height: 4px; border-radius: 3px;
            background: #E0D7C5; margin: 2px auto 14px; flex: 0 0 auto;
        }

        @keyframes mp-spin { to { transform: rotate(360deg); } }
    </style>
    {% block pageCss %}{% endblock %}
</head>
<body>
    {% block content %}{% endblock %}
    {% block javascript %}{% endblock %}
</body>
</html>
