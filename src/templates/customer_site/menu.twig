{% extends 'customer_site/skeleton.twig' %}

{% block pageCss %}
<style>
    /* Combined sticky bar so the chips always sit right under the header */
    .mp-topbar { position: sticky; top: 0; z-index: 30; background: var(--mp-cream); }
    .mp-topbar .mp-header { position: static; }

    .mp-chips-wrap {
        position: relative;
        background: var(--mp-cream);
        border-bottom: 1px solid var(--mp-line);
    }
    /* Edge fades hint that the row scrolls; shown only when there's more that way */
    .mp-chips-wrap::before,
    .mp-chips-wrap::after {
        content: '';
        position: absolute; top: 0; bottom: 0; width: 42px;
        pointer-events: none; z-index: 2;
        opacity: 0; transition: opacity .2s ease;
    }
    .mp-chips-wrap::before { left: 0; background: linear-gradient(to right, var(--mp-cream) 30%, rgba(252,250,244,0)); }
    .mp-chips-wrap::after  { right: 0; background: linear-gradient(to left,  var(--mp-cream) 30%, rgba(252,250,244,0)); }
    .mp-chips-wrap.has-fade-left::before { opacity: 1; }
    .mp-chips-wrap.has-fade-right::after { opacity: 1; }

    .mp-chips {
        display: flex;
        gap: 8px;
        padding: 12px 22px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        scroll-behavior: smooth;
    }
    .mp-chips::-webkit-scrollbar { display: none; }
    .mp-chip {
        flex: 0 0 auto;
        white-space: nowrap;
        background: transparent;
        color: var(--mp-text-2);
        border: 1px solid var(--mp-chip-border);
        border-radius: 18px;
        padding: 8px 15px;
        font-family: var(--mp-sans);
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
    }
    .mp-chip.is-active { background: var(--mp-teal); color: #fff; border-color: var(--mp-teal); }

    .mp-main { flex: 1; padding: 6px 22px; padding-bottom: 120px; }

    .mp-active-order {
        display: block;
        background: var(--mp-summary-bg);
        border: 1px solid var(--mp-summary-border);
        color: var(--mp-rust-deep);
        border-radius: 14px;
        padding: 13px 16px;
        margin: 14px 0 4px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
    }
    .mp-empty { text-align: center; color: var(--mp-muted-2); padding: 64px 0; font-size: 15px; }

    .mp-section-title {
        font-family: var(--mp-serif);
        font-size: 24px;
        color: var(--mp-ink);
        margin: 22px 0 2px;
    }

    .mp-item {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--mp-line);
    }
    .mp-item-name { font-weight: 600; font-size: 16px; color: var(--mp-ink); }
    .mp-item-price { font-weight: 700; font-size: 14px; color: var(--mp-teal); margin-top: 7px; }
    .mp-soldout {
        display: inline-block;
        margin-top: 7px;
        font-weight: 700;
        font-size: 11px;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--mp-muted-2);
        background: #F0EADD;
        border-radius: 8px;
        padding: 3px 8px;
    }

    .mp-add {
        width: 40px; height: 40px;
        border-radius: 50%;
        border: none;
        background: var(--mp-teal);
        color: #fff;
        font-size: 24px;
        line-height: 1;
        display: flex; align-items: center; justify-content: center;
        flex: 0 0 auto;
        box-shadow: 0 4px 10px -3px rgba(60,122,114,.5);
        cursor: pointer;
    }
    .mp-add:disabled { background: #CBC4B4; box-shadow: none; cursor: default; }

    .mp-stepper {
        display: flex;
        align-items: center;
        border: 1px solid var(--mp-teal);
        border-radius: 22px;
        overflow: hidden;
        flex: 0 0 auto;
    }
    .mp-stepper button {
        width: 38px; height: 38px;
        border: none;
        font-size: 20px; line-height: 1;
        color: var(--mp-teal);
        background: transparent;
        cursor: pointer;
    }
    .mp-stepper button.plus { background: var(--mp-teal); color: #fff; }
    .mp-stepper button:disabled { opacity: .4; cursor: default; }
    .mp-stepper .qty { min-width: 24px; text-align: center; font-weight: 700; font-size: 15px; color: var(--mp-ink); }

    /* Cart bar */
    .mp-cartbar {
        position: fixed;
        left: 50%; transform: translateX(-50%);
        bottom: 0;
        width: 100%; max-width: 480px;
        z-index: 40;
        padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
    }
    .mp-cartbar button {
        width: 100%;
        border: none;
        background: var(--mp-teal);
        color: #fff;
        border-radius: 18px;
        padding: 16px 20px;
        display: flex; justify-content: space-between; align-items: center;
        font-family: var(--mp-sans); font-weight: 700; font-size: 15px;
        box-shadow: 0 16px 34px -12px rgba(60,122,114,.7);
        cursor: pointer;
    }
    .mp-cartbar .left { display: flex; align-items: center; gap: 11px; }
    .mp-cartbar .count {
        background: rgba(255,255,255,.22);
        border-radius: 9px;
        padding: 2px 9px;
        font-size: 13px;
    }

    /* Drawer */
    .mp-drawer-title {
        font-family: var(--mp-serif);
        font-size: 26px;
        color: var(--mp-ink);
    }
    .mp-drawer-scroll { overflow-y: auto; flex: 1; margin: 8px -4px 0; padding: 0 4px; }
    .mp-line {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--mp-line);
    }
    .mp-line-name { font-weight: 600; font-size: 15px; color: var(--mp-ink); }
    .mp-line-extras { font-weight: 400; font-size: 12px; color: var(--mp-muted-2); margin-top: 2px; }
    .mp-line-right { display: flex; align-items: center; gap: 10px; flex: 0 0 auto; }
    .mp-line-price { font-weight: 700; font-size: 14px; color: var(--mp-ink); }
    .mp-ministep {
        display: flex; align-items: center;
        border: 1px solid var(--mp-border);
        border-radius: 16px; overflow: hidden;
    }
    .mp-ministep button {
        width: 30px; height: 30px; border: none; background: transparent;
        color: var(--mp-teal); font-size: 17px; line-height: 1; cursor: pointer;
    }
    .mp-ministep .qty { min-width: 16px; text-align: center; font-weight: 700; font-size: 13px; }

    .mp-total {
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 0 10px;
    }
    .mp-total .label { font-weight: 700; font-size: 16px; color: var(--mp-ink); }
    .mp-total .amount { font-family: var(--mp-serif); font-size: 26px; color: var(--mp-ink); }

    .mp-input {
        width: 100%;
        border: 1px solid var(--mp-border);
        border-radius: 12px;
        padding: 12px 14px;
        font-family: var(--mp-sans); font-weight: 500; font-size: 14px;
        color: var(--mp-ink);
        background: #fff;
        margin-bottom: 9px;
    }
    .mp-input:focus { outline: none; border-color: var(--mp-teal); }
    textarea.mp-input { resize: none; }

    /* Extras modal */
    .mp-extra-title { font-family: var(--mp-serif); font-size: 24px; line-height: 1.12; color: var(--mp-ink); }
    .mp-extra-price { font-weight: 600; font-size: 14px; color: var(--mp-teal); margin-top: 5px; }
    .mp-extra-label {
        font-weight: 700; font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
        color: var(--mp-muted-2); margin: 20px 0 4px;
    }
    .mp-check {
        display: flex; align-items: center; justify-content: space-between;
        padding: 13px 0; border-bottom: 1px solid var(--mp-line); cursor: pointer;
    }
    .mp-check .name { display: flex; align-items: center; gap: 13px; font-weight: 500; font-size: 15px; color: var(--mp-ink); }
    .mp-check .price { font-weight: 600; font-size: 14px; color: var(--mp-muted-2); }
    .mp-check input { position: absolute; opacity: 0; pointer-events: none; }
    .mp-box {
        width: 23px; height: 23px; border-radius: 7px;
        background: #fff; border: 1.5px solid #D8CEBB;
        flex: 0 0 auto; position: relative;
    }
    .mp-check input:checked + .mp-box { background: var(--mp-teal); border-color: var(--mp-teal); }
    .mp-check input:checked + .mp-box::after {
        content: ''; position: absolute; left: 8px; top: 3px;
        width: 5px; height: 11px; border: solid #fff; border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }
    .mp-extra-actions { display: flex; gap: 12px; margin-top: 20px; }
    .mp-extra-actions .mp-btn { width: auto; flex: 1; padding: 15px; border-radius: 15px; font-size: 15px; }
    .mp-extra-actions .mp-btn-outline { flex: 0 0 auto; padding: 15px 22px; }
</style>
{% endblock %}

{% block content %}
<div id="app" class="mp-shell" v-cloak>
    <div class="mp-topbar">
    <header class="mp-header">
        <div class="mp-brand">
            <img src="/assets/customer_logo.png" class="mp-brand-logo" alt="{{siteName}}">
{% verbatim %}
            <!--<span class="mp-brand-eyebrow">{{t.menuEyebrow}}</span>-->
        </div>
        <div class="mp-lang">
            <button :class="{ 'is-active': lang == 'en' }" @click="setLang('en')">EN</button>
            <button :class="{ 'is-active': lang == 'el' }" @click="setLang('el')">ΕΛ</button>
        </div>
    </header>

    <div class="mp-chips-wrap" v-if="sections.length > 0" :class="{ 'has-fade-left': fadeLeft, 'has-fade-right': fadeRight }">
        <nav class="mp-chips" ref="chips" @scroll="onChipsScroll">
            <button
                v-for="section in sections"
                :key="section.id"
                :id="'chip-' + section.id"
                class="mp-chip"
                :class="{ 'is-active': activeSection === section.id }"
                @click="scrollToSection(section.id)"
            >{{sectionName(section)}}</button>
        </nav>
    </div>
    </div>

    <main class="mp-main">
        <a v-if="activeStatusUrl" :href="activeStatusUrl" class="mp-active-order">{{t.activeOrder}} →</a>

        <div v-if="sections.length == 0" class="mp-empty">{{t.menuUnavailable}}</div>

        <section v-for="section in sections" :key="section.id" :id="'section-' + section.id">
            <h2 class="mp-section-title">{{sectionName(section)}}</h2>
            <div v-for="item in section.items" :key="item.id" class="mp-item">
                <div style="min-width:0;">
                    <div class="mp-item-name">{{itemName(item)}}</div>
                    <div class="mp-item-price" v-if="!item.soldOut">&euro;{{item.price.toFixed(2)}}</div>
                    <span v-if="item.soldOut" class="mp-soldout">{{t.soldOut}}</span>
                </div>
                <div class="mp-stepper" v-if="cartQuantity(item) > 0">
                    <button @click="removeOne(item)">−</button>
                    <span class="qty">{{cartQuantity(item)}}</span>
                    <button class="plus" @click="addItem(item)" :disabled="item.soldOut">+</button>
                </div>
                <button v-else class="mp-add" @click="addItem(item)" :disabled="item.soldOut">+</button>
            </div>
        </section>
    </main>

    <div class="mp-cartbar" v-if="cart.length > 0 && !cartOpen">
        <button @click="cartOpen = true">
            <span class="left"><span class="count">{{cartCount}}</span>{{t.viewCart}}</span>
            <span>&euro;{{cartTotal.toFixed(2)}}</span>
        </button>
    </div>

    <!-- Cart drawer -->
    <div class="mp-overlay" v-if="cartOpen" @click.self="cartOpen = false">
        <div class="mp-sheet">
            <div class="mp-sheet-handle"></div>
            <div style="display:flex;align-items:baseline;justify-content:space-between;flex:0 0 auto;">
                <span class="mp-drawer-title">{{t.yourOrder}}</span>
                <button class="mp-lang" style="border:none;background:none;color:var(--mp-muted-2);font-weight:700;cursor:pointer;font-family:var(--mp-sans);" @click="cartOpen = false">✕</button>
            </div>

            <div class="mp-drawer-scroll">
                <div v-for="(line, index) in cart" :key="lineKey(line)" class="mp-line">
                    <div style="min-width:0;">
                        <div class="mp-line-name">{{line.quantity}}× {{lineName(line)}}</div>
                        <div class="mp-line-extras" v-if="line.extras.length > 0">+ {{line.extras.join(', ')}}</div>
                    </div>
                    <div class="mp-line-right">
                        <span class="mp-line-price">&euro;{{lineTotal(line).toFixed(2)}}</span>
                        <div class="mp-ministep">
                            <button @click="decrementLine(index)">−</button>
                            <span class="qty">{{line.quantity}}</span>
                            <button @click="incrementLine(index)">+</button>
                        </div>
                    </div>
                </div>

                <div class="mp-total">
                    <span class="label">{{t.total}}</span>
                    <span class="amount">&euro;{{cartTotal.toFixed(2)}}</span>
                </div>

                <input class="mp-input" v-model.trim="customerName" :placeholder="t.name" maxlength="100">
                <input class="mp-input" v-model.trim="customerPhone" :placeholder="t.phone" maxlength="20" inputmode="tel">
                <textarea class="mp-input" v-model.trim="notes" :placeholder="t.noteForKitchen" rows="2" maxlength="500"></textarea>
                <input type="text" v-model="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true">

                <div class="mp-notice" style="margin-top:4px;">{{t.payAtPickupNotice}}</div>
                <div class="mp-error" style="margin-top:10px;" v-if="errorMessage">{{errorMessage}}</div>
            </div>

            <div style="flex:0 0 auto;padding-top:14px;">
                <button class="mp-btn" @click="submit" :disabled="sending || cart.length == 0">
                    <span v-if="sending">…</span>
                    <span v-else>{{t.sendOrder}} · &euro;{{cartTotal.toFixed(2)}}</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Extras modal -->
    <div class="mp-overlay" v-if="extrasModalItem" @click.self="extrasModalItem = null">
        <div class="mp-sheet">
            <div class="mp-sheet-handle"></div>
            <div class="mp-extra-title">{{itemName(extrasModalItem)}}</div>
            <div class="mp-extra-price">&euro;{{extrasModalItem.price.toFixed(2)}} {{t.each}}</div>
            <div class="mp-extra-label">{{t.addExtras}}</div>
            <div class="mp-drawer-scroll" style="margin-top:0;">
                <label class="mp-check" v-for="extra in extrasModalItem.extras" :key="extra.name">
                    <span class="name">
                        <input type="checkbox" :value="extra.name" v-model="selectedExtras">
                        <span class="mp-box"></span>
                        <span>{{extra.name}}</span>
                    </span>
                    <span class="price">{{extra.price > 0 ? '+€' + extra.price.toFixed(2) : (extra.price < 0 ? '−€' + Math.abs(extra.price).toFixed(2) : t.free)}}</span>
                </label>
            </div>
            <div class="mp-extra-actions">
                <button class="mp-btn mp-btn-outline" @click="extrasModalItem = null">{{t.cancel}}</button>
                <button class="mp-btn" @click="confirmExtras">{{t.add}} · &euro;{{extrasModalTotal.toFixed(2)}}</button>
            </div>
        </div>
    </div>
{% endverbatim %}
</div>
{% endblock %}

{% block javascript %}
<script src="/assets/js/vue.global.prod.js"></script>
<script src="/assets/js/axios.min.js"></script>
<script>
    const SECTIONS = {{ sectionsJson|raw }};

    const I18N = {
        el: {
            menuEyebrow: 'ΣΕ ΠΑΚΕΤΟ',
            viewCart: 'Παραγγελία', yourOrder: 'Η παραγγελία σας', total: 'Σύνολο',
            name: 'Όνομα', phone: 'Τηλέφωνο', noteForKitchen: 'Σχόλιο για την κουζίνα (προαιρετικό)',
            payAtPickupNotice: 'Πληρώνετε κατά την παραλαβή. Το κατάστημα θα επιβεβαιώσει την παραγγελία σας με εκτιμώμενο χρόνο.',
            sendOrder: 'Αποστολή', soldOut: 'Εξαντλήθηκε', add: 'Προσθήκη', cancel: 'Άκυρο',
            each: 'το τεμάχιο', addExtras: 'Προσθέστε extra', free: 'δωρεάν',
            activeOrder: 'Έχετε ενεργή παραγγελία', menuUnavailable: 'Ο κατάλογος δεν είναι διαθέσιμος αυτή τη στιγμή.',
            errorGeneric: 'Κάτι πήγε στραβά. Δοκιμάστε ξανά.',
            errorName: 'Συμπληρώστε το όνομά σας.', errorPhone: 'Συμπληρώστε ένα έγκυρο τηλέφωνο.'
        },
        en: {
            menuEyebrow: 'TAKE-OUT MENU',
            viewCart: 'View order', yourOrder: 'Your order', total: 'Total',
            name: 'Name', phone: 'Phone', noteForKitchen: 'Note for the kitchen (optional)',
            payAtPickupNotice: 'You pay at pickup. The restaurant will confirm your order with an estimated time.',
            sendOrder: 'Send order', soldOut: 'Sold out', add: 'Add', cancel: 'Cancel',
            each: 'each', addExtras: 'Add extras', free: 'free',
            activeOrder: 'You have an active order', menuUnavailable: 'The menu is currently unavailable.',
            errorGeneric: 'Something went wrong. Please try again.',
            errorName: 'Please enter your name.', errorPhone: 'Please enter a valid phone number.'
        }
    };

    Vue.createApp({
        data() {
            return {
                lang: localStorage.getItem('takeOutLang') || 'el',
                sections: SECTIONS,
                cart: JSON.parse(localStorage.getItem('takeOutCart') || '[]'),
                cartOpen: false,
                customerName: localStorage.getItem('takeOutName') || '',
                customerPhone: localStorage.getItem('takeOutPhone') || '',
                notes: '',
                website: '',
                sending: false,
                errorMessage: '',
                extrasModalItem: null,
                selectedExtras: [],
                activeStatusUrl: null,
                activeSection: SECTIONS.length ? SECTIONS[0].id : null,
                fadeLeft: false,
                fadeRight: false
            }
        },
        computed: {
            t() { return I18N[this.lang]; },
            cartCount() { return this.cart.reduce((sum, line) => sum + line.quantity, 0); },
            cartTotal() { return this.cart.reduce((sum, line) => sum + this.lineTotal(line), 0); },
            extrasModalTotal() {
                if (!this.extrasModalItem) return 0;
                let price = this.extrasModalItem.price;
                for (const name of this.selectedExtras) {
                    const extra = this.extrasModalItem.extras.find(e => e.name === name);
                    if (extra) price += extra.price;
                }
                return price;
            }
        },
        watch: {
            cart: { deep: true, handler(value) { localStorage.setItem('takeOutCart', JSON.stringify(value)); } },
            activeSection(id) { this.centerChip(id); }
        },
        mounted() {
            const token = localStorage.getItem('takeOutToken');
            if (token) {
                axios.get('/order/status/' + token + '/poll')
                    .then(response => {
                        if (response.data.status === 'PENDING' || response.data.status === 'ACCEPTED') {
                            this.activeStatusUrl = '/order/status/' + token;
                        }
                    })
                    .catch(() => localStorage.removeItem('takeOutToken'));
            }

            this.$nextTick(() => {
                this.updateFades();
                this.setupScrollSpy();
            });
            window.addEventListener('resize', this.updateFades);
        },
        methods: {
            setLang(lang) {
                this.lang = lang;
                localStorage.setItem('takeOutLang', this.lang);
            },
            sectionName(section) { return section.names[this.lang] || section.names.el || section.names.en; },
            itemName(item) { return item.names[this.lang] || item.names.el || item.names.en; },
            findItem(id) {
                for (const section of this.sections) {
                    const item = section.items.find(i => i.id === id);
                    if (item) return item;
                }
                return null;
            },
            lineName(line) {
                const item = this.findItem(line.id);
                return item ? this.itemName(item) : '';
            },
            lineKey(line) { return line.id + '|' + line.extras.join(','); },
            lineTotal(line) {
                const item = this.findItem(line.id);
                if (!item) return 0;
                let price = item.price;
                for (const name of line.extras) {
                    const extra = item.extras.find(e => e.name === name);
                    if (extra) price += extra.price;
                }
                return line.quantity * price;
            },
            cartQuantity(item) {
                return this.cart.filter(line => line.id === item.id).reduce((sum, line) => sum + line.quantity, 0);
            },
            addItem(item) {
                if (item.extras.length > 0) {
                    this.extrasModalItem = item;
                    this.selectedExtras = [];
                } else {
                    this.pushLine(item, []);
                }
            },
            confirmExtras() {
                this.pushLine(this.extrasModalItem, [...this.selectedExtras].sort());
                this.extrasModalItem = null;
            },
            pushLine(item, extras) {
                const key = item.id + '|' + extras.join(',');
                const line = this.cart.find(l => this.lineKey(l) === key);
                if (line && line.quantity < 20) {
                    line.quantity++;
                } else if (!line) {
                    this.cart.push({ id: item.id, quantity: 1, extras });
                }
            },
            removeOne(item) {
                for (let i = this.cart.length - 1; i >= 0; i--) {
                    if (this.cart[i].id === item.id) { this.decrementLine(i); return; }
                }
            },
            incrementLine(index) {
                if (this.cart[index].quantity < 20) this.cart[index].quantity++;
            },
            decrementLine(index) {
                this.cart[index].quantity--;
                if (this.cart[index].quantity <= 0) this.cart.splice(index, 1);
            },
            topbarOffset() {
                const topbar = document.querySelector('.mp-topbar');
                return (topbar ? topbar.offsetHeight : 100) + 8;
            },
            scrollToSection(id) {
                this.activeSection = id;
                const el = document.getElementById('section-' + id);
                if (!el) return;
                const y = el.getBoundingClientRect().top + window.scrollY - this.topbarOffset();
                window.scrollTo({ top: y, behavior: 'smooth' });
            },
            onChipsScroll() { this.updateFades(); },
            updateFades() {
                const el = this.$refs.chips;
                if (!el) { this.fadeLeft = false; this.fadeRight = false; return; }
                this.fadeLeft = el.scrollLeft > 4;
                this.fadeRight = (el.scrollWidth - el.clientWidth - el.scrollLeft) > 4;
            },
            centerChip(id) {
                const wrap = this.$refs.chips;
                const chip = document.getElementById('chip-' + id);
                if (!wrap || !chip) return;
                const target = chip.offsetLeft - (wrap.clientWidth - chip.clientWidth) / 2;
                wrap.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
            },
            setupScrollSpy() {
                if (!this.sections.length || typeof IntersectionObserver === 'undefined') return;
                const observer = new IntersectionObserver((entries) => {
                    // Pick the topmost section currently crossing the bar band
                    const visible = entries
                        .filter(e => e.isIntersecting)
                        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
                    if (visible.length) {
                        this.activeSection = parseInt(visible[0].target.id.replace('section-', ''), 10);
                    }
                }, { root: null, rootMargin: '-' + this.topbarOffset() + 'px 0px -70% 0px', threshold: 0 });
                for (const section of this.sections) {
                    const el = document.getElementById('section-' + section.id);
                    if (el) observer.observe(el);
                }
            },
            submit() {
                this.errorMessage = '';
                if (this.customerName.length === 0) { this.errorMessage = this.t.errorName; return; }
                if (!/^\+?[0-9 ]{8,20}$/.test(this.customerPhone)) { this.errorMessage = this.t.errorPhone; return; }

                this.sending = true;
                axios.post('/order/submit', {
                    customerName: this.customerName,
                    customerPhone: this.customerPhone,
                    notes: this.notes,
                    website: this.website,
                    entries: this.cart.map(line => ({
                        menuItemId: line.id,
                        quantity: line.quantity,
                        extras: line.extras
                    }))
                }).then(response => {
                    localStorage.setItem('takeOutToken', response.data.statusUrl.split('/').pop());
                    localStorage.setItem('takeOutCart', '[]');
                    localStorage.setItem('takeOutName', this.customerName);
                    localStorage.setItem('takeOutPhone', this.customerPhone);
                    window.location.href = response.data.statusUrl;
                }).catch(error => {
                    this.sending = false;
                    this.errorMessage = error.response?.data?.error || this.t.errorGeneric;
                });
            }
        }
    }).mount('#app');
</script>
{% endblock %}
