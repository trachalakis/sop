{% for supplyGroup in supplyGroups %}
	<h2 class="h4">{{supplyGroup.getName}}</h2>
	<table class="table table-responsive">
		<tbody>
			{% for supply in supplyGroup.getSupplies|filter(s => s.isActive) %}
				<tr>
      				<td class="ps-4">
						<a class="text-decoration-none" href="/admin/supplies/update?id={{supply.getId}}">{{supply.getName}}</a>
					</td>
    			</tr>
			{% endfor %}
		</tbody>
	</table>
{% endfor %}

<ul class="nav border-bottom mb-3">
	{% for supplyGroup in supplyGroups %} 
		<li class="nav-item">
			<a class="nav-link active" aria-current="page" href="#supply-group-{{supplyGroup.getId}}">{{supplyGroup.getName}}</a>
		</li>
	{% endfor %}
</ul>
<ul class="list-group">
  	{% for supplyGroup in supplyGroups %}
  		<li class="list-group-item border border-0" id="supply-group-{{supplyGroup.getId}}">
  			<div class="border-bottom">
  				{{supplyGroup.getName}}
  			</div>
	  		<ul class="list-group list-group-flush">
		  		{% for supply in supplyGroup.getSupplies|filter(s => s.isActive) %}
		  			<li class="list-group-item border-bottom">
	  					<a class="text-decoration-none" href="/admin/supplies/update?id={{supply.getId}}">
	  						{{supply.getName}} 
	  					</a> &euro;{{supply.getCustomField('price')}}/{{supply.getUnit}} {{supply.getCustomField('supplier')}}
	  					{% if not supply.getIsActive %}
	   						<span class="badge rounded-pill text-bg-danger">Inactive</span>
	   					{% endif %}
		  			</li>
		  		{% endfor %}
		  	</ul>
  		</li>
  	{% endfor %}
</ul>
{% endblock %}