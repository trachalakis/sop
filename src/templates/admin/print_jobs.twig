{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'printJobs' %}

{% block content %}{% verbatim %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/print-jobs" class="text-decoration-none">Εκτυπώσεις</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <div>
        <h1 class="mb-0">Εκτυπώσεις</h1>
        <small class="text-muted">της τελευταίας ώρας</small>
    </div>
</div>
<div id="app">
	<table class="table table-responsive table-striped">
    	<thead>
            <tr>
                <th>#</th>
                <th>Εκτυπωτής</th>
                <th>Κατάσταση</th>
                <th>Ημ/νία</th>
            </tr>
        </thead>
        <tbody>
            <tr v-for="(printJob, index) in printJobs">
                <td>
                    <a class="text-decoration-none" :href="'/admin/print-jobs/update?id=' + printJob.id">
                        #{{printJob.id}}
                    </a>
                </td>
                <td>{{printJob.printer}}</td>
                <td>
                    <span v-if="printJob.status == 'pending'" class="badge rounded-pill text-bg-warning">Αναμονή</span>
                    <span v-if="printJob.status == 'completed'" class="badge rounded-pill text-bg-success">Ολοκληρώθηκε</span>
                </td>
                <td>{{printJob.createdAt}}</td>
            </tr>
    	</tbody>
    </table>
</div>
{% endverbatim %}{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script src="/assets/js/vue.global.prod.js"></script>
	<script src="/assets/js/axios.min.js"></script>
	<script src="/assets/js/lodash.min.js"></script>
	<script>
		vueApp = Vue.createApp({
		    data() {
		    	return {
		    		printJobs: []
		    	}
		    },
		    mounted () {
		    	setInterval(() => {
					this.fetchPrintJobs()
				}, 1500)
                this.fetchPrintJobs()
		    },
		    methods: {
		    	fetchPrintJobs () {
                    axios({
                        url: '/admin/graph-ql',
                        method: 'post',
                        data: `{
                            printJobs {
                                id, createdAt, printer, status, xml
                            }
                        }`
                    }).then(response => {
                        this.printJobs = response.data.data.printJobs
                    });
		    	},
		    	getTime(date) {
		    		return date.substr(date.length - 8, 5);
		    	}
		    },
		}).mount('#app');
	</script>
{% endblock %}