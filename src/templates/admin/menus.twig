{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'menus' %}

{% block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/menus" class="text-decoration-none">Μενού</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <h1>Μενού</h1>
    <div class="btn-toolbar">
       	<a href="/admin/menus/create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i>
        </a>
    </div>
</div>
<table class="table table-striped table-responsive">
	<tbody>
		{% for menu in menus %}
			<tr>
				<td>
					<a class="text-decoration-none" href="/admin/menus/update?id={{menu.getId}}">{{menu.getName}}</a>
					{% if not menu.getIsActive %}
						<span class="badge rounded-pill text-bg-danger">ανενεργό</span>
					{% endif %}
				</td>
			</tr>
		{% endfor %}
	</tbody>
</table>
{% endblock %}