{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'menus' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Μενού</h1>
    <div class="btn-toolbar">
       	<a href="/admin/menus/create" class="btn btn-primary">
            Νέο μενού
        </a>
    </div>
</div>
<table class="table table-striped table-responsive">
	<!--<thead>
  		<tr>
  			<th>Table</th>
  			<th></th>
  		</tr>
	</thead>-->
	<tbody>
		{% for menu in menus %}
			<tr>
				<td>
					<a class="text-decoration-none" href="/admin/menu?id={{menu.getId}}">{{menu.getName}}</a>
					{% if not menu.getIsActive %}
						<span class="badge rounded-pill text-bg-danger">ανενεργό</span>
					{% endif %}
				</td>
				<td class="text-end">
					<a class="text-decoration-none" href="/admin/menus/update?id={{menu.getId}}">
						Επεξεργασία
					</a>
				</td>
			</tr>
		{% endfor %}
	</tbody>
</table>
{% endblock %}