{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'users' %}

{%  block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/users" class="text-decoration-none">Χρήστες</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <h1>Χρήστες</h1>
    <div class="btn-toolbar">
       	<a href="/admin/users/create" class="btn btn-primary">
        	<i class="bi bi-plus-lg"></i>
        </a>
    </div>
</div>
<div class="table-responsive">
	<table class="table table-striped">
    	<thead>
            <tr>
                <th>Όνομα</th>
            </tr>
        </thead>
		<tbody>
			{% for user in users %}
				<tr>
					<td>
						<a class="text-decoration-none" href="/admin/users/update?id={{user.getId}}">
							{{user.getFullName}}
						</a>
						{% if not user.getIsActive %}
							<span class="badge rounded-pill text-bg-danger">Ανενεργός</span>
						{% endif %}
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
</div>
{%  endblock %}