{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'invoices' %}

{%  block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">View invoice</h1>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label">Type</label>
	<div class="col-sm-10">
		<select class="form-select" disabled>
        	<option value="normal" {{invoice.getType == 'normal' ? 'selected' : ''}}>Normal</option>
        	<option value="credit" {{invoice.getType == 'credit' ? 'selected' : ''}}>Credit</option>
        </select>
	</div>
</div>
<div class="row mb-3">
    <label class="col-sm-2 col-form-label">Supplier</label>
    <div class="col-sm-10">
        <input class="form-control" value="{{invoice.getSupplier.getName}}" disabled/>
    </div>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label">Invoice number</label>
	<div class="col-sm-10">
		<input type="text" class="form-control" value="{{invoice.getInvoiceNumber}}" disabled/>
	</div>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label">Invoice date</label>
	<div class="col-sm-10">
		<input type="date" class="form-control" value="{{invoice.getDate.format('Y-m-d')}}" disabled/>
	</div>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label"></label>
	<div class="col-sm-10">
		<div class="row mb-2">
			<div class="col"><label>Supply</label></div>
			<div class="col"><label>Quantity</label></div>
			<div class="col"><label>Unit</label></div>
			<div class="col"><label>Price</label></div>
			<div class="col"><label>Vat</label></div>
			<div class="col"><label>Vat %</label></div>
		</div>
		{% for invoiceEntry in invoice.getInvoiceEntries %}
			<div class="row mb-3 gx-1">
    			<div class="col">
    				<input
    					class="form-control"
    					type="text"
    					value="{{invoiceEntry.getSupply.getName}}"
    					disabled
    				/>
    			</div>
    			<div class="col">
    				<input
						class="form-control"
						type="number"
    					value="{{invoiceEntry.getQuantity}}"
    					disabled
    				/>
    			</div>
    			<div class="col">
    				<select
    					class="form-select"
    					disabled
    				>
    					<option value="item" {{invoiceEntry.getUnit == 'item' ? 'selected' : ''}}>Tεμ</option>
	            		<option value="kg" {{invoiceEntry.getUnit == 'kg' ? 'selected' : ''}}>Kg</option>
	            		<option value="lt" {{invoiceEntry.getUnit == 'lt' ? 'selected' : ''}}>Lt</option>
    				</select>
    			</div>
    			<div class="col">
    				<input
    					type="number"
    					class="form-control"
    					value="{{invoiceEntry.getPrice}}"
    					disabled
    				/>
    			</div>
    			<div class="col">
    				<input
    					type="number"
    					class="form-control"
    					value="{{invoiceEntry.getVat}}"
    					disabled
    				/>
    			</div>
    			<div class="col">
    				<input
    					type="number"
    					class="form-control"
    					value="{{invoiceEntry.getVatPercentage}}"
    					disabled
    				/>
    			</div>
    		</div>
	    {% endfor %}
	</div>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label">Vat</label>
	<div class="col-sm-10">
		<input
			type="number"
			step="0.01"
			class="form-control"
			disabled
			value="{{invoice.getVat}}"
		/>
	</div>
</div>
<div class="row mb-3">
	<label class="col-sm-2 col-form-label">Total</label>
	<div class="col-sm-10">
		<input
			type="number"
			step="0.01"
			class="form-control"
			disabled
			value="{{invoice.getTotal}}"
		/>
	</div>
</div>
{% endblock %}