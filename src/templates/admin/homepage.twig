<!doctype html>
<html lang="el">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{siteName}} · Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Commissioner:wght@400;500;600;700;800&family=Mulish:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  *::-webkit-scrollbar { width: 10px; height: 10px; }
  *::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.10); border-radius: 8px; border: 3px solid transparent; background-clip: content-box; }
  *::-webkit-scrollbar-track { background: transparent; }
  body { margin: 0; background: #F4F3EF; }
  a { text-decoration: none; }
  @keyframes sopPulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .35; transform: scale(.82); } }
  @keyframes sopRise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
</head>
<body>

<div style="--accent:#E2A23A; display:flex; height:100vh; width:100%; overflow:hidden; background:#F4F3EF; color:#1F2024; font-family:'Mulish',system-ui,sans-serif; -webkit-font-smoothing:antialiased; font-size:14px;">

  <aside style="width:248px; flex-shrink:0; height:100%; display:flex; flex-direction:column; background:#FBFAF8; border-right:1px solid rgba(0,0,0,0.07);">
    <div style="height:62px; flex-shrink:0; display:flex; align-items:center; gap:11px; padding:0 20px; border-bottom:1px solid rgba(0,0,0,0.07);">
      <div style="width:34px; height:34px; border-radius:9px; background:var(--accent,#E2A23A); display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 4px 14px rgba(226,162,58,0.32);">
        <span style="font-family:'Commissioner',sans-serif; font-weight:800; font-size:18px; color:#1A1206;">S</span>
      </div>
      <div style="display:flex; flex-direction:column; line-height:1.1; min-width:0;">
        <span style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:15px; letter-spacing:-0.01em; color:#16181C;">{{siteName}}</span>
        <span style="font-size:11px; color:#9197A0; font-weight:500;">Πίνακας διαχείρισης</span>
      </div>
    </div>

    <nav style="flex:1; overflow-y:auto; padding:16px 12px; display:flex; flex-direction:column; gap:3px;">
      <div style="font-size:10.5px; font-weight:700; letter-spacing:0.09em; color:#AAAFB7; text-transform:uppercase; padding:8px 10px 6px;">Λειτουργία</div>
      <a href="/admin/" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#16181C; background:color-mix(in srgb,var(--accent,#E2A23A) 14%,transparent); font-weight:600; font-size:13.5px; position:relative;">
        <span style="position:absolute; left:-12px; top:9px; bottom:9px; width:3px; border-radius:0 3px 3px 0; background:var(--accent,#E2A23A);"></span>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--accent,#E2A23A)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
        <span>Επισκόπηση</span>
      </a>
      <a href="/orders-app/" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        <span style="flex:1;">Παραγγελίες</span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; color:#1A1206; background:var(--accent,#E2A23A); padding:1px 7px; border-radius:20px;">12</span>
      </a>
      <a href="/reservations-app/" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2.5"/><path d="M8 2v4M16 2v4M3 10h18"/></svg>
        <span>Κρατήσεις</span>
      </a>
      <a href="/take-out/" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6L5 8z"/><path d="M9 8a3 3 0 0 1 6 0"/></svg>
        <span style="flex:1;">Take-away</span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; color:#D8493F; background:rgba(238,107,99,0.16); padding:1px 7px; border-radius:20px;">3</span>
      </a>
      <a href="/admin/tables" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="9" r="4"/><circle cx="17" cy="15" r="3.2"/><path d="M8 13v7M17 18v3M3 20h10"/></svg>
        <span>Τραπέζια</span>
      </a>

      <div style="font-size:10.5px; font-weight:700; letter-spacing:0.09em; color:#AAAFB7; text-transform:uppercase; padding:16px 10px 6px;">Διαχείριση</div>
      <a href="/admin/menus" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M4 9h16M9 9v11"/></svg>
        <span>Μενού</span>
      </a>
      <a href="/admin/recipes" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3v7a3 3 0 0 1-6 0V3M6 3v18M18 3c-1.7 0-3 2-3 5s1 4 3 4v9"/></svg>
        <span>Συνταγές</span>
      </a>
      <a href="/admin/supplies" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7M12 11v10"/></svg>
        <span style="flex:1;">Προμήθειες</span>
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:600; color:#D8493F; background:rgba(238,107,99,0.16); padding:1px 7px; border-radius:20px;">5</span>
      </a>
      <a href="/shopping-lists-app/update" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h14v3H5zM6 7l1 13h10l1-13"/><path d="M9 11v6M15 11v6"/></svg>
        <span>Λίστες αγορών</span>
      </a>

      <div style="font-size:10.5px; font-weight:700; letter-spacing:0.09em; color:#AAAFB7; text-transform:uppercase; padding:16px 10px 6px;">Σύστημα</div>
      <a href="/admin/users" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.4"/><path d="M3 20a6 6 0 0 1 12 0M16 5.5a3.4 3.4 0 0 1 0 6M18 20a5.5 5.5 0 0 0-3-5"/></svg>
        <span>Προσωπικό</span>
      </a>
      <a href="/admin/printers" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="9" width="12" height="7" rx="1.5"/><path d="M6 9V4h12v5M8 16v4h8v-4"/><circle cx="16" cy="12" r=".6" fill="currentColor"/></svg>
        <span>Εκτυπωτές</span>
      </a>
      <a href="/admin/report" style="display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; cursor:pointer; color:#6A6F78; font-weight:500; font-size:13.5px;" style-hover="background:rgba(0,0,0,0.04); color:#1F2024;">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19V5M4 14l5-5 4 4 7-7"/></svg>
        <span>Αναφορές</span>
      </a>
    </nav>

    <div style="flex-shrink:0; padding:12px; border-top:1px solid rgba(0,0,0,0.07); display:flex; align-items:center; gap:10px;">
      <div style="width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#ECEAE4,#DCD8D0); display:flex; align-items:center; justify-content:center; font-family:'Commissioner',sans-serif; font-weight:700; font-size:13px; color:#1F2024; flex-shrink:0;">{{ (currentUser.getFullName|default('Δ'))|slice(0,2)|upper }}</div>
      <div style="flex:1; min-width:0; line-height:1.2;">
        <div style="font-weight:600; font-size:13px; color:#1F2024; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ currentUser.getFullName|default('Διαχειριστής') }}</div>
        <div style="font-size:11.5px; color:#9197A0;">Διαχειριστής</div>
      </div>
      <a href="/logout" title="Αποσύνδεση"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9197A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg></a>
    </div>
  </aside>

  <div style="flex:1; display:flex; flex-direction:column; min-width:0; height:100%;">
    <header style="height:62px; flex-shrink:0; display:flex; align-items:center; gap:18px; padding:0 26px; border-bottom:1px solid rgba(0,0,0,0.07); background:rgba(251,250,248,0.82);">
      <div style="display:flex; align-items:center; gap:10px; flex:1; max-width:380px; background:rgba(0,0,0,0.045); border:1px solid rgba(0,0,0,0.07); border-radius:10px; padding:8px 13px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9197A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input placeholder="Αναζήτηση παραγγελίας, τραπεζιού, πελάτη…" style="flex:1; background:transparent; border:none; outline:none; color:#1F2024; font-family:'Mulish',sans-serif; font-size:13px;" />
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#9197A0; border:1px solid rgba(0,0,0,0.1); border-radius:5px; padding:1px 5px;">⌘K</span>
      </div>
      <div style="flex:1;"></div>
      <div style="display:flex; align-items:center; gap:7px; padding:6px 12px; border-radius:8px; background:rgba(70,201,138,0.1); border:1px solid rgba(70,201,138,0.22);">
        <span style="width:7px; height:7px; border-radius:50%; background:#1E9D62; animation:sopPulse 2s ease-in-out infinite;"></span>
        <span style="font-size:12px; font-weight:600; color:#1E9D62;">Σε λειτουργία</span>
      </div>
      <button style="width:38px; height:38px; border-radius:9px; background:rgba(0,0,0,0.045); border:1px solid rgba(0,0,0,0.07); display:flex; align-items:center; justify-content:center; cursor:pointer; position:relative; color:#6A6F78;" style-hover="background:rgba(0,0,0,0.08); color:#1F2024;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        <span style="position:absolute; top:7px; right:8px; width:7px; height:7px; border-radius:50%; background:#D8493F; border:2px solid #F4F3EF;"></span>
      </button>
    </header>

    <div style="flex:1; overflow-y:auto; padding:24px 26px 40px; background:radial-gradient(820px 420px at 88% -8%, rgba(226,162,58,0.07), transparent 62%), #F4F3EF;">

      <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:22px; flex-wrap:wrap;">
        <div>
          <div style="display:flex; align-items:center; gap:11px;">
            <h1 style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:26px; letter-spacing:-0.02em; color:#16181C;">Επισκόπηση</h1>
            <span style="font-size:12px; font-weight:600; color:var(--accent,#E2A23A); background:rgba(226,162,58,0.12); padding:3px 10px; border-radius:20px; margin-bottom:2px;">Βάρδια βραδιού</span>
          </div>
          <p style="color:#868B94; font-size:13.5px; margin-top:5px;">Κυριακή, 15 Ιουνίου 2026 · ενημέρωση πριν 2′</p>
        </div>
        <div style="display:flex; align-items:center; gap:10px;">
          <div style="display:flex; padding:4px; gap:3px; background:rgba(0,0,0,0.045); border:1px solid rgba(0,0,0,0.07); border-radius:10px;">
            <button data-range="today" style="padding:6px 13px; border-radius:7px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:700; letter-spacing:0.01em; transition:all .15s ease; background:var(--accent,#E2A23A); color:#1A1206;">Σήμερα</button>
            <button data-range="7d" style="padding:6px 13px; border-radius:7px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:600; letter-spacing:0.01em; transition:all .15s ease; background:transparent; color:#6A6F78;">7 ημέρες</button>
            <button data-range="30d" style="padding:6px 13px; border-radius:7px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:600; letter-spacing:0.01em; transition:all .15s ease; background:transparent; color:#6A6F78;">30 ημέρες</button>
          </div>
          <button style="display:flex; align-items:center; gap:8px; padding:9px 15px; border-radius:10px; background:var(--accent,#E2A23A); border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-weight:700; font-size:13px; color:#1A1206;" style-hover="filter:brightness(1.07);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1A1206" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 10l5 5 5-5M5 21h14"/></svg>
            Ημερήσια αναφορά
          </button>
        </div>
      </div>

      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:16px;">

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:15px; padding:17px 18px; display:flex; flex-direction:column; gap:13px;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:12.5px; font-weight:600; color:#6A6F78;">Έσοδα σήμερα</span>
            <span style="width:30px; height:30px; border-radius:8px; background:rgba(226,162,58,0.13); display:flex; align-items:center; justify-content:center; color:var(--accent,#E2A23A);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7c0-1.7-2.7-3-6-3S6 5.3 6 7s2.7 3 6 3 6 1.3 6 3-2.7 3-6 3-6-1.3-6-3M12 3v18"/></svg></span>
          </div>
          <div style="display:flex; align-items:baseline; gap:9px;">
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:27px; letter-spacing:-0.02em; color:#16181C;">€{{revenue.whole}}<span style="font-size:18px; color:#868B94;">,{{revenue.decimals}}</span></span>
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:15px; padding:17px 18px; display:flex; flex-direction:column; gap:13px;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:12.5px; font-weight:600; color:#6A6F78;">Παραγγελίες</span>
            <span style="width:30px; height:30px; border-radius:8px; background:rgba(91,160,201,0.14); display:flex; align-items:center; justify-content:center; color:#3B83B2;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg></span>
          </div>
          <div style="display:flex; align-items:baseline; gap:9px;">
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:27px; letter-spacing:-0.02em; color:#16181C;">{{ordersCount}}</span>
            <span style="font-size:12px; color:#868B94; font-weight:500;">{{openCount}} ανοιχτές</span>
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:15px; padding:17px 18px; display:flex; flex-direction:column; gap:13px;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:12.5px; font-weight:600; color:#6A6F78;">Καλυμμένα</span>
            <span style="width:30px; height:30px; border-radius:8px; background:rgba(0,0,0,0.06); display:flex; align-items:center; justify-content:center; color:#1F2024;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3 20a6 6 0 0 1 12 0M16 5.5a3.4 3.4 0 0 1 0 6M18 20a5.5 5.5 0 0 0-3-5"/></svg></span>
          </div>
          <div style="display:flex; align-items:baseline; gap:9px;">
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:27px; letter-spacing:-0.02em; color:#16181C;">{{covers}}</span>
            <span style="font-size:12px; color:#868B94; font-weight:500;">{{coverAdults}} ενήλικες</span>
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:15px; padding:17px 18px; display:flex; flex-direction:column; gap:13px;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:12.5px; font-weight:600; color:#6A6F78;">Μέση παραγγελία</span>
            <span style="width:30px; height:30px; border-radius:8px; background:rgba(0,0,0,0.06); display:flex; align-items:center; justify-content:center; color:#1F2024;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg></span>
          </div>
          <div style="display:flex; align-items:baseline; gap:9px;">
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:27px; letter-spacing:-0.02em; color:#16181C;">€{{avg.whole}}<span style="font-size:18px; color:#868B94;">,{{avg.decimals}}</span></span>
          </div>
        </div>

      </div>

      <div style="display:grid; grid-template-columns:2.05fr 1fr; gap:16px; margin-bottom:16px;">

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 22px 16px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:14px;">
            <div>
              <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Κίνηση ημέρας</div>
              <div style="display:flex; align-items:baseline; gap:10px; margin-top:8px;">
                <span id="sopMetaValue" style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:24px; letter-spacing:-0.02em; color:#16181C;">{{chart.revenue.value}}</span>
              </div>
              <div id="sopMetaSub" style="font-size:12px; color:#868B94; margin-top:5px;">{{chart.revenue.sub}}</div>
            </div>
            <div style="display:flex; padding:4px; gap:2px; background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.06); border-radius:11px;">
              <button data-tab="revenue" style="padding:6px 13px; border-radius:8px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:700; background:rgba(0,0,0,0.07); color:#16181C; transition:all .15s ease;">Έσοδα</button>
              <button data-tab="orders" style="padding:6px 13px; border-radius:8px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:600; background:transparent; color:#868B94; transition:all .15s ease;">Παραγγελίες</button>
              <button data-tab="covers" style="padding:6px 13px; border-radius:8px; border:none; cursor:pointer; font-family:'Mulish',sans-serif; font-size:12.5px; font-weight:600; background:transparent; color:#868B94; transition:all .15s ease;">Καλυμμένα</button>
            </div>
          </div>

          <svg viewBox="0 0 800 220" preserveAspectRatio="none" style="width:100%; height:208px; overflow:visible;">
            <defs>
              <linearGradient id="sopArea" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--accent,#E2A23A)" stop-opacity="0.28"/>
                <stop offset="100%" stop-color="var(--accent,#E2A23A)" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <line x1="20" y1="30" x2="780" y2="30" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>
            <line x1="20" y1="80" x2="780" y2="80" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>
            <line x1="20" y1="130" x2="780" y2="130" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>
            <line x1="20" y1="180" x2="780" y2="180" stroke="rgba(0,0,0,0.05)" stroke-width="1"/>
            <path id="sopChartArea" d="{{chart.revenue.area}}" fill="url(#sopArea)"/>
            <path id="sopChartLine" d="{{chart.revenue.line}}" fill="none" stroke="var(--accent,#E2A23A)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div style="display:flex; justify-content:space-between; padding:8px 16px 0; font-family:'JetBrains Mono',monospace; font-size:11px; color:#9197A0;">
            {% for l in chart.labels %}<span>{{l}}</span>{% endfor %}
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 20px 14px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Κατάσταση συστήματος</div>
            <span style="display:inline-flex; align-items:center; gap:5px; font-size:11.5px; font-weight:600; color:#1E9D62;"><span style="width:6px; height:6px; border-radius:50%; background:#1E9D62;"></span>{{system.clear}}/{{system.total}}</span>
          </div>
          <div style="display:flex; flex-direction:column; gap:2px; flex:1;">
{% for p in system.printers %}
            <div style="display:flex; align-items:center; gap:12px; padding:11px 4px;{% if not loop.last %} border-bottom:1px solid rgba(0,0,0,0.05);{% endif %}">
              <span style="width:8px; height:8px; border-radius:50%; background:{% if p.ok %}#1E9D62{% else %}#C2891B{% endif %}; flex-shrink:0; box-shadow:0 0 8px rgba(70,201,138,0.5);"></span>
              <div style="flex:1; min-width:0;"><div style="font-size:13.5px; font-weight:600; color:#1F2024;">{{p.name}}</div><div style="font-size:11.5px; color:#9197A0;">{{p.subtitle}}</div></div>
              <span style="font-size:11.5px; font-weight:600; color:{% if p.ok %}#1E9D62{% else %}#C2891B{% endif %};">{{p.statusLabel}}</span>
            </div>
{% else %}
            <div style="padding:24px 4px; text-align:center; color:#9197A0; font-size:13px;">Δεν υπάρχουν ενεργοί εκτυπωτές.</div>
{% endfor %}
          </div>
          <div style="margin-top:8px; padding-top:13px; border-top:1px solid rgba(0,0,0,0.07); display:flex; gap:10px;">
            <div style="flex:1; background:rgba(0,0,0,0.03); border-radius:9px; padding:9px 11px;"><div style="font-family:'JetBrains Mono',monospace; font-size:17px; font-weight:600; color:#16181C;">{{system.openCount}}</div><div style="font-size:11px; color:#868B94;">ανοιχτές παραγγ.</div></div>
            <div style="flex:1; background:rgba(0,0,0,0.03); border-radius:9px; padding:9px 11px;"><div style="font-family:'JetBrains Mono',monospace; font-size:17px; font-weight:600; color:#16181C;">{{system.queueTotal}}</div><div style="font-size:11px; color:#868B94;">στην ουρά εκτύπωσης</div></div>
          </div>
        </div>

      </div>

      <div style="display:grid; grid-template-columns:1.75fr 1fr; gap:16px; margin-bottom:16px;">

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 22px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:16px; flex-wrap:wrap;">
            <div>
              <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Κάτοψη — Κύρια αίθουσα</div>
              <div style="font-size:12px; color:#868B94; margin-top:3px;">{{floor.counts.occupied}} κατειλημμένα · {{floor.counts.free}} ελεύθερα · {{floor.counts.reserved}} κρατήσεις</div>
            </div>
            <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
              <span style="display:inline-flex; align-items:center; gap:6px; font-size:11.5px; color:#6A6F78;"><span style="width:9px; height:9px; border-radius:3px; background:color-mix(in srgb,var(--accent,#E2A23A) 30%,transparent); border:1px solid var(--accent,#E2A23A);"></span>Κατειλημμένο</span>
              <span style="display:inline-flex; align-items:center; gap:6px; font-size:11.5px; color:#6A6F78;"><span style="width:9px; height:9px; border-radius:3px; background:transparent; border:1px dashed rgba(0,0,0,0.3);"></span>Ελεύθερο</span>
              <span style="display:inline-flex; align-items:center; gap:6px; font-size:11.5px; color:#6A6F78;"><span style="width:9px; height:9px; border-radius:3px; background:rgba(91,160,201,0.3); border:1px solid #3B83B2;"></span>Κράτηση</span>
              
            </div>
          </div>

          <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:11px;">
{% for t in floor.tables %}{% if t.state == 'occupied' %}
            <div style="border-radius:11px; padding:12px 0; display:flex; flex-direction:column; align-items:center; gap:2px; cursor:pointer; background:color-mix(in srgb,var(--accent,#E2A23A) 13%,transparent); border:1px solid color-mix(in srgb,var(--accent,#E2A23A) 36%,transparent);" style-hover="filter:brightness(1.15);"><span style="font-family:'JetBrains Mono',monospace; font-weight:700; font-size:15px; color:var(--accent,#E2A23A);">{{t.name}}</span><span style="font-size:10.5px; color:#868B94;">ανοιχτό</span></div>
{% elseif t.state == 'reserved' %}
            <div style="border-radius:11px; padding:12px 0; display:flex; flex-direction:column; align-items:center; gap:2px; cursor:pointer; background:rgba(91,160,201,0.12); border:1px solid rgba(91,160,201,0.4);" style-hover="filter:brightness(1.15);"><span style="font-family:'JetBrains Mono',monospace; font-weight:700; font-size:15px; color:#3B83B2;">{{t.name}}</span><span style="font-size:10.5px; color:#3B83B2;">{{t.info}}</span></div>
{% else %}
            <div style="border-radius:11px; padding:12px 0; display:flex; flex-direction:column; align-items:center; gap:2px; cursor:pointer; background:rgba(0,0,0,0.025); border:1px dashed rgba(0,0,0,0.13);" style-hover="filter:brightness(1.3);"><span style="font-family:'JetBrains Mono',monospace; font-weight:700; font-size:15px; color:#9197A0;">{{t.name}}</span><span style="font-size:10.5px; color:#AAAFB7;">ελεύθερο</span></div>
{% endif %}{% else %}
            <div style="grid-column:1/-1; padding:26px; text-align:center; color:#9197A0; font-size:13px;">Δεν υπάρχουν ενεργά τραπέζια.</div>
{% endfor %}
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 20px 16px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
            <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Επόμενες κρατήσεις</div>
            <a href="/reservations-app/" style="font-size:11.5px; font-weight:600; color:var(--accent,#E2A23A); cursor:pointer;">Όλες →</a>
          </div>
          <div style="display:flex; flex-direction:column; gap:9px; flex:1;">
{% for r in reservations %}
            <div style="display:flex; align-items:center; gap:12px; padding:10px 11px; border-radius:11px; background:rgba(0,0,0,0.028);">
              <div style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:14px; color:var(--accent,#E2A23A); width:42px;">{{r.time}}</div>
              <div style="flex:1; min-width:0;"><div style="font-size:13.5px; font-weight:600; color:#1F2024; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{r.name}}</div><div style="font-size:11.5px; color:#868B94;">{{r.people}} άτομα · {{r.tables}}</div></div>
              {% if r.statusKind == 'ok' %}<span style="font-size:10.5px; font-weight:600; color:#1E9D62; background:rgba(70,201,138,0.12); padding:3px 8px; border-radius:20px;">{{r.statusLabel}}</span>{% else %}<span style="font-size:10.5px; font-weight:600; color:#C2891B; background:rgba(232,176,75,0.14); padding:3px 8px; border-radius:20px;">{{r.statusLabel}}</span>{% endif %}
            </div>
{% else %}
            <div style="padding:30px 11px; text-align:center; color:#9197A0; font-size:13px;">Καμία επόμενη κράτηση.</div>
{% endfor %}
          </div>
        </div>

      </div>

      <div style="display:grid; grid-template-columns:1.75fr 1fr; gap:16px; margin-bottom:16px;">

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 0 8px; display:flex; flex-direction:column; overflow:hidden;">
          <div style="display:flex; align-items:center; justify-content:space-between; padding:0 22px 14px;">
            <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Πρόσφατες παραγγελίες</div>
            <a href="/orders-app/" style="font-size:11.5px; font-weight:600; color:var(--accent,#E2A23A); cursor:pointer;">Όλες →</a>
          </div>
          <div style="display:grid; grid-template-columns:0.85fr 0.7fr 1.35fr 0.5fr 0.95fr 0.95fr 1fr; gap:12px; padding:0 22px 9px; font-size:11px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; color:#9197A0; border-bottom:1px solid rgba(0,0,0,0.07);">
            <span>Δελτίο</span><span>Τραπέζι</span><span>Σερβιτόρος</span><span style="text-align:center;">Καλ.</span><span style="text-align:right;">Σύνολο</span><span>Πληρωμή</span><span style="text-align:right;">Κατάσταση</span>
          </div>

{% for o in recentOrders %}
          <div style="display:grid; grid-template-columns:0.85fr 0.7fr 1.35fr 0.5fr 0.95fr 0.95fr 1fr; gap:12px; padding:13px 22px; align-items:center;{% if not loop.last %} border-bottom:1px solid rgba(0,0,0,0.04);{% endif %}" style-hover="background:rgba(0,0,0,0.022);">
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:13px; color:#1F2024;">#{{o.ticket}}</span>
            {% if o.isTakeAway %}<span style="font-size:12px; color:#868B94; display:inline-flex; align-items:center; gap:4px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 8h14l-1 12H6L5 8zM9 8a3 3 0 0 1 6 0"/></svg>{{o.tableLabel}}</span>{% else %}<span style="font-size:13px; color:#3C3F45;">{{o.tableLabel}}</span>{% endif %}
            <span style="font-size:13px; color:#3C3F45; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{o.waiter}}</span>
            <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#6A6F78; text-align:center;">{{o.covers}}</span>
            <span style="font-family:'JetBrains Mono',monospace; font-weight:600; font-size:13px; color:#16181C; text-align:right;">&euro;{{o.price}}</span>
            <span style="font-size:12px; color:#6A6F78;">{{o.payment}}</span>
            <span style="text-align:right;">{% if o.statusOpen %}<span style="font-size:11px; font-weight:700; color:var(--accent,#E2A23A); background:color-mix(in srgb,var(--accent,#E2A23A) 14%,transparent); padding:3px 9px; border-radius:20px;">{{o.statusLabel}}</span>{% else %}<span style="font-size:11px; font-weight:700; color:#6A6F78; background:rgba(0,0,0,0.06); padding:3px 9px; border-radius:20px;">{{o.statusLabel}}</span>{% endif %}</span>
          </div>
{% else %}
          <div style="padding:30px 22px; text-align:center; color:#9197A0; font-size:13px;">Δεν υπάρχουν παραγγελίες σήμερα ακόμη.</div>
{% endfor %}
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 20px 16px; display:flex; flex-direction:column;">
          <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C; margin-bottom:16px;">Ροή δραστηριότητας</div>
          <div style="display:flex; flex-direction:column; gap:0; flex:1;">
{% for a in activity %}
            <div style="display:flex; gap:12px;">
              <div style="display:flex; flex-direction:column; align-items:center;">
                {% if a.kind == 'order' %}<span style="width:30px; height:30px; border-radius:8px; background:color-mix(in srgb,var(--accent,#E2A23A) 14%,transparent); display:flex; align-items:center; justify-content:center; color:var(--accent,#E2A23A); flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg></span>{% elseif a.kind == 'payment' %}<span style="width:30px; height:30px; border-radius:8px; background:rgba(70,201,138,0.13); display:flex; align-items:center; justify-content:center; color:#1E9D62; flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>{% else %}<span style="width:30px; height:30px; border-radius:8px; background:rgba(91,160,201,0.14); display:flex; align-items:center; justify-content:center; color:#3B83B2; flex-shrink:0;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2.5"/><path d="M8 2v4M16 2v4M3 10h18"/></svg></span>{% endif %}
                {% if not loop.last %}<span style="width:1px; flex:1; background:rgba(0,0,0,0.07); margin:4px 0;"></span>{% endif %}
              </div>
              <div style="padding-bottom:14px;"><div style="font-size:13px; color:#1F2024;"><b style="font-weight:700;">{{a.title}}</b> · {{a.detail}}</div><div style="font-size:11.5px; color:#9197A0; margin-top:2px;">{{a.who}} · {{a.ago}}</div></div>
            </div>
{% else %}
            <div style="padding:24px; text-align:center; color:#9197A0; font-size:13px;">Καμία πρόσφατη δραστηριότητα.</div>
{% endfor %}
          </div>
        </div>

      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 22px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:18px;">
            <div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Κορυφαία είδη σήμερα</div>
            <a href="/admin/report" style="font-size:11.5px; font-weight:600; color:var(--accent,#E2A23A); cursor:pointer;">Αναφορά →</a>
          </div>
          <div style="display:flex; flex-direction:column; gap:15px;">
{% for it in topItems %}
            <div style="display:flex; align-items:center; gap:13px;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:#9197A0; width:14px;">{{loop.index}}</span>
              <div style="flex:1; min-width:0;"><div style="display:flex; justify-content:space-between; gap:10px; margin-bottom:6px;"><span style="font-size:13px; font-weight:600; color:#1F2024;">{{it.name}}</span><span style="font-family:'JetBrains Mono',monospace; font-size:12.5px; color:#868B94;">{{it.qty}} τεμ · <span style="color:#1F2024; font-weight:600;">{{it.revenue}}</span></span></div><div style="height:6px; border-radius:6px; background:rgba(0,0,0,0.05);"><div style="height:100%; width:{{it.pct}}%; border-radius:6px; background:var(--accent,#E2A23A);"></div></div></div>
            </div>
{% else %}
            <div style="padding:22px 0; text-align:center; color:#9197A0; font-size:13px;">Δεν υπάρχουν πωλήσεις σήμερα ακόμη.</div>
{% endfor %}
          </div>
        </div>

        <div style="background:#FFFFFF; border:1px solid rgba(0,0,0,0.07); border-radius:16px; padding:20px 22px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <div style="display:flex; align-items:center; gap:9px;"><div style="font-family:'Commissioner',sans-serif; font-weight:700; font-size:16px; color:#16181C;">Χαμηλό απόθεμα</div></div>
            <a href="/shopping-lists-app/update" style="font-size:11.5px; font-weight:600; color:var(--accent,#E2A23A); cursor:pointer;">Λίστα αγορών →</a>
          </div>
          <div style="display:flex; flex-direction:column; gap:2px; flex:1;">

            <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; gap:9px; padding:26px 8px;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C7CCD3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7M12 11v10"/></svg>
              <div style="font-size:13px; color:#868B94; max-width:240px; line-height:1.5;">Η παρακολούθηση αποθέματος δεν είναι ακόμη διαθέσιμη.</div>
            </div>
          
          </div>
          <a href="/shopping-lists-app/update" style="margin-top:14px; width:100%; padding:11px; border-radius:10px; background:rgba(0,0,0,0.045); border:1px solid rgba(0,0,0,0.09); cursor:pointer; font-family:'Mulish',sans-serif; font-weight:600; font-size:13px; color:#1F2024; display:flex; align-items:center; justify-content:center; gap:8px;" style-hover="background:rgba(0,0,0,0.08);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
            Δημιουργία λίστας αγορών
          </a>
        </div>

      </div>

    </div>
  </div>
</div>

<script>
(function () {
  // Replicate the design's style-hover behaviour
  document.querySelectorAll('[style-hover]').forEach(function (el) {
    var base = el.getAttribute('style') || '';
    var hover = el.getAttribute('style-hover');
    el.addEventListener('mouseenter', function () { el.setAttribute('style', base + ';' + hover); });
    el.addEventListener('mouseleave', function () { el.setAttribute('style', base); });
  });

  var ACCENT = '#E2A23A';

  // Time-range segmented control (cosmetic toggle, like the design)
  function rangeStyle(active) {
    return 'padding:6px 13px; border-radius:7px; border:none; cursor:pointer;'
      + " font-family:'Mulish',sans-serif; font-size:12.5px; letter-spacing:0.01em; transition:all .15s ease;"
      + ' font-weight:' + (active ? 700 : 600) + ';'
      + ' background:' + (active ? ACCENT : 'transparent') + ';'
      + ' color:' + (active ? '#1A1206' : '#6A6F78') + ';';
  }
  var rangeBtns = document.querySelectorAll('[data-range]');
  rangeBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      rangeBtns.forEach(function (x) { x.setAttribute('style', rangeStyle(false)); });
      b.setAttribute('style', rangeStyle(true));
    });
  });

  // Chart tabs — swap the line + meta the way the design does
  var paths = {
    revenue: '{{ chart.revenue.line }}',
    orders:  '{{ chart.orders.line }}',
    covers:  '{{ chart.covers.line }}'
  };
  var areas = {
    revenue: '{{ chart.revenue.area }}',
    orders:  '{{ chart.orders.area }}',
    covers:  '{{ chart.covers.area }}'
  };
  var meta = {
    revenue: { value: '{{ chart.revenue.value }}', sub: '{{ chart.revenue.sub }}' },
    orders:  { value: '{{ chart.orders.value }}', sub: '{{ chart.orders.sub }}' },
    covers:  { value: '{{ chart.covers.value }}', sub: '{{ chart.covers.sub }}' }
  };
  function tabStyle(active) {
    return 'padding:6px 13px; border-radius:8px; border:none; cursor:pointer;'
      + " font-family:'Mulish',sans-serif; font-size:12.5px; transition:all .15s ease;"
      + ' font-weight:' + (active ? 700 : 600) + ';'
      + ' background:' + (active ? 'rgba(0,0,0,0.07)' : 'transparent') + ';'
      + ' color:' + (active ? '#16181C' : '#868B94') + ';';
  }
  var line = document.getElementById('sopChartLine');
  var area = document.getElementById('sopChartArea');
  var mValue = document.getElementById('sopMetaValue');
  var mSub = document.getElementById('sopMetaSub');
  var tabBtns = document.querySelectorAll('[data-tab]');
  tabBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      var tab = b.getAttribute('data-tab');
      line.setAttribute('d', paths[tab]);
      area.setAttribute('d', areas[tab]);
      var m = meta[tab];
      mValue.textContent = m.value;
      mSub.textContent = m.sub;
      tabBtns.forEach(function (x) { x.setAttribute('style', tabStyle(x.getAttribute('data-tab') === tab)); });
    });
  });
})();
</script>
</body>
</html>
