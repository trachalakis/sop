{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'dashboard' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
</div>
<div class="row mb-3">
    <div class="col-6">
        <div class="card text-bg-light mb-3">
            <div class="card-header"><a class="text-decoration-none" href="/orders-app/">Orders</a></div>
            <div class="card-body">
                <h5 class="card-title">{{openOrders|length}} tables</h5>
                <p class="card-text">
                	{{adults}} adults, {{minors}} minors
                </p>
            </div>
        </div>
    </div>
    <div class="col-6">
        <div class="card text-bg-light mb-3">
            <div class="card-header"><a class="text-decoration-none" href="/reservations-app/">Reservations</a></div>
            <div class="card-body">
                <h5 class="card-title">{{todaysReservations|length}} Reservations</h5>
                <p class="card-text">5 adults / 9 minors</p>
            </div>
        </div>
    </div>
</div>
<div class="row">
