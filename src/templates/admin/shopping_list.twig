{% extends 'app_skeleton.twig' %}

{% set activeNavLink = 'shopping-lists' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-5 border-bottom">
    <h1 class="h2" id="shopping-list-date">Ψώνια {{shoppingList.getDate.format('D j M Y')}}</h1>
    <div class="btn-toolbar">
	    <button class="btn btn-primary btn-lg me-1" id="print-shopping-list"><i class='bx bx-printer' ></i></button>
	</div>
</div>
<form method="post" autocomplete="off">
	{% for supplyGroup in supplyGroups|filter(s => s.showInShoppingList) %}
		<div class="supply-group" data-name="{{supplyGroup.getName}}">
			<h5 class="mb-3 pb-2 border-bottom text-muted">{{supplyGroup.getName}}</h5>
			{% for supply in supplyGroup.getSupplies|filter(s => s.isActive) %}
				<div class="row mb-3 shopping-list-item">
					<label class="col-sm-3 offset-md-1 col-form-label">{{supply.getName}}</label>
					<div class="col-sm-7">
						<div class="input-group mb-3">
	  						<a class="input-group-text plus text-decoration-none fs-4" href="#">+</a>
	  						<input
	  							type="number"
	  							min="0"
	  							step="0.5"
	  							class="form-control"
	  							name="quantity[{{supply.getId}}]"
	  							value="{{shoppingList.supplyQuantity(supply)}}"
	  						/>
	  						<a class="input-group-text minus text-decoration-none fs-4" href="#">-</a>
						</div>
			    	</div>
				</div>
			{% endfor %}
		</div>
	{% endfor %}
	<hr/>
	<div class="row mb-3">
		<div class="col-sm-9 offset-sm-3">
			<button type="submit" class="btn btn-primary">Save</button>
		</div>
	</div>
</form>
{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script>
		$('.plus').click(function (evt) {
			evt.preventDefault();
			let next = $(this).next();
			next.val(parseFloat(next.val()) + 1);
		})

		$('.minus').click(function (evt) {
			evt.preventDefault();
			let prev = $(this).prev();
			if (prev.val() > 0 ) {
				prev.val(parseFloat(prev.val()) - 1);
			}
		})
	</script>
	<script src="/assets/js/epos-2.24.0.js"></script>
	<script>
		$('#print-shopping-list').click(function () {
			let printer = new epson.ePOSBuilder();
			printer.addFeedLine(3);
			printer.addTextAlign(printer.ALIGN_CENTER);
			printer.addTextSmooth(true);
			printer.addTextSize(2,2);
			printer.addText($('#shopping-list-date').html());
			printer.addTextSize(1,1);
			printer.addFeedLine(5);
			printer.addTextAlign(printer.ALIGN_LEFT);
			printer.addTextFont(printer.FONT_B);
			printer.addTextSize(2, 2);
			printer.addTextLineSpace(50);
			$('.supply-group').each(function (index) {
				let count = $(this).find('input').filter(function() {
  					return $(this).attr("value") > 0;
				}).length
				if (count > 0) {
					printer.addText($(this).data('name') + '\n');
					printer.addText('_'.repeat(32));
				}
			});
			/*$('.shopping-list-item').each(function (index) {
				let quantity = $(this).find('input').val()

				if (quantity > 0 ) {
					let name = $(this).find('label').html();
					let dots = '.'.repeat(32 - (name.length + quantity.length));
					printer.addText(`${name}${dots}${quantity}\n`);
				}
			});*/
			printer.addFeedLine(5);
			printer.addCut(printer.CUT_FEED);

			var address = `https://192.168.1.10/cgi-bin/epos/service.cgi?devid=local_printer&timeout=10000`;
				var epos = new epson.ePOSPrint(address);
				epos.onreceive = function (res) {
					if (!res.success) {
						alert(`A print error occurred.`);
					}
				}
				epos.send(printer.toString());
		});
	</script>
{% endblock %}