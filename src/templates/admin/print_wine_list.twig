<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <title>Menu | Almyriki.gr</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<style type="text/css">
		body {
			font-family: 'pfalfabeta', 'Aegithalos', Fallback, sans-serif;
		}

		@font-face {
    		font-family: Aegithalos;
    		src: url("/assets/fonts/aegithalos.otf") format("opentype");
		}

		.me-n {
			margin-right: -1.25rem !important;
		}

		.ms-n {
			margin-left: -1.25rem !important;
		}

		@font-face {
    		font-family: 'pfalfabeta';
    		src: url('/assets/fonts/pfalfabeta/pfalfabeta-regular.otf') format('opentype');
    		font-weight: normal;
    		font-style: normal;
		}
	</style>
</head>
<body contenteditable="true">
	<div class="container-fluid text-center">
		<div class="row mb-3">
			<div class="col-12 text-center">
				<img src="/assets/img/logo_no_name.png" height="100"/>
			</div>
		</div>
		{% for menuSection in menuSections %}
			{% if menuSection.getActiveMenuItems|length > 0 %}
				<div class="row mb-5">
					<div class="col">
						<div class="row mb-3">
							<div class="col">
								<h1 class="h4">{{menuSection.getTranslation(lang).getName}}</h1>
							</div>
						</div>
						{% for menuItem in menuSection.getMenuItems|filter(menuItem => menuItem.getIsPublic and menuItem.getIsActive) %}
							<div class="row mb-2">
								<div class="col text-end me-n">
									<h6 class="mb-0">
										{% if menuItem.getCustomField('name_el')| length > 0 %}
											{{menuItem.getCustomField('name_el')}} /
										{% endif %}
										{% if menuItem.getCustomField('aoc_el')| length > 0 %}
											{{menuItem.getCustomField('aoc_el')}} /
										{% endif %}
										{% if menuItem.getCustomField('winery_el')| length > 0 %}
											{{menuItem.getCustomField('winery_el')}}
										{% endif %}
									</h6>
									<p class="mb-1">
										{{menuItem.getCustomField('vintage')}} / {{menuItem.getCustomField('variety_el')}}
									</p>
								</div>
								<div class="col-1">
									&euro;{{menuItem.getPrice}}
									{% if menuItem.getCustomField('color') == 'red' %}
										<p>
											<svg height="20" width="20" xmlns="http://www.w3.org/2000/svg">
													<circle r="10" cx="10" cy="10" fill="#800020" />
											</svg>
										</p>
									{% endif %}
									{% if menuItem.getCustomField('color') == 'rose' %}
										<p>
											<svg height="20" width="20" xmlns="http://www.w3.org/2000/svg">
													<circle r="10" cx="10" cy="10" fill="#FFC5CB" />
											</svg>
										</p>
									{% endif %}
								</div>
								<div class="col text-start ms-n">
									<h6 class="mb-0">
										{% if menuItem.getCustomField('name_en')| length > 0 %}
											{{menuItem.getCustomField('name_en')}} /
										{% endif %}
										{% if menuItem.getCustomField('aoc_en')| length > 0 %}
											{{menuItem.getCustomField('aoc_en')}} /
										{% endif %}
										{% if menuItem.getCustomField('winery_en')| length > 0 %}
											{{menuItem.getCustomField('winery_en')}}
										{% endif %}
									</h6>
									<p class="mb-1">
										{{menuItem.getCustomField('vintage')}} / {{menuItem.getCustomField('variety_en')}}
									</p>
								</div>
							</div>
						{% endfor %}
					</div>
				</div>
			{% endif %}
		{% endfor %}
	</div>
</body>
</html>