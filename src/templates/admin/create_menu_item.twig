{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'menus' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">New item</h1>
</div>
<form method="post" autocomplete="off" enctype="multipart/form-data">
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Active</label>
		<div class="col-sm-10">
			<select class="form-select" name="isActive">
  				<option value="1" selected>Yes</option>
  				<option value="0">No</option>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Menu section</label>
		<div class="col-sm-10">
			<select class="form-select" name="menuSection">
  				{% for menuSection in menuSections %}
  					<option value="{{menuSection.getId}}">{{menuSection.getTranslation('en').getName}}</option>
  				{% endfor %}
			</select>
    	</div>
	</div>
	{% for language in languages %}
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label">Name [{{language.getIsoCode}}]</label>
			<div class="col-sm-10">
				<input type="text" class="form-control" name="translations[{{language.getId}}][name]" required/>
			</div>
		</div>
	{% endfor %}
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Position</label>
		<div class="col-sm-10">
			<input type="number" min="1" step="1" class="form-control" name="position" required/>
		</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Price</label>
		<div class="col-sm-10">
			<input type="number" min="0" step="0.5" class="form-control" name="price"/>
		</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Unit</label>
		<div class="col-sm-10">
			<select class="form-select" name="isPricePerKg">
				<option value="0">Item</option>
				<option value="1">Kg</option>
			</select>
		</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Is drink</label>
		<div class="col-sm-10">
			<select class="form-select" name="isDrink">
  				<option value="0">No</option>
  				<option value="1">Yes</option>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Stations</label>
		<div class="col-sm-10">
			<select class="form-select" name="stations[]" multiple>
				{% for station in stations %}
					<option value="{{station.getId}}">{{station.getName}}</option>
				{% endfor %}
			</select>
		</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Extras</label>
		<div class="col-sm-10">
			<a class="btn btn-sm btn-success add-extra">
				<i class="bx bx-plus"></i>
			</a>
		</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Public</label>
		<div class="col-sm-10">
			<select class="form-select" name="isPublic">
  				<option value="1">Yes</option>
  				<option value="0" selected>No</option>
			</select>
    	</div>
	</div>
	<hr/>
	<div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Save</button>
		</div>
	</div>
</form>
{% endblock %}

{% block javascript %}
	{{parent()}}
	<script src="https://cdnjs.cloudflare.com/ajax/libs/handlebars.js/4.7.7/handlebars.min.js" integrity="sha512-RNLkV3d+aLtfcpEyFG8jRbnWHxUqVZozacROI4J2F1sTaDqo1dPQYs01OMi1t1w9Y2FdbSCDSQ2ZVdAC8bzgAg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
	<script id="extra-template" type="text/x-handlebars-template">
        <div class="row extra-entry mb-2">
            <div class="col-sm-5">
                <input
                	type="text"
                	class="form-control"
                	name="extra[{% verbatim %}{{index}}{% endverbatim %}][name]"
                	required
                />
            </div>
            <div class="col-sm-5">
                <input
                	type="number"
                	step="0.5"
                	value="0"
                	class="form-control"
                	name="extra[{% verbatim %}{{index}}{% endverbatim %}][price]"
                	required
                />
            </div>
            <div class="col-sm-2">
                <a class="btn btn-sm btn-danger delete-extra">
                    <i class="bx bx-trash"></i>
                </a>
            </div>
        </div>
    </script>
    <script>
        $('.add-extra').click(function() {
            var source   = $('#extra-template').html();
            var template = Handlebars.compile(source);

            $(this).before(template({
                index: $('.extra-entry').length + 1
            }));
        });

        $('form').on('click', '.delete-extra', function() {
            $(this).parent().parent().remove();
        });
    </script>
{% endblock %}