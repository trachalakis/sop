{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'roles' %}

{% block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/roles" class="text-decoration-none">Ρόλοι</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <h1>Ρόλοι</h1>
    <div class="btn-toolbar">
        <a href="/admin/roles/create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i>
        </a>
    </div>
</div>
<table class="table table-responsive table-striped">
    <thead>
        <tr>
            <th>Ετικέτα</th>
            <th>Όνομα</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for role in roles %}
            <tr>
                <td>
                    <a class="text-decoration-none" href="/admin/roles/update?id={{role.getId}}">
                        {{role.getLabel}}
                    </a>
                </td>
                <td>
                    <code>{{role.getName}}</code>
                </td>
                <td class="text-end">
                    <a href="/admin/roles/delete?id={{role.getId}}" class="btn btn-sm btn-outline-danger confirm">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
