{% extends 'admin/skeleton.twig' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Update scan</h1>
</div>
<form method="post" autocomplete="off">
	<div class="row mb-3">
        <label class="col-md-2 col-form-label">Check in</label>
        <div class="col-md-10">
            <input
            	type="datetime-local"
            	name="checkIn"
            	class="form-control"
            	step="1"
            	value="{{scan.getCheckIn.format('Y-m-d\\TH:i:s')}}"
            />
        </div>
    </div>
    <div class="row mb-3">
        <label class="col-md-2 control-label">Check out</label>
        <div class="col-md-10">
            <input
            	type="datetime-local"
            	name="checkOut"
            	class="form-control"
            	step="1"
            	value="{{scan.getCheckOut.format('Y-m-d\\TH:i:s')}}"
            />
        </div>
    </div>
    <hr/>
    <div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Save</button>
			<a class="btn btn-danger confirm" href="/admin/scans/delete?id={{scan.getId}}">Delete</a>
		</div>
	</div>
</form>
{% endblock %}