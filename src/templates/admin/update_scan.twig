{% extends 'admin/skeleton.twig' %}

{% block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/scans" class="text-decoration-none">Ωράρια</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <h1>Επεξεργασία</h1>
    <div class="btn-toolbar">
       	<a href="/admin/scans/delete?id={{scan.getId}}" class="btn btn-danger confirm">
            <i class="bi bi-trash"></i>
        </a>
    </div>
</div>
<form method="post" autocomplete="off">
	<div class="row mb-3">
        <label class="col-md-2 col-form-label">Χρήστης</label>
        <div class="col-md-10">
            <input
            	type="text"
            	class="form-control"
                value="{{scan.getUser.getFullName}}"
                disabled
            />
        </div>
    </div>
    <div class="row mb-3">
        <label class="col-md-2 col-form-label">Αρχή</label>
        <div class="col-md-10">
            <input
            	type="datetime-local"
            	name="checkIn"
            	class="form-control"
            	step="1"
            	value="{{scan.getCheckIn.format('Y-m-d\\TH:i:s')}}"
            />
        </div>
    </div>
    <div class="row mb-3">
        <label class="col-md-2 control-label">Τέλος</label>
        <div class="col-md-10">
            <input
            	type="datetime-local"
            	name="checkOut"
            	class="form-control"
            	step="1"
            	value="{{scan.getCheckOut.format('Y-m-d\\TH:i:s')}}"
            />
        </div>
    </div>
    <hr/>
    <div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Αποθήκευση</button>
		</div>
	</div>
</form>
{% endblock %}