<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <title>Menu | Almyriki.gr</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500&display=swap" rel="stylesheet">
	<style type="text/css">
		@font-face {
  			font-family: 'Hellenica';
  			src:  url('/assets/fonts/PFHellenicaPro-Reg.woff2') format('woff2'),
        		url('/assets/fonts/PFHellenicaPro-Reg.woff2') format('woff');
		}

		body {
			font-family: 'Hellenica', Fallback, sans-serif;
		}
	</style>
</head>
<body contenteditable="true">
	<div class="container-fluid text-center">
		{% for menuSection in menuSections %}
			{% if menuSection.getActiveMenuItems|length > 0 %}
				<div class="row mb-4">
					<div class="col">
						<div class="row mb-1">
							<div class="col">
								<h1 class="h2">{{menuSection.getTranslation(lang).getName}}</h1>
							</div>
						</div>
						{% for menuItem in menuSection.getActiveMenuItems  %}
							{% if menuItem.getIsPublic %}
								<div class="row mb-1">
									<div class="col">
										<h5 class="mb-0">{{menuItem.getTranslation(lang).getName|split('/')[0]}} &centerdot; &euro;{{menuItem.getPrice}}</h5>
										<p class="mb-0">
											{% if menuItem.getCustomField('print_description_' ~ lang) %}
												{{menuItem.getCustomField('print_description_' ~ lang)}}
											{% endif %}
										</p>
									</div>
								</div>
							{% endif %}
						{% endfor %}
					</div>
				</div>
			{% endif %}
		{% endfor %}
	</div>
</body>
</html>