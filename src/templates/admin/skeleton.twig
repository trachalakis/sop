<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin | {{siteName}}</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous"
	>
	<link href="/assets/admin/css/dashboard.css" rel="stylesheet">
	{% block pageCss %}{% endblock %}
	<link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>
<body>
<header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
  	<a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6" href="/">Almyriki</a>
  	<button class="navbar-toggler position-absolute d-md-none collapsed" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
    	<span class="navbar-toggler-icon"></span>
  	</button>
  	<!--
	  	<input class="form-control form-control-dark w-100 rounded-0 border-0" type="text" placeholder="Search" aria-label="Search">
	  	<div class="navbar-nav">
	    	<div class="nav-item text-nowrap">
	      		<a class="nav-link px-3" href="/logout">Αποσύνδεση</a>
	    	</div>
	  	</div>
	-->
</header>
<div class="container-fluid">
	<div class="row">
		{% block sidebar %}
			<nav id="sidebarMenu" class="col-lg-2 col-md-3 d-md-block bg-light sidebar collapse">
				<div class="position-sticky pt-3 sidebar-sticky">
	        		<ul class="nav flex-column">
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'dashboard' ? 'active' : ''}}" href="/admin/">
						  		Αρχική
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/orders-app/">
						  		OrdersApp
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/reservations-app/">
						  		ReservationsApp
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'menus' ? 'active' : ''}}" href="/admin/menus">
						  		Μενού
							</a>
							{% if menus is defined %}
								<ul class="nav flex-column">
									{% for menu in menus|filter(m => m.getIsActive) %}
										<li class="nav-item">
											<a class="nav-link" style="padding-left:32px" href="/admin/menu?id={{menu.getId}}">
												{{menu.getName}}
											</a>
										</li>
									{% endfor %}
								</ul>
							{% endif %}
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'tables' ? 'active' : ''}}" href="/admin/tables">
								Τραπέζια
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'supplies' ? 'active' : ''}}" href="/admin/supplies">
								Προμήθειες
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'recipes' ? 'active' : ''}}" href="/admin/recipes">
								Συνταγές
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'printers' ? 'active' : ''}}" href="/admin/printers">
								Printers
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'scans' ? 'active' : ''}}" href="/admin/scans">
								Scans
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link {{activeNavLink == 'users' ? 'active' : ''}}" href="/admin/users">
								Χρήστες
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="/logout">
								Αποσύνδεση
							</a>
						</li>
	        		</ul>
	      		</div>
	    	</nav>
	    {% endblock %}
    	<main class="col-md-10 ms-sm-auto px-md-4">
    		{% block content %}{% endblock %}
    	</main>
    </div>
</div>
{% block javascript %}
	<script src="https://code.jquery.com/jquery-3.6.3.min.js" integrity="sha256-pvPw+upLPUjgMXY0G+8O0xUf+/Im1MZjXxxgOcBQBXU=" crossorigin="anonymous"></script>
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous">
    </script>
    <script
        src="https://cdnjs.cloudflare.com/ajax/libs/bootbox.js/6.0.0/bootbox.min.js"
        integrity="sha512-oVbWSv2O4y1UzvExJMHaHcaib4wsBMS5tEP3/YkMP6GmkwRJAa79Jwsv+Y/w7w2Vb/98/Xhvck10LyJweB8Jsw=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer">
    </script>
    <script src="/assets/js/popper.min.js"></script>
	<script>
		$('.confirm').click(function() {
    		return confirm("Are you sure?");
		});
	</script>
{%  endblock %}
</body>
</html>