{% extends 'admin/skeleton.twig' %}

{% block content %}
<h1 class="page-title">Menu items</h1>
<div class="row">
	<div class="col-md-12">
        <div class="portlet  ">
            <div class="portlet-body">
            	<div class="table-toolbar">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="btn-group">
                                <a href="/admin/menu-items/create" class="btn sbold green">
                                    <i class="fa fa-plus"></i> Add New
                                </a>
                            </div>
                        </div>
                    </div>
				</div>
                <div class="table-scrollable">
                    <table class="table table-striped table-hover">
                        {% for menuSection in menuSections %}
                            <tbody>
                                <tr>
                                    <th></th>
                                    <th colspan="4">{{menuSection.getName}}</th>
                                </tr>
                                {% for menuItem in menuSection.getMenuItems %}
                                	<tr>
    	                                <td>#{{menuItem.getId}}</td>
    	                                <td>
                                            {{menuItem.getName}} / &euro;{{menuItem.getPrice}}
                                            {% if menuItem.getIsActive %}
                                                <span class="label label-primary">Active</span>
                                            {% else %}
                                                <span class="label label-danger">Inactive</span>
                                            {% endif %}
                                        </td>
    	                                <td>
    	                                	<a class="btn btn-warning" href="/admin/menu-items/update?id={{menuItem.getId}}">Edit</a>
    	                                </td>
    	                            </tr>
                                {% endfor %}
                            </tbody>
                        {% endfor %}
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascript %}
    {{parent()}}
    <script>
        $('select').change(function () {
            $(this).parents('form').submit();
        });
    </script>
{% endblock %}