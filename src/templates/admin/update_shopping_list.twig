{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'shopping-lists' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Ψώνια</h1>
    <!--<div class="btn-toolbar">
	    <a href="" class="btn btn-outline-primary btn-lg"><i class='bx bx-printer' ></i></a>
	</div>-->
</div>
<form method="post" autocomplete="off">
	{% for supplyGroup in supplyGroups|filter(s => s.showInShoppingList) %}
		<h5 class="mb-3 pb-2 border-bottom text-muted">{{supplyGroup.getName}}</h5>
		{% for supply in supplyGroup.getSupplies|filter(s => s.isActive) %}
			<div class="row mb-3">
				<label class="col-sm-2 offset-md-1 col-form-label">{{supply.getName}}</label>
				<div class="col-sm-8">
					<input type="number" min="0" step="0.5" class="form-control" name="quantity[{{supply.getId}}]" value="0"/>
		    	</div>
			</div>
		{% endfor %}
	{% endfor %}
	<hr/>
	<div class="row mb-3">
		<div class="col-sm-9 offset-sm-3">
			<button type="submit" class="btn btn-primary">Save</button>
		</div>
	</div>
</form>
{% endblock %}