<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <title></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
    <style type="text/css">
		body {
			font-family: 'pfalfabeta', 'Aegithalos', Fallback, sans-serif;
		}

		@font-face {
    		font-family: Aegithalos;
    		src: url("/assets/fonts/aegithalos.otf") format("opentype");
		}

		@font-face {
    		font-family: 'pfalfabeta';
    		src: url('/assets/fonts/pfalfabeta/pfalfabeta-regular.otf') format('opentype');
    		font-weight: normal;
    		font-style: normal;
		}
	</style>
</head>
<body contenteditable="true">
	<div class="container-fluid text-center">
		<div class="row mb-3">
			<div class="col-12 text-center">
				<img src="/assets/img/logo_no_name.png" height="100"/>
			</div>
		</div>
		{% for menuSection in menuSections %}
			<div class="row mb-4">
                <div class="col">
                    <div class="row mb-1">
                        <div class="col">
                            <h1 class="h3">
                                {{menuSection.getTranslation('el').getName}} | {{menuSection.getTranslation('en').getName}} 
                            </h1>
                        </div>
                    </div>
                    {% for menuItem in menuSection.getActiveMenuItems %}
                        <div class="row mb-1">
                            <div class="col text-end me-n">
                                <h5 class="mb-0">
                                    {{(menuItem.getTranslation('el').getName|split('/'))[0]}}
                                </h5>
                                <p class="mb-1">
                                    {{menuItem.getCustomField('print_description_el')|nl2br}}
                                </p>
                            </div>
                            <div class="col-1">&euro;{{menuItem.getPrice}}</div>
                            <div class="col text-start ms-n">
                                <h5 class="mb-0">
                                    {{(menuItem.getTranslation('en').getName|split('/'))[0]}}
                                </h5>
                                <p class="mb-1">
                                    {{menuItem.getCustomField('print_description_en')|nl2br}}
                                </p>
                            </div>
                        </div>
			        {% endfor %}
                </div>
            </div>
		{% endfor %}
	</div>
</body>
</html>