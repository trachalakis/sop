{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'printers' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Δημιουργία εκτυπωτή</h1>
</div>
<form method="post" autocomplete="off">
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Ενεργός</label>
		<div class="col-sm-10">
			<select class="form-select" name="isActive">
  				<option value="1">Ναί</option>
  				<option value="0">Όχι</option>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Όνομα</label>
		<div class="col-sm-10">
			<input type="text" class="form-control" name="name" value="" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Τύπος</label>
		<div class="col-sm-10">
			{% for printerType in printerTypes %}
				<div class="form-check form-check-inline">
					<input 
						class="form-check-input" 
						type="radio" 
						id="printer-type-{{loop.index}}" 
						value="{{printerType.value}}" 
						name="printerType"
						required
					>
					<label class="form-check-label" for="printer-type-{{loop.index}}">{{printerType.value|replace({'_': ' '})|capitalize}}</label>
				</div>
			{% endfor %}
		</div>
	</div>
	<div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Αποθήκευση</button>
		</div>
	</div>
</form>
{% endblock %}