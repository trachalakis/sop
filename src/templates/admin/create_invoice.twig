{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'invoices' %}

{%  block content %}{% verbatim %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">New invoice</h1>
</div>
<div id="invoiceApp">
	<form method="post" autocomplete="off" @submit.prevent="createInvoice">
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label">Type</label>
			<div class="col-sm-10">
				<select class="form-select" tabindex="1" v-model="invoice.type">
	            	<option value="normal" selected>Normal</option>
	            	<option value="credit">Credit</option>
	            </select>
	    	</div>
		</div>
		<div class="row mb-3">
	        <label class="col-sm-2 col-form-label">Supplier</label>
	        <div class="col-sm-10">
	            <input class="form-control" list="suppliers" tabindex="2" required v-model="invoice.supplier"/>
	        </div>
	    </div>
	    <div class="row mb-3">
			<label class="col-sm-2 col-form-label">Invoice number</label>
			<div class="col-sm-10">
				<input type="text" class="form-control" tabindex="3" required v-model="invoice.invoiceNumber"/>
	    	</div>
		</div>
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label">Invoice date</label>
			<div class="col-sm-10">
				<input type="date" class="form-control" tabindex="4" required v-model="invoice.date"/>
	    	</div>
		</div>
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label"></label>
			<div class="col-sm-10">
				<div class="row mb-2">
					<div class="col"><label>Supply</label></div>
					<div class="col"><label>Quantity</label></div>
					<div class="col"><label>Unit</label></div>
					<div class="col"><label>Price</label></div>
					<div class="col"><label>Vat</label></div>
					<div class="col"><label>Vat %</label></div>
				</div>
				<div class="row mb-3 gx-1" v-for="(invoiceEntry, index) in invoice.invoiceEntries">
	    			<div class="col">
	    				<input
	    					class="form-control"
	    					list="supplies"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 5"
	    					v-model="invoiceEntry.supply"
	    					@change="autoFillEntryParams(invoiceEntry.supply, index)"
	    				/>
	    			</div>
	    			<div class="col">
	    				<input
	    					type="number"
	    					min="0"
	    					step="0.001"
	    					class="form-control"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 6"
	    					v-model="invoiceEntry.quantity"
	    				/>
	    			</div>
	    			<div class="col">
	    				<select
	    					class="form-select"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 7"
	    					v-model="invoiceEntry.unit"
	    				>
	    					<option value="item">Tεμ</option>
		            		<option value="kg">Kg</option>
		            		<option value="lt">Lt</option>
	    				</select>
	    			</div>
	    			<div class="col">
	    				<input
	    					type="number"
	    					step="0.01"
	    					class="form-control"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 8"
	    					v-model="invoiceEntry.price"
	    				/>
	    			</div>
	    			<div class="col">
	    				<input
	    					type="number"
	    					step="0.01"
	    					class="form-control"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 9"
	    					v-model="invoiceEntry.vat"
	    				/>
	    			</div>
	    			<div class="col">
	    				<input
	    					type="number"
	    					step="1"
	    					class="form-control"
	    					:data-index="index"
	    					:tabindex="(index * 5) + 10"
	    					v-model="invoiceEntry.vatPercentage"
	    				/>
	    			</div>
	    		</div>
	    		<a class="btn btn-sm btn-success" @click="addInvoiceEntry()">
					<i class="fa fa-plus"></i>
				</a>
			</div>
		</div>
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label">Vat</label>
			<div class="col-sm-10">
				<input
					type="number"
					step="0.01"
					class="form-control"
					required
					:tabindex="(invoice.invoiceEntries.length * 6) + 5"
					v-model="invoice.vat"
				/>
	    	</div>
		</div>
		<div class="row mb-3">
			<label class="col-sm-2 col-form-label">Total</label>
			<div class="col-sm-10">
				<input
					type="number"
					step="0.01"
					class="form-control"
					required
					:tabindex="(invoice.invoiceEntries.length * 6) + 6"
					v-model="invoice.total"
				/>
	    	</div>
		</div>
		<hr/>
		<div class="row mb-3">
			<div class="col-sm-10 offset-sm-2">
				<button type="submit" class="btn btn-primary" :tabindex="(invoice.invoiceEntries.length * 6) + 7">Save</button>
			</div>
		</div>
	</form>

	<datalist id="suppliers">
		<option v-for="supplier in suppliers" :value="supplier.name"/>
	</datalist>
	<datalist id="supplies">
		<option v-for="supply in supplies" :value="supply.name"/>
	</datalist>
</div>
{% endverbatim %}{% endblock %}

{% block javascript %}
	{{parent()}}
	<!--<script src="https://unpkg.com/vue-multiselect@2.1.0"></script>-->
	<script src="https://unpkg.com/vue@3"></script>
	<script src="https://unpkg.com/axios"></script>
	<script src="https://unpkg.com/lodash"></script>
	<script>
		//Vue.component('vue-select', window.VueMultiselect.default)
		//import invoiceEntry from '/assets/admin/js/invoiceEntry.js';

		vueApp = Vue.createApp({
		  	data() {
		  		return {
			  		invoice: {
			  			type: 'normal',
			  			supplier: null,
			  			invoiceNumber: null,
			  			comments: null,
			  			date: null,
			  			invoiceEntries: [{}, {}, {}, {}, {}, {}, {}, {}],
			  			vat: null,
			  			total: null
			  		},
			  		suppliers: [],
			  		supplies: [],
			  	}
		  	},
		  	components: {
            	//'InvoiceEntry': Vue.defineAsyncComponent( () => import('/assets/admin/js/invoiceEntry.js'))
        	},
        	watch: {
		        'invoice.invoiceEntries': {
		            handler: function ()  {
		                this.updatePartialSums();
		            },
		            deep: true
		        }
		    },
		  	mounted () {
		  		axios({
                    url: '/admin/graph-ql',
                    method: 'post',
                    data: `{
                        suppliers {
                            id, name
                        },
                        supplies {
                        	id, name, unit, vatPercentage
                        }
                    }`
                }).then(response => {
                    this.suppliers = response.data.data.suppliers
                    this.supplies = response.data.data.supplies
                });

                document.onkeydown = e => {
				    if (e.key === "a" && (e.ctrlKey)) {
				    	e.preventDefault();

				    	this.addInvoiceEntry();
				    }

				    if (e.key === "d" && (e.ctrlKey)) {
				    	e.preventDefault();

				    	this.removeInvoiceEntry(document.activeElement.dataset.index);
				    }
				};
		  	},
		  	computed: {
                total () {
                    return _.floor(_.sumBy(
                        this.invoice.invoiceEntries,
                        e => {
                            if (e.price > 0) {
                                return e.price * (1 + (e.vatPercentage / 100))
                            } else {
                                return 0;
                            }
                        }
                    ), 2);
                },
                vat () {
                    return _.ceil(_.sumBy(
                        this.invoice.invoiceEntries,
                        e => {
                            if (e.price > 0) {
                                return e.price * (e.vatPercentage / 100)
                            } else {
                                return 0;
                            }
                        }
                    ), 2);
                }
		  	},
		  	methods: {
		  		updatePartialSums: function () {
		  			invoiceVat = 0;
		  			invoiceTotal = 0;

		  			_.forEach(this.invoice.invoiceEntries, (invoiceEntry) => {
		  				if (invoiceEntry.price > 0 && invoiceEntry.vatPercentage > 0) {
		  					invoiceEntry.vat = _.ceil(invoiceEntry.price * (invoiceEntry.vatPercentage / 100), 2);

		  					invoiceVat += invoiceEntry.vat;
		  					invoiceTotal += invoiceEntry.price + invoiceEntry.vat;
		  				}
		  			});

		  			this.invoice.vat = Number.parseFloat(invoiceVat).toFixed(2);
		  			this.invoice.total = Number.parseFloat(invoiceTotal).toFixed(2);
		  		},
		  		addInvoiceEntry: function () {
		  			this.invoice.invoiceEntries.push({});
		  		},
		  		removeInvoiceEntry: function (index) {
		  			this.invoice.invoiceEntries.splice(index, 1);
		  		},
		  		createInvoice: function () {
		  			axios.post('/admin/invoices/create', this.invoice)
						.then(response => {
							window.location = '/admin/invoices/create';
						})
						.catch(function (error) {
							alert('Could not save order.');
						});
		  		},
		  		autoFillEntryParams: function (supplyName, index) {
		  			let i = _.findIndex(this.supplies,
		    			s => s.name == supplyName
		    		);

		  			if (i > -1) {
			    		this.invoice.invoiceEntries[index].unit = this.supplies[i].unit;
			    		this.invoice.invoiceEntries[index].vatPercentage = this.supplies[i].vatPercentage;
			    	}
		  		}
		  	}
		}).mount('#invoiceApp');
	</script>
{% endblock %}