{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'printers' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Εκτυπωτές</h1>
    <div class="btn-toolbar">
       	<a href="/admin/printers/create" class="btn btn-primary">
            Νέος εκτυπωτής
        </a>
    </div>
</div>
<table class="table table-striped table-responsive">
	<!--<thead>
  		<tr>
  			<th>Table</th>
  			<th></th>
  		</tr>
	</thead>-->
	<tbody>
		{% for printer in printers %}
			<tr>
				<td>
					<a class="text-decoration-none" href="/admin/printers/update?id={{printer.getId}}">{{printer.getName}}</a>
					{% if not printer.getIsActive %}
						<span class="badge rounded-pill text-bg-danger">ανενεργό</span>
					{% endif %}
				</td>
				<td class="text-end">
					<a class="text-decoration-none text-danger confirm" href="/admin/printers/delete?id={{printer.getId}}">
						Διαγραφή
					</a>
				</td>
			</tr>
		{% endfor %}
	</tbody>
</table>
{% endblock %}