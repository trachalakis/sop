<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <title></title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous"
	>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
    <style type="text/css">
		body {
			font-family: "EB Garamond", serif;
            font-optical-sizing: auto;
            font-weight: 400;
            font-style: normal;
		}
	</style>
</head>
<body contenteditable="true">
	<div class="container-fluid text-center">
		<div class="row mb-3">
			<div class="col-12 text-center">
				<img src="/assets/logo.jpg" height="100"/>
			</div>
		</div>
		{% for menuSection in menuSections %}
			<div class="row mb-4">
                <div class="col">
                    <div class="row mb-1">
                        <div class="col">
                            <h1 class="h3">
                                {{menuSection.getTranslation('el').getName}} | {{menuSection.getTranslation('en').getName}} 
                            </h1>
                        </div>
                    </div>
                    {% for menuItem in menuSection.getActiveMenuItems
                        |filter(
                            m => m.getCustomField('print_menu_description_en')|length > 0 and 
                            m.getCustomField('print_menu_description_el')|length > 0
                        )
                    %}
                        <div class="row mb-1">
                            <div class="col text-end me-n">
                                <h5 class="mb-0">
                                    {{(menuItem.getTranslation('el').getName|split('/'))[0]}}
                                </h5>
                                <p class="mb-1">
                                    {{menuItem.getCustomField('print_menu_description_el')|nl2br}}
                                </p>
                            </div>
                            <div class="col-1">&euro;{{menuItem.getPrice}}</div>
                            <div class="col text-start ms-n">
                                <h5 class="mb-0">
                                    {{(menuItem.getTranslation('en').getName|split('/'))[0]}}
                                </h5>
                                <p class="mb-1">
                                    {{menuItem.getCustomField('print_menu_description_en')|nl2br}}
                                </p>
                            </div>
                        </div>
			        {% endfor %}
                </div>
            </div>
		{% endfor %}
	</div>
</body>
</html>