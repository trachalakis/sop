{% block javascript %}
	{{parent()}}
<script 
    src="https://cdnjs.cloudflare.com/ajax/libs/handlebars.js/4.7.7/handlebars.min.js"
    integrity="sha512-RNLkV3d+aLtfcpEyFG8jRbnWHxUqVZozacROI4J2F1sTaDqo1dPQYs01OMi1t1w9Y2FdbSCDSQ2ZVdAC8bzgAg=="
    crossorigin="anonymous"
    referrerpolicy="no-referrer">
</script>

    <script id="ingredient-template" type="text/x-handlebars-template">
        <div class="row mb-2">
            <div class="ingredient-entry input-group">
                <input
                    type="text"
                    class="form-control"
                    name="ingredients[{% verbatim %}{{index}}{% endverbatim %}][quantity]"
                    required
                />
                <span class="input-group-text">/</span>
                <select name="ingredients[{% verbatim %}{{index}}{% endverbatim %}][supply]">
                    {% for supplyGroup in supplyGroups %}
                        <optgroup label="{{supplyGroup.getName}}">
                            {% for supply in supplyGroup.getSupplies %}
                                <option
                                    value="{{supply.getId}}"
                                    
                                    {{ingredient.getSupply == supply ? 'selected' : ''}}
                                >
                                    {{supply.getName}}
                                </option>
                            {% endfor %}
                        </optgoup>
                    {% endfor %}
                </select>
                <button class="btn btn-outline-danger delete-ingredient confirm">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    </script>
    <script>
        $('.add-ingredient').click(function() {
            var source   = $('#ingredient-template').html();
            var template = Handlebars.compile(source);

            $(this).before(template({
                index: $('.ingredient-entry').length + 1
            }));
        });

        $('form').on('click', '.delete-ingredient', function(e) {
            e.preventDefault();
            let self = $(this);

            bootbox.confirm({
                title: 'Απαιτείται επιβεβαίωση',
                message: "Είστε σίγουρος ότι θέλετε να προχωρήσετε;",
                buttons: {
                    confirm: {
                        label: 'Ναί',
                        className: 'btn-primary'
                    },
                    cancel: {
                        label: 'Όχι',
                        className: 'btn-secondary'
                    }
                },
                callback: function (result) {
                    if (result) {
                        self.parent().parent().remove();
                    }
                }
            });
        });
    </script>
{% endblock %}