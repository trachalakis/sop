    <hr/>
	<div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Save</button>
		</div>
	</div>
</form>#}
<datalist id="supplies">
	{% for supply in supplies %}
		<option value="{{supply.getId}}" label="{{supply.getName}} ({{supply.getPriceUnit}})"/>
	{% endfor %}
</datalist>
{% endblock %}
