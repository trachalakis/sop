{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'roles' %}

{% block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/roles" class="text-decoration-none">Ρόλοι</a>
    </li>
</ol>
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-1 mb-3 border-bottom">
    <h1>{{role.getLabel}}</h1>
</div>
<form method="post" autocomplete="off">
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">Ετικέτα</label>
        <div class="col-sm-10">
            <input type="text" class="form-control" name="label" value="{{role.getLabel}}" required/>
            <div class="form-text">Εμφανίζεται στη διεπαφή (π.χ. «Σερβιτόρος»)</div>
        </div>
    </div>
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">Όνομα</label>
        <div class="col-sm-10">
            <input type="text" class="form-control" name="name" value="{{role.getName}}" required pattern="[a-z0-9_]+" title="Μόνο πεζά γράμματα, αριθμοί και κάτω παύλα"/>
            <div class="form-text">Μοναδικό αναγνωριστικό, χρησιμοποιείται εσωτερικά. Αλλαγή θα επηρεάσει χρήστες που έχουν αυτόν τον ρόλο.</div>
        </div>
    </div>
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">Ελάχιστες ώρες</label>
        <div class="col-sm-10">
            <input type="number" step="0.5" min="0" class="form-control" name="minimumManHours" value="{{role.getMinimumManHours}}"/>
            <div class="form-text">Ελάχιστες ώρες ανθρωποχρόνου που απαιτούνται για τη σωστή λειτουργία του ρόλου.</div>
        </div>
    </div>
    <hr/>
    <div class="row mb-3">
        <div class="col-sm-10 offset-sm-2">
            <button type="submit" class="btn btn-primary">Αποθήκευση</button>
            <a href="/admin/roles" class="btn btn-secondary ms-2">Ακύρωση</a>
        </div>
    </div>
</form>
{% endblock %}
