{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'users' %}

{% block content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Νέος χρήστης</h1>
</div>
<form method="post" autocomplete="off">
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Active</label>
		<div class="col-sm-10">
			<select class="form-select" name="isActive">
  				<option value="1" selected>Yes</option>
  				<option value="0">No</option>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Name</label>
		<div class="col-sm-10">
			<input type="text" class="form-control" name="fullName" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Email</label>
		<div class="col-sm-10">
			<input type="email" class="form-control" name="emailAddress"/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Password</label>
		<div class="col-sm-10">
			<input type="text" class="form-control" name="password" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Hourly rate</label>
		<div class="col-sm-10">
			<input type="number" step="0.5" min="0" class="form-control" name="hourlyRate"/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Monthly credits</label>
		<div class="col-sm-10">
			<input type="number" step="1" min="0" class="form-control" name="monthlyCredits" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Roles</label>
		<div class="col-sm-10">
			<select class="form-select" name="roles[]" size="15" multiple>
  				<option value="webmaster">webmaster</option>
				<option value="employee">employee</option>
				<optgroup label="B.O.H">
					<option value="boh">boh</option>
					<option value="warm_cuisine">warm_cuisine</option>
					<option value="cold_cuisine">cold_cuisine</option>
					<option value="prep">prep</option>
				</optgroup>
				<optgroup label="F.O.H">
					<option value="foh">foh</option>
					<option value="waiter">waiter</option>
					<option value="reservations_manager">reservations manager</option>
					<option value="assistant_waiter">assistant waiter</option>
					<option value="bar">bar</option>
					<option value="terminal">terminal</option>
				</optgroup>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Menu access</label>
		<div class="col-sm-10">
			<select class="form-select" name="allowedMenus[]" multiple>
  				{% for menu in menus %}
					<option value="{{menu.getId}}">{{menu.getName}}</option>
				{% endfor %}
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Σημειώσεις</label>
		<div class="col-sm-10">
			<textarea rows="5" class="form-control" name="notes"></textarea>
    	</div>
	</div>
	<hr/>
	<div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Save</button>
		</div>
	</div>
</form>
{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script>
		$('input[name=password]').val(Math.random().toString(36).slice(2));
	</script>
{%  endblock %}