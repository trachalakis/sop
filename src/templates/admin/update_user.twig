{% extends 'admin/skeleton.twig' %}

{% set activeNavLink = 'users' %}

{% block content %}
<ol class="breadcrumb pt-3">
    <li class="breadcrumb-item">
        <a href="/admin/" class="text-decoration-none">
            <i class="bi bi-house"></i>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="/admin/users" class="text-decoration-none">Χρήστες</a>
    </li>
</ol>
<ul class="nav nav-tabs mb-4">
	<li class="nav-item">
    	<a class="nav-link fs-5 active" href="/admin/users/update?id={{user.getId}}">{{user.getFullName}}</a>
  	</li>
  	<li class="nav-item">
    	<a class="nav-link fs-5" href="/admin/scans/user?id={{user.getId}}">Ωράρια</a>
  	</li>
  	<li class="nav-item">
    	<a class="nav-link fs-5" href="/admin/users/orders?id={{user.getId}}">Αυτοπαραδόσεις</a>
  	</li>
</ul>
<form method="post" autocomplete="off">
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Ενεργός</label>
		<div class="col-sm-10">
			<select class="form-select" name="isActive">
  				<option value="1" {{user.getIsActive ? 'selected' : ''}}>Ναί</option>
  				<option value="0" {{user.getIsActive ? '' : 'selected'}}>Όχι</option>
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Όνομα</label>
		<div class="col-sm-10">
			<input type="text" class="form-control" name="fullName" value="{{user.getFullName}}" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Email</label>
		<div class="col-sm-10">
			<input type="email" class="form-control" name="emailAddress" value="{{user.getEmailAddress}}" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Συνθηματικό</label>
		<div class="col-sm-10">
			<div class="input-group mb-3">
  				<input type="text" class="form-control" name="password">
  				<button class="btn btn-outline-primary" type="button" id="generate-password">Generate</button>
			</div>
    	</div>
		
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Ωρομίσθιο</label>
		<div class="col-sm-10">
			<input type="number" step="0.5" min="4" class="form-control" name="hourlyRate" value="{{user.getHourlyRate}}" required/>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Roles</label>
		<div class="col-sm-10">
			<select class="form-select" name="roles[]" size="15" multiple>
				{% set userRoleNames = user.getRoles()|map(r => r.getName) %}
				{% for userRole in userRoles %}
                    <option value="{{userRole.getName}}" {{userRole.getName in userRoleNames ? 'selected' : ''}}>{{userRole.getLabel}}</option>
                {% endfor %}
			</select>
    	</div>
	</div>
	<div class="row mb-3">
		<label class="col-sm-2 col-form-label">Σημειώσεις</label>
		<div class="col-sm-10">
			<textarea rows="5" class="form-control" name="notes">{{user.getNotes}}</textarea>
    	</div>
	</div>
	<hr/>
	<div class="row mb-3">
		<div class="col-sm-10 offset-sm-2">
			<button type="submit" class="btn btn-primary">Αποθήκευση</button>
		</div>
	</div>
</form>
{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script>
		$('#generate-password').click(function () {
			$('input[name=password]').val(Math.random().toString(36).slice(2));
		})
	</script>
{%  endblock %}