{% extends 'admin/skeleton.twig' %}

{% block content %}
<h1 class="page-title">Menu sections</h1>
<div class="row">
	<div class="col-md-12">
        <div class="portlet  ">
            <div class="portlet-body">
                <div class="table-toolbar">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="btn-group">
                                <a href="/admin/menu-sections/create" class="btn sbold green"> Add New
                                    <i class="fa fa-plus"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-scrollable">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for menuSection in menuSections %}
                            	<tr>
	                                <td>{{menuSection.getName}} [{{menuSection.getPosition}}]</td>
	                                <td>
	                                	<a class="btn btn-warning" href="/admin/menu-sections/update?id={{menuSection.getId}}">Edit</a>
	                                	<a class="btn btn-danger" href="/admin/menu-sections/delete?id={{menuSection.getId}}">Delete</a>
	                                </td>
	                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}