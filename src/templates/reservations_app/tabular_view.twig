{% extends 'orders_app/skeleton.twig' %}

{% block pageCss %}
    {{ parent() }}
    <style>
        @media print {
            a {
            	color: #000;
            }

            header, .header, .btn, .actions, .badge {
                display: none !important;
            }

            td {font-size:  11px !important}
        }
    </style>
{%  endblock %}

{% block content %}{% verbatim %}
<div id="app">
	<div class="header d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
	    <h1>
		    <a class="text-decoration-none" href="/orders-app/"><i class="bi bi-house"></i></a>
		    / <i class="bi bi-telephone"></i>
		</h1>
	    <!--<div class="btn-toolbar">
	       	<a href="/reservations-app/print" class="btn btn-primary btn-lg me-1"><i class='bx bx-printer' ></i></a>
	       	<a href="/reservations-app/create" class="btn btn-primary btn-lg">Νέα κράτηση</a>
	    </div>-->
	</div>
	<div class="row gx-1 mb-2">
		<div class="col">
			<div class="header d-flex justify-content-between">
				<a class="btn btn-primary btn-lg " href="">
		            <i class="bi bi-chevron-left"></i>
		        </a>
		        <h2 class="mb-0"></h2>
		        <a class="btn btn-primary btn-lg" href="">
		            <i class="bi bi-chevron-right"></i>
		        </a>
			</div>
		</div>
	</div>
	<table class="table table-striped table-bordered fs-4 mt-4">
		<thead>
		    <tr>
		    	<th scope="col">Table</th>
		      	<th scope="col" v-for="timeSlot in timeSlots">{{timeSlot}}</th>
		    </tr>
	  	</thead>
		<tbody>
			<tr v-for="table in tables">
				<td>{{table.name}}</td>
				<td v-for="i in timeSlots.length" @click="showReservationsModal = true"></td>
			</tr>
		</tbody>
	</table>

	<div class="modal modal-lg d-block" v-if="showReservationsModal">
		<div class="modal-dialog">
			<div class="modal-content">
	  			<div class="modal-header">
	    			<h5 class="modal-title">Κρατήσεις</h5>
	    			<button type="button" class="btn-close" @click="showReservationsModal = false" ></button>
	  			</div>
	  			<div class="modal-body">
					<div class="row gx-1">
		        		<div class="col-sm-6 mb-2" v-for="reservation in todaysReservations">
		        			<div class="btn-group w-100">
  								<button
  									type="button"
  									class="btn btn-lg btn-outline-primary w-75"
  									@click="
	  									return;
	  								"
	  								:disabled="cellHours > getHours(reservation.dateTime)"
  								>
  									{{getTime(reservation.dateTime)}} / {{reservation.adults}} / {{reservation.minors}} / {{reservation.name}}
  								</button>
							</div>
		        		</div>
		        	</div>
      			</div>
			</div>
		</div>
	</div>
</div>

{% endverbatim %}{% endblock %}

{% block javascript %}
	{{ parent() }}
	<script src="https://unpkg.com/vue@3.4.30"></script>
	<script src="https://unpkg.com/axios"></script>
	<script>
		vueApp = Vue.createApp({
		    data() {
		    	return {
		    		showReservationsModal: false,
		    		cellHours: null,
		    		tables: [],
		    		todaysReservations: [],

		    		timeSlots: [
		    			'12:30', '13:00', '13:30', '14:00', '14:30', '15:00', '15:30', '16:00',
		    			'16:30', '17:00', '17:30', '18:00', '18:30', '19:00', '19:30', '20:00',
		    			'20:30', '21:00', '21:30', '22:00', '22:30'
		    		]
		    	}
		    },
		    computed: {
		    	futureReservations () {
		    	},
		    	/*timeSlots () {
		    		return ['12:30', '13:00', '13:30', '14:00', '14:30', '15:00', '15:30', '16:00'];
		    	}*/
		    },
		    mounted () {
		    	//console.log(new Date('March 13, 08 12:20').getHours());

		    	//setInterval(() => {
					//this.fetchOrders()
				//}, 5000)
                this.fetchReservations();
		    },
		    methods: {
		    	/*timeSlots () {
		    		let timeSlots = [];
		    		hour = new Date('March 13, 08 12:20').getHours();

		    		let firstHour = Math.max(hour - 1, 12);
		    		let lastHour = Math.min(hour + 5, 23);

		    		for(i = firstHour; i<= lastHour; i++) {
		    			timeSlots.push(i + ':00')
		    			timeSlots.push(i + ':30')
		    		}

		    		return timeSlots;
		    	},*/
		    	fetchReservations () {
		    		axios({
	                    url: '/admin/graph-ql',
	                    method: 'post',
	                    data: `{
	                        todaysReservations {
	                        	id, name, comments, dateTime, adults, minors
	                        }
	                    }`
	                }).then(response => {
	                    //this.tables = response.data.data.tables
	                    this.todaysReservations = response.data.data.todaysReservations
	                });
		    	},
		    	getTime(date) {
		    		return date.substr(date.length - 8, 5);
		    	},
		    	getHours(date) {
		    		return parseInt(this.getTime(date).replace(':', ''));
		    	}
		    }
		}).mount('#app');
	</script>
{% endblock %}